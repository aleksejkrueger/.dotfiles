// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation::
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "split",
  "edit_predictions": {
    "allow_data_collection": "no",
    "provider": "zed"
  },
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "zsh",
        "args": [],
        "title_override": null,
      },
    },
  },
  "cli_default_open_behavior": "existing_window",
  "proxy": "",
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
  },
  "minimap": {
    "show": "auto",
  },
  "ui_font_family": ".ZedSans",
  "disable_ai": false,
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "codex",
      "model": "gpt-5.4",
    },
    "model_parameters": [],
  },
  "outline_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "dock": "left",
  },
  "ui_font_size": 17,
  "buffer_font_size": 15,
  "buffer_font_family": "Monaco Nerd Font",
  "theme": {
    "mode": "system",
    "light": "Dracula",
    "dark": "Dracula",
  },
}
