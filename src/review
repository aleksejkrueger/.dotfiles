    def add_jira_comment_from_popup(self, config: JiraConfig, issue: JiraIssue) -> tuple[JiraIssue, str]:
        """Prompt for and post a Jira comment from the ticket popup."""
        body = prompt(self.screen, "jira comment> ")
        if body is None:
