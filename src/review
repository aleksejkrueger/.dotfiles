    if not success:
        die(f"could not reply to GitHub comment {note.note_id}\n{output}")
    print(f"posted github reply to comment {note.note_id}")


def post_remote_reply(provider: str, thread: RemoteThread, note: RemoteNote, body: str) -> None:
    """Post a reply to a remote review thread or comment."""
    if provider == "gitlab":
        post_gitlab_reply(thread, body)
    elif provider == "github":
        post_github_reply(thread, note, body)
    else:
        die(f"unsupported provider: {provider}")


def toggle_remote_thread_resolved(provider: str, thread: RemoteThread) -> str:
    """Toggle resolved state for a remote thread when the provider supports it."""
    if provider != "gitlab":
        return "Resolve toggle is only supported for GitLab threads."
    target_state = not thread.resolved
    output = StringIO()
    with redirect_stdout(output), redirect_stderr(output):
        try:
            set_gitlab_thread_resolved(thread, target_state)
        except SystemExit:
            detail = output.getvalue().strip().splitlines()
            return detail[-1] if detail else "Resolve toggle failed."
        except Exception as error:
            return f"Resolve toggle failed: {error}"
    state = "resolved" if target_state else "unresolved"
    return f"Marked thread {state}."


def publish_github_comment(
    comment: ReviewComment,
    repo: str,
    number: str,
    commit_id: str,
    *,
    positioned: bool,
) -> None:
    """Publish one comment as a GitHub PR review comment."""
    output = ""
    if positioned:
        payload = {
            "body": comment.body,
            "commit_id": commit_id,
            "path": comment.path,
            "line": comment.target_line,
            "side": "RIGHT",
        }
        command = [
            "gh",
            "api",
            f"repos/{repo}/pulls/{number}/comments",
            "--method",
            "POST",
            "--header",
            "Content-Type: application/json",
            "--input",
            "-",
        ]
        success, output = try_run(command, input_text=json.dumps(payload))
        if success:
            print(f"posted github {comment.path}:{comment.target_line}")
            return

    fallback_command = [
        "gh",
        "api",
        f"repos/{repo}/issues/{number}/comments",
        "--method",
        "POST",
        "--header",
        "Content-Type: application/json",
        "--input",
        "-",
    ]
    fallback_success, fallback_output = try_run(
        fallback_command,
        input_text=json.dumps({"body": fallback_body(comment)}),
    )
    if not fallback_success:
        die(f"could not publish GitHub comment at {comment.path}:{comment.target_line}\n{output}\n{fallback_output}")
    print(f"posted github fallback {comment.path}:{comment.target_line}")


def publish_comments(
    ref_range: ReviewRange,
    provider: str,
    dry_run: bool,
    *,
    force: bool = False,
    ignore_patterns: Sequence[str] = (),
) -> list[ReviewComment]:
    """Publish local review comments to a provider."""
    files = reviewable_files(ref_range, ignore_patterns)
    all_comments = collect_comments(files)
    if not all_comments:
        print("No #review comments found.")
        return []

    state = load_state(ref_range)
    published = published_comment_ids(state)
    comments = all_comments if force else [comment for comment in all_comments if comment_id(comment) not in published]
    skipped = len(all_comments) - len(comments)
    if skipped:
        print(f"Skipping {skipped} already published comment{'s' if skipped != 1 else ''}.")
    if not comments:
        print("No unpublished #review comments found.")
        return []

    lines_by_path = changed_lines_by_path(ref_range, {comment.path for comment in comments})
    bad_comments = [comment for comment in comments if comment.target_line not in lines_by_path[comment.path]]
    if bad_comments:
        print("These comments do not point at changed lines; they will use fallback comments:")
        for comment in bad_comments:
            print(f"- {comment.path}:{comment.target_line}: {comment.body}")

    if dry_run:
        for comment in comments:
            print(f"{provider} {comment.path}:{comment.target_line}: {comment.body}")
        return []

    published_comments: list[ReviewComment] = []
    if provider == "gitlab":
        project = gitlab_project_path()
        iid = gitlab_mr_iid()
        version = gitlab_latest_version(project, iid)
        for comment in comments:
            publish_gitlab_comment(
                comment,
                project,
                iid,
                version,
                positioned=comment.target_line in lines_by_path[comment.path],
            )
            mark_comment_published(ref_range, state, comment)
            published_comments.append(comment)
    elif provider == "github":
        repo = github_repo()
        pr = github_pr()
        number = str(pr["number"])
        commit_id = str(pr["headRefOid"])
        for comment in comments:
            publish_github_comment(
                comment,
                repo,
                number,
                commit_id,
                positioned=comment.target_line in lines_by_path[comment.path],
            )
            mark_comment_published(ref_range, state, comment)
            published_comments.append(comment)
    else:
        die(f"unsupported provider: {provider}")
    return published_comments


def add_text(window: curses.window, y: int, x: int, text: str, width: int, mode: int = 0) -> None:
    """Draw clipped text if it fits inside a curses window."""
    if width <= 0:
        return
    try:
        window.addnstr(y, x, text, width, mode)
    except curses.error:
        pass


def hex_to_rgb(value: str) -> tuple[int, int, int]:
    """Convert a hex color string to an RGB tuple."""
    normalized = value.strip().removeprefix("#")
    if len(normalized) != 6:
        raise ValueError(value)
    return (int(normalized[0:2], 16), int(normalized[2:4], 16), int(normalized[4:6], 16))


def load_theme(theme_name: str) -> dict[str, tuple[int, int, int]]:
    """Load a built-in or user theme."""
    if theme_name in THEMES:
        return THEMES[theme_name]

    theme_path = Path.home() / ".config" / "review" / "themes" / f"{theme_name}.json"
    if not theme_path.exists():
        return THEMES["dracula"]

    with theme_path.open(encoding="utf-8") as handle:
        raw_theme = json.load(handle)

    theme = dict(THEMES["dracula"])
    for name, value in raw_theme.items():
        if isinstance(value, str):
            try:
                theme[name] = hex_to_rgb(value)
            except ValueError:
                continue
    return theme


def init_theme(theme_name: str) -> None:
    """Initialize transparent-background color pairs for the TUI."""
    global ACTIVE_THEME

    ACTIVE_THEME = load_theme(theme_name)
    COLOR_PAIR_CACHE.clear()
    THEME_COLOR_NUMBERS.clear()
    if not curses.has_colors():
        return

    curses.start_color()
    try:
        curses.use_default_colors()
    except curses.error:
        pass

    can_define_colors = curses.can_change_color() and curses.COLORS > 32
    start_color = 16
    for offset, (name, rgb) in enumerate(ACTIVE_THEME.items()):
        color_number = start_color + offset
        if can_define_colors and color_number < curses.COLORS:
            try:
                curses.init_color(color_number, *(round(channel / 255 * 1000) for channel in rgb))
                THEME_COLOR_NUMBERS[name] = color_number
            except curses.error:
                THEME_COLOR_NUMBERS[name] = DRACULA_ANSI_COLORS.get(name, 7)
        else:
            THEME_COLOR_NUMBERS[name] = DRACULA_ANSI_COLORS.get(name, 7)


def theme_color(name: str) -> int:
    """Return a curses color number from the active theme."""
    return THEME_COLOR_NUMBERS.get(name, -1)


def color_pair(color: int, reverse: bool = False) -> int:
    """Return a curses color pair using the terminal default background."""
    if color < 0 or not curses.has_colors():
        return curses.A_REVERSE if reverse else 0

    key = (color, reverse)
    if key not in COLOR_PAIR_CACHE:
        pair_number = len(COLOR_PAIR_CACHE) + 1
        if pair_number >= curses.COLOR_PAIRS:
            return curses.A_REVERSE if reverse else 0
        background = color if reverse else -1
        foreground = -1 if reverse else color
        try:
            curses.init_pair(pair_number, foreground, background)
        except curses.error:
            return curses.A_REVERSE if reverse else 0
        COLOR_PAIR_CACHE[key] = pair_number
    return curses.color_pair(COLOR_PAIR_CACHE[key])


def nearest_theme_color(red: int, green: int, blue: int) -> int:
    """Return the closest active theme color for an RGB value."""
    if not THEME_COLOR_NUMBERS:
        return -1

    closest_name = min(
        THEME_COLOR_NUMBERS,
        key=lambda name: sum((ACTIVE_THEME[name][index] - value) ** 2 for index, value in enumerate((red, green, blue))),
    )
    return THEME_COLOR_NUMBERS[closest_name]


def ansi_256_to_color(value: int) -> int:
    """Map a 256-color ANSI value to a curses color number."""
    if 232 <= value <= 255:
        level = 8 + (value - 232) * 10
        return nearest_theme_color(level, level, level)
    if 16 <= value <= 255:
        red_index = (value - 16) // 36
        green_index = ((value - 16) % 36) // 6
        blue_index = (value - 16) % 6
        steps = [0, 95, 135, 175, 215, 255]
        return nearest_theme_color(steps[red_index], steps[green_index], steps[blue_index])
    return ansi_basic_color(value + 30 if value < 8 else value + 82)


def ansi_basic_color(code: int) -> int:
    """Map a basic ANSI color code to the active theme."""
    color_names = {
        30: "foreground",
        31: "red",
        32: "green",
        33: "yellow",
        34: "purple",
        35: "pink",
        36: "cyan",
        37: "foreground",
        90: "comment",
        91: "red",
        92: "green",
        93: "yellow",
        94: "purple",
        95: "pink",
        96: "cyan",
        97: "foreground",
    }
    return theme_color(color_names.get(code, "foreground"))


def parse_ansi_line(line: str) -> list[StyledSegment]:
    """Parse ANSI SGR color sequences into styled text segments."""
    segments: list[StyledSegment] = []
    position = 0
    color = theme_color("foreground")
    bold = False
    reverse = False

    for match in ANSI_RE.finditer(line):
        if match.start() > position:
            segments.append(StyledSegment(line[position : match.start()], color, bold, reverse))

        sequence = match.group()
        if sequence.endswith("m"):
            codes = [int(code or "0") for code in sequence[2:-1].split(";")]
            index = 0
            while index < len(codes):
                code = codes[index]
                if code == 0:
                    color = theme_color("foreground")
                    bold = False
                    reverse = False
                elif code == 1:
                    bold = True
                elif code == 22:
                    bold = False
                elif code == 7:
                    reverse = True
                elif code == 27:
                    reverse = False
                elif code == 39:
                    color = theme_color("foreground")
                elif code in BASIC_ANSI_COLOR_CODES:
                    color = ansi_basic_color(code)
                elif code == 38 and index + 2 < len(codes) and codes[index + 1] == 5:
                    color = ansi_256_to_color(codes[index + 2])
                    index += 2
                elif code == 38 and index + 4 < len(codes) and codes[index + 1] == 2:
                    color = nearest_theme_color(codes[index + 2], codes[index + 3], codes[index + 4])
                    index += 4
                index += 1
        position = match.end()

    if position < len(line):
        segments.append(StyledSegment(line[position:], color, bold, reverse))
    return segments or [StyledSegment("")]


def visible_length(segments: Sequence[StyledSegment]) -> int:
    """Return visible width for parsed segments."""
    return sum(len(segment.text) for segment in segments)


def add_styled_text(
    window: curses.window,
    y: int,
    x: int,
    segments: Sequence[StyledSegment],
    width: int,
) -> None:
    """Draw clipped styled text segments."""
    used = 0
    for segment in segments:
        if used >= width:
            return
        text = segment.text[: width - used]
        mode = color_pair(segment.color, segment.reverse)
        if segment.bold:
            mode |= curses.A_BOLD
        add_text(window, y, x + used, text, width - used, mode)
        used += len(text)


def wrap_text(text: str, width: int) -> list[str]:
    """Wrap text to a fixed terminal width."""
    if width <= 1:
        return [text]
    lines: list[str] = []
    for raw_line in text.splitlines() or [""]:
        line = raw_line
        while len(line) > width:
            lines.append(line[:width])
            line = line[width:]
        lines.append(line)
    return lines


def plain_popup_lines(messages: Sequence[str], width: int) -> list[tuple[str, int]]:
    """Return wrapped popup lines using the normal foreground color."""
    lines: list[tuple[str, int]] = []
    mode = color_pair(theme_color("foreground"))
    for message in messages:
        for wrapped in wrap_text(message, width):
            lines.append((wrapped, mode))
    return lines or [("", mode)]


def short_timestamp(value: str) -> str:
    """Return a compact timestamp for comment metadata."""
    return value.replace("T", " ")[:16] if value else ""


def append_wrapped_popup_text(
    lines: list[tuple[str, int]],
    text: str,
    width: int,
    indent: int,
    mode: int,
) -> None:
    """Append wrapped popup text with a fixed left indent."""
    prefix = " " * max(0, min(indent, width - 1))
    wrap_width = max(1, width - len(prefix))
    for wrapped in wrap_text(text, wrap_width):
        lines.append((f"{prefix}{wrapped}", mode))


def append_jira_field(lines: list[tuple[str, int]], width: int, label: str, value: str) -> None:
    """Append one Jira metadata field to popup lines."""
    mode = color_pair(theme_color("foreground"))
    text = f"{label}: {value or '-'}"
    for wrapped in wrap_text(text, width):
        lines.append((wrapped, mode))


def jira_issue_popup_lines(issue: JiraIssue, width: int) -> list[tuple[str, int]]:
    """Return styled popup lines for a Jira issue."""
    lines: list[tuple[str, int]] = []
    heading = f"{issue.key}  {issue.summary}"
    lines.append((heading, curses.A_BOLD | color_pair(theme_color("cyan"))))
    append_jira_field(lines, width, "Status", issue.status)
    append_jira_field(lines, width, "Type", issue.issue_type)
    append_jira_field(lines, width, "Priority", issue.priority)
    append_jira_field(lines, width, "Assignee", issue.assignee)
    append_jira_field(lines, width, "Reporter", issue.reporter)
    append_jira_field(lines, width, "Resolution", issue.resolution)
    append_jira_field(lines, width, "Labels", ", ".join(issue.labels))
    append_jira_field(lines, width, "Components", ", ".join(issue.components))
    append_jira_field(lines, width, "Fix versions", ", ".join(issue.fix_versions))
    append_jira_field(lines, width, "Created", short_timestamp(issue.created))
    append_jira_field(lines, width, "Updated", short_timestamp(issue.updated))
    append_jira_field(lines, width, "URL", issue.url)
    lines.append(("", 0))

    lines.append(("Description", curses.A_BOLD | color_pair(theme_color("purple"))))
    append_wrapped_popup_text(
        lines,
        issue.description or "No description.",
        width,
        2,
        color_pair(theme_color("foreground")),
    )
    lines.append(("", 0))

    lines.append((f"Comments ({len(issue.comments)})", curses.A_BOLD | color_pair(theme_color("purple"))))
    if not issue.comments:
        lines.append(("  No comments.", color_pair(theme_color("comment"))))
    for comment in issue.comments:
        timestamp = short_timestamp(comment.created)
        suffix = f"  {timestamp}" if timestamp else ""
        lines.append((f"  @{comment.author}{suffix}", curses.A_BOLD | color_pair(theme_color("green"))))
        append_wrapped_popup_text(lines, comment.body or "-", width, 4, color_pair(theme_color("foreground")))
        lines.append(("", 0))
    return lines


def append_help_section(lines: list[tuple[str, int]], width: int, title: str, entries: Sequence[tuple[str, str]]) -> None:
