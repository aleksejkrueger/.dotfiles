def die(message: str) -> None:
    """Print an error message and exit with status 1."""
    print(f"review: {message}", file=sys.stderr)
    raise SystemExit(1)


def run(command: Sequence[str], *, input_text: str | None = None) -> str:
    """Run a command and return stdout."""
    try:
        return subprocess.check_output(
            list(command),
            input=input_text,
            stderr=subprocess.PIPE,
            text=True,
        )
    except FileNotFoundError:
        die(f"missing dependency: {command[0]}")
    except subprocess.CalledProcessError as error:
        detail = error.stderr.strip() or f"command failed: {shlex.join(command)}"
        die(detail)


def try_run(command: Sequence[str], *, input_text: str | None = None) -> tuple[bool, str]:
    """Run a command and return success plus output without exiting."""
    try:
        output = subprocess.check_output(
            list(command),
            input=input_text,
            stderr=subprocess.STDOUT,
            text=True,
        )
    except FileNotFoundError:
        return False, f"missing dependency: {command[0]}"
    except subprocess.CalledProcessError as error:
        return False, error.output.strip() or f"command failed: {shlex.join(command)}"
    return True, output


def call(command: Sequence[str], *, input_text: str | None = None) -> int:
    """Run a command and return its exit code."""
    try:
        return subprocess.run(list(command), input=input_text, text=True, check=False).returncode
    except FileNotFoundError:
        die(f"missing dependency: {command[0]}")


def git(args: Sequence[str]) -> str:
    """Run git and return stdout."""
    return run(["git", *args])


def git_dir() -> Path:
    """Return the repository git directory."""
    return Path(git(["rev-parse", "--git-dir"]).strip())


def branch_name() -> str:
    """Return the current branch name, falling back to HEAD."""
    branch = git(["branch", "--show-current"]).strip()
    return branch or "HEAD"


def work_config_path() -> Path:
    """Return the work config path used for Jira settings."""
    return Path(os.environ.get("WORK_CONFIG", str(Path.home() / ".work" / "work.zsh"))).expanduser()


def parse_shell_export_value(value: str) -> str:
    """Parse a simple shell export value without executing shell code."""
    if "$(" in value or "`" in value:
        return ""
    try:
        parts = shlex.split(value, posix=True)
    except ValueError:
        return value.strip().strip("\"'")
    return parts[0] if parts else ""


def exported_config(path: Path) -> dict[str, str]:
    """Return exported KEY=value entries from a shell config file."""
    if not path.is_file():
        return {}
    values: dict[str, str] = {}
    with path.open(encoding="utf-8") as handle:
        for line in handle:
            match = EXPORT_RE.match(line)
            if match is None:
                continue
            value = parse_shell_export_value(match.group("value").strip())
            if value:
                values[match.group("key")] = value
    return values


def yaml_config_value(key: str, path: Path) -> str:
    """Return a simple top-level YAML scalar value."""
    if not path.is_file():
        return ""
    with path.open(encoding="utf-8") as handle:
        for line in handle:
            raw_key, separator, raw_value = line.partition(":")
            if separator and raw_key.strip() == key:
                return raw_value.strip().strip("\"'")
    return ""


def first_config_value(config: dict[str, str], names: Sequence[str]) -> str:
    """Return the first non-empty value from the environment or config."""
    for name in names:
        value = os.environ.get(name) or config.get(name) or ""
        if value:
            return value
    return ""


def normalized_base_url(value: str) -> str:
    """Return a normalized base URL."""
    if not value:
        return ""
    base_url = value if value.startswith(("http://", "https://")) else f"https://{value}"
    return base_url.rstrip("/")


def readable_ca_file(config: dict[str, str]) -> str:
    """Return a readable CA bundle path from environment or work config."""
    for name in ("CURL_CA_BUNDLE", "SSL_CERT_FILE", "REQUESTS_CA_BUNDLE"):
        value = os.environ.get(name) or config.get(name) or ""
        path = Path(value).expanduser()
        if value and path.is_file():
            return str(path)
    return ""


def jira_config() -> JiraConfig:
    """Return Jira REST API configuration from environment and work config."""
    config = exported_config(work_config_path())
    token = first_config_value(config, ("JIRA_TOKEN", "JIRA_API_TOKEN", "JIRA_PAT", "ATLASSIAN_API_TOKEN", "JIRA_PASSWORD"))
    if not token:
        token = yaml_config_value("jira_api_token", Path.home() / ".config" / "jiratui" / "config.yaml")
    return JiraConfig(
        base_url=normalized_base_url(first_config_value(config, ("JIRA_BASE_URL", "JIRA_API_URL", "JIRA_URL", "JIRA_HOST"))),
        user=first_config_value(config, ("JIRA_EMAIL", "JIRA_USER", "JIRA_USERNAME", "JIRA_NAME")),
        token=token,
        ca_file=readable_ca_file(config),
    )


def jira_issue_key_from_text(value: str) -> str:
    """Return the first Jira issue key found in text."""
    match = JIRA_KEY_RE.search(value.upper())
    return match.group("key") if match is not None else ""


def current_jira_issue_key(branch: str) -> str:
    """Return the Jira issue key for the current review context."""
    return (os.environ.get("JIRA_KEY") or jira_issue_key_from_text(branch)).upper()


def ref_exists(ref: str) -> bool:
    """Return whether a git ref exists."""
    return (
        subprocess.run(
            ["git", "rev-parse", "--verify", "--quiet", ref],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        ).returncode
        == 0
    )


def default_base() -> str:
    """Return the repository default comparison base."""
    for ref in ("origin/HEAD", "main", "master"):
        try:
            output = subprocess.check_output(
                ["git", "rev-parse", "--verify", "--quiet", "--abbrev-ref", ref],
                stderr=subprocess.DEVNULL,
                text=True,
            ).strip()
        except subprocess.CalledProcessError:
            continue
        if output:
            local_ref = output.removeprefix("origin/")
            return local_ref if ref_exists(local_ref) else output
    return "main"


def review_range(base: str, target: str = "HEAD", *, explicit: bool = False) -> ReviewRange:
    """Create a review range."""
    return ReviewRange(base=base, target=target, explicit=explicit)


def range_label(ref_range: ReviewRange) -> str:
    """Return a human readable review range label."""
    separator = ".." if ref_range.explicit else "..."
    return f"{ref_range.base}{separator}{ref_range.target}"


def display_range_label(ref_range: ReviewRange, branch: str | None = None) -> str:
    """Return a review range label suitable for UI display."""
    target = branch if ref_range.target == "HEAD" and branch else ref_range.target
    separator = ".." if ref_range.explicit else "..."
    return f"{ref_range.base}{separator}{target}"


def diff_ref(ref_range: ReviewRange) -> str:
    """Return the git diff revision argument."""
    separator = ".." if ref_range.explicit else "..."
    return f"{ref_range.base}{separator}{ref_range.target}"


def state_key(scope: StateScope) -> str:
    """Return the filesystem state key for a review range."""
    if isinstance(scope, str):
        return f"{safe_name(scope)}...{safe_name(branch_name())}"
    if not scope.explicit and scope.target == "HEAD":
        return f"{safe_name(scope.base)}...{safe_name(branch_name())}"
    return safe_name(range_label(scope))


def verify_base(base: str) -> None:
    """Fail if the base ref does not exist."""
    git(["rev-parse", "--verify", "--quiet", base])


def verify_range(ref_range: ReviewRange) -> None:
    """Fail if the review range refs do not exist."""
    verify_base(ref_range.base)
    verify_base(ref_range.target)


def safe_name(value: str) -> str:
    """Return a filesystem-safe name."""
    return "".join(character if character.isalnum() else "-" for character in value)


def review_root(scope: StateScope) -> Path:
    """Return the private state directory for this branch review."""
    return git_dir() / "review" / state_key(scope)


def state_file(scope: StateScope) -> Path:
    """Return the JSON state file for this branch review."""
    return review_root(scope) / "state.json"


def load_state(scope: StateScope) -> dict[str, Any]:
    """Load review state."""
    path = state_file(scope)
    if not path.exists():
        return {"reviewed": []}
    with path.open(encoding="utf-8") as handle:
        return json.load(handle)


def save_state(scope: StateScope, state: dict[str, Any]) -> None:
    """Save review state."""
    path = state_file(scope)
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        json.dump(state, handle, indent=2, sort_keys=True)
        handle.write("\n")


def has_glob(pattern: str) -> bool:
    """Return whether a pattern contains shell-style glob tokens."""
    return any(character in pattern for character in "*?[")


def matches_ignore_pattern(path: str, pattern: str) -> bool:
    """Return whether a git path matches one ignore pattern."""
    normalized_pattern = pattern.strip()
    if not normalized_pattern:
        return False
    normalized_path = path.strip("/")
    normalized_pattern = normalized_pattern.strip("/")

    if not normalized_pattern:
        return False
    if has_glob(normalized_pattern):
        return fnmatch.fnmatchcase(normalized_path, normalized_pattern) or fnmatch.fnmatchcase(
            Path(normalized_path).name,
            normalized_pattern,
        )
    return normalized_path == normalized_pattern or normalized_path.startswith(f"{normalized_pattern}/")


def ignored_path(path: str, patterns: Sequence[str]) -> bool:
    """Return whether a git path should be hidden by ignore patterns."""
    return any(matches_ignore_pattern(path, pattern) for pattern in patterns)


def changed_files(ref_range: ReviewRange, ignore_patterns: Sequence[str] = ()) -> list[ChangedFile]:
    """Return files changed in the review range."""
    output = subprocess.check_output(
        ["git", "diff", "--name-only", "-z", diff_ref(ref_range)],
        stderr=subprocess.PIPE,
    )
    paths = [path.decode() for path in output.split(b"\0") if path]
    visible_paths = [path for path in paths if not ignored_path(path, ignore_patterns)]
    return [ChangedFile(index=index, path=path) for index, path in enumerate(visible_paths, 1)]


def renumber_files(files: Sequence[ChangedFile]) -> list[ChangedFile]:
    """Return changed files with consecutive display indexes."""
    return [ChangedFile(index=index, path=changed_file.path) for index, changed_file in enumerate(files, 1)]


def reviewed_paths(state: dict[str, Any]) -> set[str]:
    """Return reviewed file paths from state."""
    return set(state.get("reviewed", []))


def ignored_file_paths(state: dict[str, Any]) -> set[str]:
    """Return ignored file paths from state."""
    return set(state.get("ignored", []))


def reviewable_files(ref_range: ReviewRange, ignore_patterns: Sequence[str] = ()) -> list[ChangedFile]:
    """Return changed files that are not marked ignored."""
    ignored = ignored_file_paths(load_state(ref_range))
    return renumber_files(
        changed_file
        for changed_file in changed_files(ref_range, ignore_patterns)
        if changed_file.path not in ignored
    )


def published_comment_ids(state: dict[str, Any]) -> set[str]:
    """Return published review comment IDs from state."""
    return set(state.get("published", []))


def reply_drafts(state: dict[str, Any]) -> list[ReplyDraft]:
    """Return saved reply drafts from state."""
    drafts: list[ReplyDraft] = []
    for raw_draft in state.get("reply_drafts", []):
        if not isinstance(raw_draft, dict):
            continue
        body = str(raw_draft.get("body") or "").strip()
        path = str(raw_draft.get("path") or "")
        thread_id = str(raw_draft.get("thread_id") or "")
        if not body or not path or not thread_id:
            continue
        try:
            line = int(raw_draft.get("line") or 0)
        except (TypeError, ValueError):
            line = 0
        drafts.append(
            ReplyDraft(
                draft_id=str(raw_draft.get("draft_id") or ""),
                thread_id=thread_id,
                note_id=str(raw_draft.get("note_id") or ""),
                path=path,
                line=line,
                body=body,
            )
        )
    return drafts


def reply_draft_id(draft: ReplyDraft) -> str:
    """Return a stable ID for a reply draft."""
    payload = {
        "body": draft.body,
        "note_id": draft.note_id,
        "path": draft.path,
        "thread_id": draft.thread_id,
    }
    encoded = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode()
    return hashlib.sha1(encoded).hexdigest()


def reply_draft_state(draft: ReplyDraft) -> dict[str, Any]:
    """Return a JSON-serializable reply draft."""
    draft_id = draft.draft_id or reply_draft_id(draft)
    return {
        "body": draft.body,
        "draft_id": draft_id,
        "line": draft.line,
        "note_id": draft.note_id,
        "path": draft.path,
        "thread_id": draft.thread_id,
    }


def save_reply_drafts(scope: StateScope, drafts: Sequence[ReplyDraft]) -> None:
    """Persist reply drafts in review state."""
    state = load_state(scope)
    state["reply_drafts"] = [reply_draft_state(draft) for draft in drafts]
    save_state(scope, state)


def add_reply_draft(scope: StateScope, target: ReplyTarget, body: str) -> ReplyDraft:
    """Add a reply draft for a remote review note."""
    draft = ReplyDraft(
        draft_id="",
        thread_id=target.thread.thread_id,
        note_id=target.note.note_id,
        path=target.thread.path,
        line=target.thread.line,
        body=body.strip(),
    )
    saved_draft = ReplyDraft(
        draft_id=reply_draft_id(draft),
        thread_id=draft.thread_id,
        note_id=draft.note_id,
        path=draft.path,
        line=draft.line,
        body=draft.body,
    )
    existing_drafts = [
        existing_draft
        for existing_draft in reply_drafts(load_state(scope))
        if existing_draft.draft_id != saved_draft.draft_id
    ]
    save_reply_drafts(scope, [*existing_drafts, saved_draft])
    return saved_draft


def update_reply_draft_body(scope: StateScope, draft: ReplyDraft, body: str) -> ReplyDraft:
    """Replace an existing reply draft body and persist it."""
    draft_id = draft.draft_id or reply_draft_id(draft)
    updated = ReplyDraft(
        draft_id=draft_id,
        thread_id=draft.thread_id,
        note_id=draft.note_id,
        path=draft.path,
        line=draft.line,
        body=body.strip(),
    )
    replaced = False
    updated_drafts: list[ReplyDraft] = []
    for existing_draft in reply_drafts(load_state(scope)):
        if existing_draft.draft_id == draft_id:
            updated_drafts.append(updated)
            replaced = True
        else:
            updated_drafts.append(existing_draft)
    if not replaced:
        updated_drafts.append(updated)
    save_reply_drafts(scope, updated_drafts)
    return updated


def remove_reply_drafts(scope: StateScope, draft_ids: set[str]) -> int:
    """Remove reply drafts by ID and return the number removed."""
    drafts = reply_drafts(load_state(scope))
    kept = [draft for draft in drafts if draft.draft_id not in draft_ids]
    save_reply_drafts(scope, kept)
    return len(drafts) - len(kept)


def reply_draft_matches_target(draft: ReplyDraft, target: ReplyTarget) -> bool:
    """Return whether a draft belongs to a selected remote note."""
    return (
        draft.thread_id == target.thread.thread_id
        and draft.note_id == target.note.note_id
        and draft.path == target.thread.path
    )


def suggestion_line_range(note: RemoteNote, meta: str) -> tuple[int, int]:
    """Return the file line range replaced by a suggestion block."""
    match = SUGGESTION_RANGE_RE.search(meta)
    if match is not None:
        start = note.line + int(match.group("start"))
        end = note.line + int(match.group("end"))
    else:
        start = note.start_line or note.line
        end = note.line
    return max(1, min(start, end)), max(1, max(start, end))


def suggestion_id(note: RemoteNote, index: int, body: str, start_line: int, end_line: int) -> str:
    """Return a stable local ID for a remote suggestion block."""
    payload = {
        "body": body,
        "end_line": end_line,
        "index": index,
        "note_id": note.note_id,
        "path": note.path,
        "start_line": start_line,
    }
    encoded = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode()
    return hashlib.sha1(encoded).hexdigest()


def note_suggestions(note: RemoteNote) -> list[ReviewSuggestion]:
    """Return suggestion blocks parsed from a remote note body."""
    suggestions: list[ReviewSuggestion] = []
    if not note.path or not note.line:
        return suggestions
    for index, match in enumerate(SUGGESTION_BLOCK_RE.finditer(note.body), 1):
        body = match.group("body").rstrip("\n")
        start_line, end_line = suggestion_line_range(note, match.group("meta").strip())
        suggestions.append(
            ReviewSuggestion(
                suggestion_id=suggestion_id(note, index, body, start_line, end_line),
                path=note.path,
                start_line=start_line,
                end_line=end_line,
                body=body,
            )
        )
    return suggestions


def suggestion_undo(state: dict[str, Any]) -> SuggestionUndo | None:
    """Return the last stored suggestion undo snapshot."""
    raw_undo = state.get("suggestion_undo")
    if not isinstance(raw_undo, dict):
        return None
    path = str(raw_undo.get("path") or "")
    suggestion_id = str(raw_undo.get("suggestion_id") or "")
    if not path or not suggestion_id:
        return None
    try:
        start_line = int(raw_undo.get("start_line") or 0)
        end_line = int(raw_undo.get("end_line") or 0)
    except (TypeError, ValueError):
        start_line = 0
        end_line = 0
    return SuggestionUndo(
        path=path,
        content=str(raw_undo.get("content") or ""),
        suggestion_id=suggestion_id,
        start_line=start_line,
        end_line=end_line,
    )


def suggestion_undo_state(undo: SuggestionUndo) -> dict[str, Any]:
    """Return a JSON-serializable suggestion undo snapshot."""
    return {
        "content": undo.content,
        "end_line": undo.end_line,
        "path": undo.path,
        "start_line": undo.start_line,
        "suggestion_id": undo.suggestion_id,
    }


def save_suggestion_undo(scope: StateScope, undo: SuggestionUndo) -> None:
    """Persist the last suggestion undo snapshot."""
    state = load_state(scope)
    state["suggestion_undo"] = suggestion_undo_state(undo)
    save_state(scope, state)


def clear_suggestion_undo(scope: StateScope) -> None:
    """Clear the stored suggestion undo snapshot."""
    state = load_state(scope)
    state.pop("suggestion_undo", None)
    save_state(scope, state)


def comment_id(comment: ReviewComment) -> str:
    """Return a stable ID for a review comment."""
    payload = {
        "body": comment.body,
        "path": comment.path,
        "target_line": comment.target_line,
    }
    encoded = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode()
    return hashlib.sha1(encoded).hexdigest()


def mark_comment_published(scope: StateScope, state: dict[str, Any], comment: ReviewComment) -> None:
    """Persist that a review comment has been published."""
    published = published_comment_ids(state)
    published.add(comment_id(comment))
    state["published"] = sorted(published)
    save_state(scope, state)


def is_reviewed(path: str, state: dict[str, Any]) -> bool:
    """Return whether a file is marked reviewed."""
    return path in reviewed_paths(state)


def is_ignored(path: str, state: dict[str, Any]) -> bool:
    """Return whether a file is marked ignored."""
    return path in ignored_file_paths(state)


def toggle_reviewed(scope: StateScope, path: str) -> None:
    """Toggle the reviewed checkbox for a file."""
    state = load_state(scope)
    reviewed = reviewed_paths(state)
    if path in reviewed:
        reviewed.remove(path)
    else:
        reviewed.add(path)
    state["reviewed"] = sorted(reviewed)
    save_state(scope, state)


def toggle_ignored(scope: StateScope, path: str) -> bool:
    """Toggle the ignored flag for a file and return its new state."""
    state = load_state(scope)
    ignored = ignored_file_paths(state)
    if path in ignored:
        ignored.remove(path)
        is_now_ignored = False
    else:
        ignored.add(path)
        is_now_ignored = True
    state["ignored"] = sorted(ignored)
    save_state(scope, state)
    return is_now_ignored


def marker_only(line: str) -> bool:
    """Return whether a line only contains a review marker in a comment."""
    return REVIEW_MARKER_RE.match(line.strip()) is not None or LEGACY_MARKER_RE.match(line.strip()) is not None


def review_marker_match(line: str) -> re.Match[str] | None:
    """Return a review marker match for a line."""
    return REVIEW_MARKER_RE.search(line) or LEGACY_MARKER_RE.search(line)


def next_code_line(lines: list[str], start_index: int) -> int:
    """Return the next non-empty non-marker line number after a marker."""
    for index in range(start_index + 1, len(lines)):
        line = lines[index]
        if line.strip() and not MARKER_RE.search(line):
            return index + 1
    return start_index + 1


def adjusted_target_line(lines: list[str], marker_index: int) -> int:
    """Return the target line adjusted for local standalone marker lines."""
    line = lines[marker_index]
    raw_target = next_code_line(lines, marker_index) if marker_only(line) else marker_index + 1
    local_marker_lines = sum(
        1
        for line_number, current_line in enumerate(lines[:raw_target], 1)
        if line_number <= raw_target and MARKER_RE.search(current_line) and marker_only(current_line)
    )
    return max(1, raw_target - local_marker_lines)


def comments_in_file(path: str) -> list[ReviewComment]:
    """Return review comments found in one file."""
    file_path = Path(path)
    if not file_path.exists() or not file_path.is_file():
        return []

    lines = file_path.read_text(encoding="utf-8", errors="replace").splitlines()
    comments: list[ReviewComment] = []
    for index, line in enumerate(lines):
        match = review_marker_match(line)
        if match is None:
            continue
        body = match.group("body").strip()
        if body:
            comments.append(
                ReviewComment(
                    path=path,
                    marker_line=index + 1,
                    target_line=adjusted_target_line(lines, index),
                    body=body,
                )
            )
    return comments


def collect_comments(files: Sequence[ChangedFile]) -> list[ReviewComment]:
    """Return all local review comments in changed files."""
    comments: list[ReviewComment] = []
    for changed_file in files:
        comments.extend(comments_in_file(changed_file.path))
    return comments


def comments_by_path(files: Sequence[ChangedFile]) -> dict[str, list[ReviewComment]]:
    """Return local review comments grouped by changed file path."""
    comments: dict[str, list[ReviewComment]] = {}
    for changed_file in files:
        path_comments = comments_in_file(changed_file.path)
        if path_comments:
            comments[changed_file.path] = path_comments
    return comments


def remove_published_markers_from_file(path: str, published_ids: set[str]) -> int:
    """Remove standalone local review marker lines by comment ID."""
    file_path = Path(path)
    if not file_path.is_file():
        return 0

    lines = file_path.read_text(encoding="utf-8", errors="replace").splitlines()
    kept_lines: list[str] = []
    removed = 0
    for index, line in enumerate(lines):
        match = review_marker_match(line)
        if match is None or not marker_only(line):
            kept_lines.append(line)
            continue

        comment = ReviewComment(
            path=path,
            marker_line=index + 1,
            target_line=adjusted_target_line(lines, index),
            body=match.group("body").strip(),
        )
        if comment_id(comment) in published_ids:
            removed += 1
            continue
        kept_lines.append(line)

    if removed:
        file_path.write_text("\n".join(kept_lines) + ("\n" if kept_lines else ""), encoding="utf-8")
    return removed


def remove_published_markers(comments: Sequence[ReviewComment]) -> int:
    """Remove standalone local markers for published comments."""
    ids_by_path: dict[str, set[str]] = {}
    for comment in comments:
        ids_by_path.setdefault(comment.path, set()).add(comment_id(comment))
    return sum(remove_published_markers_from_file(path, ids) for path, ids in ids_by_path.items())


def changed_new_lines(ref_range: ReviewRange, path: str) -> set[int]:
    """Return new-side line numbers touched by the review range."""
    diff = git(["diff", "--unified=0", diff_ref(ref_range), "--", path])
    lines: set[int] = set()
    for line in diff.splitlines():
        if not line.startswith("@@"):
            continue
        match = re.search(r"\+(\d+)(?:,(\d+))?", line)
        if match is None:
            continue
        start = int(match.group(1))
        count = int(match.group(2) or "1")
        lines.update(range(start, start + count))
    return lines


def changed_lines_by_path(ref_range: ReviewRange, paths: set[str]) -> dict[str, set[int]]:
    """Return changed new-side line numbers keyed by file path."""
    return {path: changed_new_lines(ref_range, path) for path in paths}


def print_status(ref_range: ReviewRange, ignore_patterns: Sequence[str] = ()) -> None:
    """Print the changed-file checklist and local comments."""
    files = changed_files(ref_range, ignore_patterns)
    state = load_state(ref_range)
    file_comments = comments_by_path(files)

    if not files:
        print(f"No files changed in {range_label(ref_range)}.")
        return

    for changed_file in files:
        checked = "x" if is_reviewed(changed_file.path, state) else " "
        ignored = "i" if is_ignored(changed_file.path, state) else " "
        count = len(file_comments.get(changed_file.path, []))
        suffix = f" ({count} comment{'s' if count != 1 else ''})" if count else ""
        print(f"{changed_file.index:>3}. [{checked}][{ignored}] {changed_file.path}{suffix}")


def checked_files(ref_range: ReviewRange, ignore_patterns: Sequence[str] = ()) -> list[ChangedFile]:
    """Return changed files marked reviewed in state."""
    files = reviewable_files(ref_range, ignore_patterns)
    reviewed = reviewed_paths(load_state(ref_range))
    return [changed_file for changed_file in files if changed_file.path in reviewed]


def print_checked(ref_range: ReviewRange, ignore_patterns: Sequence[str] = ()) -> None:
    """Print changed files marked reviewed."""
    files = checked_files(ref_range, ignore_patterns)
    if not files:
        print(f"No checked files in {range_label(ref_range)}.")
        return
    for changed_file in files:
        print(changed_file.path)


def delta_command(width: int | None = None, *, paging: str = "always") -> list[str]:
    """Return the delta command used for review diffs."""
    command = [
        "delta",
        f"--paging={paging}",
        "--side-by-side",
        "--syntax-theme=Dracula",
        "--line-numbers",
        "--line-numbers-plus-style=#50fa7b #1f3a2a",
        "--line-numbers-minus-style=#ff5555 #4a1f2b",
        "--plus-style=syntax #1f3a2a",
        "--minus-style=syntax #4a1f2b",
        "--plus-emph-style=syntax bold #1f3a2a",
        "--minus-emph-style=syntax bold #4a1f2b",
        "--keep-plus-minus-markers",
    ]
    if width is not None and width > 0:
        command.append(f"--width={width}")
    return command


def diff_command(ref_range: ReviewRange, path: str, branch: str | None = None) -> list[str]:
    """Return the git diff command for one file."""
    target = branch if ref_range.target == "HEAD" and branch else ref_range.target
    return [
        "git",
        "diff",
        "--no-ext-diff",
        f"--src-prefix={ref_range.base}/",
        f"--dst-prefix={target}/",
        diff_ref(ref_range),
        "--",
        path,
    ]


def show_diff(ref_range: ReviewRange, path: str, branch: str | None = None) -> None:
    """Show a side-by-side diff for one file in the pager."""
    git_command = diff_command(ref_range, path, branch)
    delta_process = None
    git_process = subprocess.Popen(git_command, stdout=subprocess.PIPE)
    try:
        delta_process = subprocess.Popen(delta_command(), stdin=git_process.stdout)
    except FileNotFoundError:
        die("missing dependency: delta")
    if git_process.stdout is not None:
        git_process.stdout.close()
    delta_process.wait()
    git_process.wait()


def fast_preview_command(ref_range: ReviewRange, branch: str) -> str:
    """Return the shell preview command used by fzf fast mode."""
    target = branch if ref_range.target == "HEAD" else ref_range.target
    git_command = [
        "git",
        "diff",
        "--no-ext-diff",
        "--color=always",
        f"--src-prefix={ref_range.base}/",
        f"--dst-prefix={target}/",
        diff_ref(ref_range),
        "--",
        "{}",
    ]
    delta_arguments = [argument for argument in delta_command(paging="never") if not argument.startswith("--width=")]
    git_part = shlex.join(git_command).replace("'{}'", "{}")
    delta_part = f"{shlex.join(delta_arguments)} --width=${{FZF_PREVIEW_COLUMNS:-120}}"
    return f"if command -v delta >/dev/null 2>&1; then {git_part} | {delta_part}; else {git_part}; fi"


def fast_select_file(ref_range: ReviewRange, files: Sequence[ChangedFile]) -> str | None:
    """Select a changed file with fzf and an inline diff preview."""
    command = [
        "fzf",
        "--ansi",
        "--height=100%",
        "--layout=reverse",
        "--border",
        "--prompt=review fast> ",
        "--preview-window=up,70%,border-bottom",
        "--preview",
        fast_preview_command(ref_range, branch_name()),
    ]
    try:
        result = subprocess.run(
            command,
            input="\n".join(changed_file.path for changed_file in files),
            stdout=subprocess.PIPE,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        die("missing dependency: fzf")
    if result.returncode != 0:
        return None
    selected = result.stdout.strip()
    return selected or None


def fast_review(ref_range: ReviewRange, ignore_patterns: Sequence[str] = ()) -> None:
    """Run the lightweight fzf/delta review flow."""
    files = reviewable_files(ref_range, ignore_patterns)
    if not files:
        print(f"No files changed in {range_label(ref_range)}.")
        return
    selected = fast_select_file(ref_range, files)
    if selected is not None:
        show_diff(ref_range, selected, branch_name())


def side_by_side_diff_lines(ref_range: ReviewRange, path: str, width: int, branch: str | None = None) -> list[str]:
    """Return side-by-side diff lines with ANSI colors preserved."""
    git_command = diff_command(ref_range, path, branch)
    git_process = subprocess.Popen(git_command, stdout=subprocess.PIPE)
    try:
        output = subprocess.check_output(
            delta_command(width, paging="never"),
            stdin=git_process.stdout,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except (FileNotFoundError, subprocess.CalledProcessError):
        output = run(["git", "diff", "--no-color", diff_ref(ref_range), "--", path])
    finally:
        if git_process.stdout is not None:
            git_process.stdout.close()
        git_process.wait()

    lines = [line.replace("\t", "    ") for line in output.splitlines()]
    return lines or ["No diff for this file."]


def rendered_new_line_matches(line: str, line_number: int) -> bool:
    """Return whether a rendered diff row belongs to the new-side line number."""
    text = ANSI_RE.sub("", line)
    parts = text.split("│", 4)
    if len(parts) >= 5:
        return parts[3].strip() == str(line_number)
    return re.search(rf"(?<!\d){line_number}(?!\d)", text) is not None


def file_newline(text: str) -> str:
    """Return the dominant newline sequence for a text file."""
    return "\r\n" if "\r\n" in text else "\n"


def replacement_lines(body: str, newline: str, keep_final_newline: bool) -> list[str]:
    """Return file lines for a suggestion replacement body."""
    if body == "":
        return []
    lines = [f"{line}{newline}" for line in body.split("\n")]
    if not keep_final_newline and lines:
        lines[-1] = lines[-1].removesuffix(newline)
    return lines


def build_suggestion_undo(suggestion: ReviewSuggestion) -> tuple[SuggestionUndo | None, str]:
    """Return an undo snapshot before applying a suggestion."""
    path = Path(suggestion.path)
    if not path.exists():
        return None, f"File not found: {suggestion.path}"
    try:
        content = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        return None, f"File is not UTF-8 text: {suggestion.path}"
    return (
        SuggestionUndo(
            path=suggestion.path,
            content=content,
            suggestion_id=suggestion.suggestion_id,
            start_line=suggestion.start_line,
            end_line=suggestion.end_line,
        ),
        "",
    )

def apply_suggestion_to_file(suggestion: ReviewSuggestion) -> tuple[bool, str]:
    """Apply a remote suggestion to the working tree."""
    path = Path(suggestion.path)
    if not path.exists():
        return False, f"File not found: {suggestion.path}"

    try:
        text = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        return False, f"File is not UTF-8 text: {suggestion.path}"
    lines = text.splitlines(keepends=True)
    if suggestion.start_line < 1 or suggestion.end_line < suggestion.start_line:
        return False, f"Invalid suggestion range: {suggestion.start_line}-{suggestion.end_line}"
    if suggestion.end_line > len(lines):
        return False, f"Suggestion range exceeds file length: {suggestion.start_line}-{suggestion.end_line}"

    start_index = suggestion.start_line - 1
    end_index = suggestion.end_line
    newline = file_newline(text)
    keep_final_newline = end_index < len(lines) or text.endswith(("\n", "\r\n"))
    updated_lines = [
        *lines[:start_index],
        *replacement_lines(suggestion.body, newline, keep_final_newline),
        *lines[end_index:],
    ]
    path.write_text("".join(updated_lines), encoding="utf-8")
    return True, f"Applied suggestion to {suggestion.path}:{suggestion.start_line}-{suggestion.end_line}."


def restore_suggestion_undo(scope: StateScope) -> tuple[bool, str]:
    """Restore the last applied suggestion snapshot."""
    undo = suggestion_undo(load_state(scope))
    if undo is None:
        return False, "No applied suggestion to undo."
    Path(undo.path).write_text(undo.content, encoding="utf-8")
    clear_suggestion_undo(scope)
    return True, f"Undid suggestion for {undo.path}:{undo.start_line}-{undo.end_line}."


def open_file(path: str) -> None:
    """Open a file in the configured editor."""
    call(editor_command(path))


def edit_text(initial_text: str, *, suffix: str = ".md") -> tuple[bool, str]:
    """Edit text in the configured editor and return the saved body."""
    path: Path | None = None
    try:
        with tempfile.NamedTemporaryFile(
            "w",
            encoding="utf-8",
            prefix="review-draft-",
            suffix=suffix,
            delete=False,
        ) as handle:
            path = Path(handle.name)
            handle.write(initial_text)
            if initial_text and not initial_text.endswith("\n"):
                handle.write("\n")
        if call(editor_command(str(path))) != 0:
            return False, initial_text
        return True, path.read_text(encoding="utf-8").strip()
    finally:
        if path is not None:
            path.unlink(missing_ok=True)


def editor_command(path: str) -> list[str]:
    """Return the configured editor command with a file path appended."""
    editor = os.environ.get("VISUAL") or os.environ.get("EDITOR") or "nvim"
    command = shlex.split(editor)
    return [*command, path] if command else ["nvim", path]


def resolve_path(files: Sequence[ChangedFile], value: str) -> str:
    """Resolve a file index or path."""
    if value.isdigit():
        wanted = int(value)
        for changed_file in files:
            if changed_file.index == wanted:
                return changed_file.path
    paths = {changed_file.path for changed_file in files}
    if value in paths:
        return value
    die(f"not a changed file: {value}")


def list_comments(ref_range: ReviewRange, ignore_patterns: Sequence[str] = ()) -> None:
    """Print local review comments."""
    files = reviewable_files(ref_range, ignore_patterns)
    comments = collect_comments(files)
    if not comments:
        print("No #review comments found.")
        return

    for comment in comments:
        changed_lines = changed_new_lines(ref_range, comment.path)
        marker = "" if comment.target_line in changed_lines else " [not in diff]"
        print(f"{comment.path}:{comment.target_line}{marker}: {comment.body}")


def remote_url() -> str:
    """Return the git remote URL used to detect the hosting provider."""
    for remote in ("origin", "upstream"):
        try:
            url = subprocess.check_output(
                ["git", "remote", "get-url", remote],
                stderr=subprocess.DEVNULL,
                text=True,
            ).strip()
        except subprocess.CalledProcessError:
            continue
        if url:
            return url
    return ""


def detect_provider() -> str | None:
    """Detect GitLab or GitHub from the git remote URL."""
    url = remote_url().lower()
    if "github" in url:
        return "github"
    if "gitlab" in url:
        return "gitlab"
    return None


def open_review_request(provider: str) -> bool:
    """Open the current merge or pull request in the browser."""
    if provider == "gitlab":
        success, _ = try_run(["glab", "mr", "view", "--web"])
        return success
    if provider == "github":
        success, _ = try_run(["gh", "pr", "view", "--web"])
        return success
    die(f"unsupported provider: {provider}")


def open_url(url: str) -> bool:
    """Open a URL in the system browser."""
    success, _ = try_run(["open", url])
    return success


def jira_ssl_context(config: JiraConfig) -> ssl.SSLContext:
    """Return an SSL context for Jira API calls."""
    return ssl.create_default_context(cafile=config.ca_file) if config.ca_file else ssl.create_default_context()


def jira_auth_headers(config: JiraConfig) -> list[dict[str, str]]:
    """Return Jira Authorization header candidates."""
    if not config.token:
        return [{}]
    headers = [{"Authorization": f"Bearer {config.token}"}]
    if config.user:
        encoded = base64.b64encode(f"{config.user}:{config.token}".encode()).decode()
        headers.append({"Authorization": f"Basic {encoded}"})
    return headers


def jira_error_message(error: HTTPError) -> str:
    """Return a concise Jira HTTP error message."""
    detail = ""
    try:
        detail = error.read().decode().strip()
    except Exception:
        detail = ""
    suffix = f": {detail[:300]}" if detail else ""
    return f"Jira API returned HTTP {error.code}{suffix}"


def jira_request(
    config: JiraConfig,
    method: str,
    path: str,
    *,
    query: dict[str, str] | None = None,
    payload: dict[str, Any] | None = None,
) -> dict[str, Any]:
    """Run one Jira REST API request."""
    if not config.base_url:
        raise RuntimeError(f"Set JIRA_URL in {work_config_path()}")
    query_string = f"?{urlencode(query)}" if query else ""
    url = f"{config.base_url}{path}{query_string}"
    body = json.dumps(payload).encode() if payload is not None else None
    last_error = ""
    for headers in jira_auth_headers(config):
        request = Request(url, data=body, method=method)
        request.add_header("Accept", "application/json")
        if payload is not None:
            request.add_header("Content-Type", "application/json")
        for key, value in headers.items():
            request.add_header(key, value)
        try:
            with urlopen(request, context=jira_ssl_context(config)) as response:
                raw_body = response.read().decode().strip()
                return json.loads(raw_body) if raw_body else {}
        except HTTPError as error:
            last_error = jira_error_message(error)
            if error.code not in (401, 403) or "Basic " in headers.get("Authorization", ""):
                break
        except URLError as error:
            raise RuntimeError(f"Could not reach Jira API: {error.reason}") from error
    raise RuntimeError(last_error or "Jira API request failed.")


def jira_display_name(value: dict[str, Any] | None) -> str:
    """Return a display name from a Jira user object."""
    if not value:
        return "unassigned"
    return str(value.get("displayName") or value.get("name") or value.get("emailAddress") or "unknown")


def jira_named_value(value: dict[str, Any] | None) -> str:
    """Return the name field from a Jira value object."""
    if not value:
        return ""
    return str(value.get("name") or value.get("value") or "")


def jira_named_values(values: Sequence[Any]) -> tuple[str, ...]:
    """Return display names for Jira list field values."""
    names: list[str] = []
    for value in values:
        if isinstance(value, dict):
            name = jira_named_value(value)
        else:
            name = str(value)
        if name:
            names.append(name)
    return tuple(names)


def jira_text(value: Any) -> str:
    """Return readable text from Jira plain text or document values."""
    if value is None:
        return ""
    if isinstance(value, str):
        return value
    if isinstance(value, list):
        return "\n".join(part for part in (jira_text(item) for item in value) if part)
    if isinstance(value, dict):
        if isinstance(value.get("text"), str):
            return value["text"]
        return jira_text(value.get("content", []))
    return str(value)


def jira_comment_from_json(data: dict[str, Any]) -> JiraComment:
    """Return a Jira comment parsed from API JSON."""
    return JiraComment(
        author=jira_display_name(data.get("author")),
        body=jira_text(data.get("body")),
        created=str(data.get("created") or ""),
        updated=str(data.get("updated") or ""),
    )


def jira_issue_from_json(config: JiraConfig, data: dict[str, Any], comments: Sequence[JiraComment]) -> JiraIssue:
    """Return a Jira issue parsed from API JSON."""
    fields = data.get("fields") or {}
    return JiraIssue(
        key=str(data.get("key") or ""),
        url=f"{config.base_url}/browse/{data.get('key')}",
        summary=str(fields.get("summary") or ""),
        status=jira_named_value(fields.get("status")),
        issue_type=jira_named_value(fields.get("issuetype")),
        priority=jira_named_value(fields.get("priority")) or "none",
        assignee=jira_display_name(fields.get("assignee")),
        reporter=jira_display_name(fields.get("reporter")),
        resolution=jira_named_value(fields.get("resolution")) or "unresolved",
        labels=tuple(str(label) for label in fields.get("labels") or ()),
        components=jira_named_values(fields.get("components") or ()),
        fix_versions=jira_named_values(fields.get("fixVersions") or ()),
        created=str(fields.get("created") or ""),
        updated=str(fields.get("updated") or ""),
        description=jira_text(fields.get("description")),
        comments=tuple(comments),
    )


def fetch_jira_comments(config: JiraConfig, key: str) -> list[JiraComment]:
    """Fetch all comments for a Jira issue."""
    comments: list[JiraComment] = []
    start_at = 0
    while True:
        page = jira_request(
            config,
            "GET",
            f"/rest/api/2/issue/{quote(key)}/comment",
            query={"startAt": str(start_at), "maxResults": "100", "orderBy": "created"},
        )
        raw_comments = page.get("comments") or page.get("values") or []
        comments.extend(jira_comment_from_json(comment) for comment in raw_comments if isinstance(comment, dict))
        total = int(page.get("total", len(comments)))
        if not raw_comments or len(comments) >= total:
            return comments
        start_at += len(raw_comments)


def fetch_jira_issue(config: JiraConfig, key: str) -> JiraIssue:
    """Fetch a Jira issue and its comments."""
    fields = ",".join(
        (
            "summary",
            "status",
            "issuetype",
            "priority",
            "assignee",
            "reporter",
            "resolution",
            "labels",
            "components",
            "fixVersions",
            "created",
            "updated",
            "description",
        )
    )
    issue = jira_request(config, "GET", f"/rest/api/2/issue/{quote(key)}", query={"fields": fields})
    return jira_issue_from_json(config, issue, fetch_jira_comments(config, key))


def post_jira_comment(config: JiraConfig, key: str, body: str) -> JiraComment:
    """Post a comment to a Jira issue."""
    data = jira_request(config, "POST", f"/rest/api/2/issue/{quote(key)}/comment", payload={"body": body})
    return jira_comment_from_json(data)


def gitlab_project_path() -> str:
    """Return the GitLab project path from glab."""
    data = json.loads(run(["glab", "repo", "view", "--output", "json"]))
    path = data.get("full_name") or data.get("fullName") or data.get("path_with_namespace")
    if not path:
        die("could not detect GitLab project path")
    return quote(str(path), safe="")


def gitlab_mr_iid() -> str:
    """Return the current branch merge request IID."""
    data = json.loads(run(["glab", "mr", "view", "--output", "json"]))
    iid = data.get("iid") or data.get("Iid") or data.get("number")
    if not iid:
        die("could not detect GitLab merge request")
    return str(iid)


def gitlab_latest_version(project: str, iid: str) -> dict[str, Any]:
    """Return the latest GitLab MR version metadata."""
    versions = json.loads(run(["glab", "api", f"projects/{project}/merge_requests/{iid}/versions"]))
    if not versions:
        die("GitLab merge request has no diff versions")
    return versions[0]


def author_name(value: dict[str, Any]) -> str:
    """Return a display name from a provider author object."""
    return str(value.get("username") or value.get("login") or value.get("name") or "unknown")


def remote_threads_by_path(threads: Sequence[RemoteThread]) -> dict[str, list[RemoteThread]]:
    """Return remote review threads grouped by file path."""
    grouped: dict[str, list[RemoteThread]] = {}
    for thread in threads:
        grouped.setdefault(thread.path, []).append(thread)
    return grouped


def fallback_remote_note(
    body: str,
    author: str,
    created_at: str = "",
    *,
    is_reply: bool = False,
) -> RemoteNote | None:
    """Parse a fallback provider comment body into a remote note."""
    match = FALLBACK_BODY_RE.match(body)
    if match is None:
        return None
    return RemoteNote(
        path=match.group("path"),
        line=int(match.group("line")),
        author=author,
        body=match.group("body").strip(),
        note_id="",
        created_at=created_at,
        is_reply=is_reply,
    )


def thread_from_note(
    thread_id: str,
    note: RemoteNote,
    *,
    resolved: bool = False,
    replyable: bool = True,
    pending: bool = False,
) -> RemoteThread:
    """Create a single-note remote thread."""
    return RemoteThread(
        thread_id=thread_id,
        path=note.path,
        line=note.line,
        notes=(note,),
        resolved=resolved,
        replyable=replyable,
        pending=pending,
    )


def provider_note_path_line(note: dict[str, Any], default_path: str, default_line: int) -> tuple[str, int]:
    """Return provider note path and line, falling back to the current thread position."""
    position = note.get("position") or {}
    path = position.get("new_path") or position.get("old_path") or default_path
    line = position.get("new_line") or position.get("old_line") or default_line
    return str(path or ""), int(line or 0)


def provider_note_start_line(note: dict[str, Any], fallback_line: int) -> int:
    """Return the first line covered by a provider note position."""
    position = note.get("position") or {}
    line_range = position.get("line_range") or {}
    start = line_range.get("start") or {}
    start_line = start.get("new_line") or start.get("old_line") or position.get("start_line") or fallback_line
    return int(start_line or fallback_line or 0)


def gitlab_remote_note(note: dict[str, Any], path: str, line: int, *, is_reply: bool) -> RemoteNote:
    """Return a remote note parsed from one GitLab discussion note."""
    return RemoteNote(
        path=path,
        line=line,
        author=author_name(note.get("author") or {}),
        body=str(note.get("body") or ""),
        note_id=str(note.get("id") or ""),
        created_at=str(note.get("created_at") or ""),
        is_reply=is_reply,
        start_line=provider_note_start_line(note, line),
    )


def fetch_gitlab_threads() -> list[RemoteThread]:
    """Fetch GitLab MR discussion threads."""
    project = gitlab_project_path()
    iid = gitlab_mr_iid()
    discussions = json.loads(run(["glab", "api", f"projects/{project}/merge_requests/{iid}/discussions"]))
    threads: list[RemoteThread] = []
    for discussion in discussions:
        discussion_path = ""
        discussion_line = 0
        notes: list[RemoteNote] = []
        for note in discussion.get("notes", []):
            body = str(note.get("body") or "")
            author = author_name(note.get("author") or {})
            created_at = str(note.get("created_at") or "")
            path, line = provider_note_path_line(note, discussion_path, discussion_line)
            if path:
                discussion_path = path
            if line:
                discussion_line = line
            if note.get("system"):
                continue
            if not path or not line:
                fallback = fallback_remote_note(body, author, created_at, is_reply=bool(notes))
                if fallback is not None:
                    notes.append(fallback)
                    discussion_path = fallback.path
                    discussion_line = fallback.line
                continue
            notes.append(gitlab_remote_note(note, path, line, is_reply=bool(notes)))
        if notes:
            thread_id = str(discussion.get("id") or len(threads) + 1)
            resolved = bool(discussion.get("resolved") or any(note.get("resolved") for note in discussion.get("notes", [])))
            threads.append(
                RemoteThread(
                    thread_id=thread_id,
                    path=notes[0].path,
                    line=notes[0].line,
                    notes=tuple(notes),
                    resolved=resolved,
                )
            )
    return [*threads, *fetch_gitlab_draft_threads(project, iid)]


def gitlab_draft_note_thread(note: dict[str, Any], index: int) -> RemoteThread | None:
    """Return a pending GitLab draft note as a remote thread."""
    body = str(note.get("note") or note.get("body") or "")
    created_at = str(note.get("created_at") or "")
    path, line = provider_note_path_line(note, "", 0)
    author = author_name(note.get("author") or {"username": "draft"})
    if not path or not line:
        fallback = fallback_remote_note(body, author, created_at)
        if fallback is None:
            return None
        return thread_from_note(
            f"draft-{note.get('id') or index}",
            fallback,
            replyable=False,
            pending=True,
        )

    note_id = f"draft-{note.get('id') or index}"
    remote_note = RemoteNote(
        path=path,
        line=line,
        author=author,
        body=body,
        note_id=note_id,
        created_at=created_at,
        start_line=provider_note_start_line(note, line),
    )
    return thread_from_note(note_id, remote_note, replyable=False, pending=True)


def fetch_gitlab_draft_threads(project: str, iid: str) -> list[RemoteThread]:
    """Fetch pending GitLab review draft notes visible to the current user."""
    success, output = try_run(["glab", "api", f"projects/{project}/merge_requests/{iid}/draft_notes"])
    if not success:
        return []
    try:
        draft_notes = json.loads(output)
    except json.JSONDecodeError:
        return []

    threads: list[RemoteThread] = []
    for index, note in enumerate(draft_notes, 1):
        if not isinstance(note, dict):
            continue
        thread = gitlab_draft_note_thread(note, index)
        if thread is not None:
            threads.append(thread)
    return threads


def fallback_body(comment: ReviewComment) -> str:
    """Return a general discussion body for providers that reject positioned comments."""
    return f"{comment.path}:{comment.target_line}\n\n{comment.body}"


def publish_gitlab_comment(
    comment: ReviewComment,
    project: str,
    iid: str,
    version: dict[str, Any],
    *,
    positioned: bool,
) -> None:
    """Publish one comment as a GitLab MR discussion."""
    command = [
        "glab",
        "api",
        f"projects/{project}/merge_requests/{iid}/discussions",
        "--method",
        "POST",
        "--header",
        "Content-Type: application/json",
        "--input",
        "-",
    ]
    output = ""
    if positioned:
        payload = {
            "body": comment.body,
            "position": {
                "position_type": "text",
                "base_sha": version["base_commit_sha"],
                "start_sha": version["start_commit_sha"],
                "head_sha": version["head_commit_sha"],
                "new_path": comment.path,
                "old_path": comment.path,
                "new_line": comment.target_line,
            },
        }
        success, output = try_run(command, input_text=json.dumps(payload))
        if success:
            print(f"posted gitlab {comment.path}:{comment.target_line}")
            return

    fallback_success, fallback_output = try_run(command, input_text=json.dumps({"body": fallback_body(comment)}))
    if not fallback_success:
        die(f"could not publish GitLab comment at {comment.path}:{comment.target_line}\n{output}\n{fallback_output}")
    print(f"posted gitlab fallback {comment.path}:{comment.target_line}")


def github_repo() -> str:
    """Return the GitHub owner/repo name."""
    data = json.loads(run(["gh", "repo", "view", "--json", "nameWithOwner"]))
    return str(data["nameWithOwner"])


def github_pr() -> dict[str, Any]:
    """Return the current branch pull request metadata."""
    return json.loads(run(["gh", "pr", "view", "--json", "number,headRefOid"]))


def github_remote_note(comment: dict[str, Any]) -> RemoteNote | None:
    """Return a remote note parsed from one GitHub PR review comment."""
    path = comment.get("path")
    line = comment.get("line") or comment.get("original_line")
    if not path or not line:
        return None
    start_line = comment.get("start_line") or comment.get("original_start_line") or line
    return RemoteNote(
        path=str(path),
        line=int(line),
        author=author_name(comment.get("user") or {}),
        body=str(comment.get("body") or ""),
        note_id=str(comment.get("id") or ""),
        created_at=str(comment.get("created_at") or ""),
        start_line=int(start_line or line),
    )


def remote_note_with_reply(note: RemoteNote, *, is_reply: bool) -> RemoteNote:
    """Return a note with the reply flag adjusted."""
    return RemoteNote(
        path=note.path,
        line=note.line,
        author=note.author,
        body=note.body,
        note_id=note.note_id,
        created_at=note.created_at,
        is_reply=is_reply,
        start_line=note.start_line,
    )


def github_thread_notes(
    root_id: str,
    notes_by_id: dict[str, RemoteNote],
    children_by_parent: dict[str, list[str]],
) -> tuple[RemoteNote, ...]:
    """Return one GitHub review thread with replies flattened in display order."""
    notes = [remote_note_with_reply(notes_by_id[root_id], is_reply=False)]
    for child_id in children_by_parent.get(root_id, []):
        notes.append(remote_note_with_reply(notes_by_id[child_id], is_reply=True))
        for nested_id in children_by_parent.get(child_id, []):
            notes.append(remote_note_with_reply(notes_by_id[nested_id], is_reply=True))
    return tuple(notes)


def fetch_github_pending_review_threads(repo: str, number: str) -> list[RemoteThread]:
    """Fetch pending GitHub review comments visible to the current user."""
    success, output = try_run(["gh", "api", f"repos/{repo}/pulls/{number}/reviews"])
    if not success:
        return []
    try:
        reviews = json.loads(output)
    except json.JSONDecodeError:
        return []

    threads: list[RemoteThread] = []
    for review in reviews:
        if not isinstance(review, dict) or str(review.get("state") or "").upper() != "PENDING":
            continue
        review_id = str(review.get("id") or "")
        if not review_id:
            continue
        comments_success, comments_output = try_run(
            ["gh", "api", f"repos/{repo}/pulls/{number}/reviews/{review_id}/comments"]
        )
        if not comments_success:
            continue
        try:
            comments = json.loads(comments_output)
        except json.JSONDecodeError:
            continue
        for index, comment in enumerate(comments, 1):
            if not isinstance(comment, dict):
                continue
            note = github_remote_note(comment)
            if note is None:
                continue
            thread_id = f"pending-review-{review_id}-{note.note_id or index}"
            threads.append(thread_from_note(thread_id, note, replyable=False, pending=True))
    return threads


def fetch_github_threads() -> list[RemoteThread]:
    """Fetch GitHub PR review threads."""
    repo = github_repo()
    pr = github_pr()
    number = str(pr["number"])
    raw_comments = json.loads(run(["gh", "api", f"repos/{repo}/pulls/{number}/comments"]))
    threads: list[RemoteThread] = []
    notes_by_id: dict[str, RemoteNote] = {}
    parent_by_id: dict[str, str] = {}
    ordered_ids: list[str] = []
    for index, comment in enumerate(raw_comments, 1):
        note = github_remote_note(comment)
        if note is None:
            continue
        note_id = str(comment.get("id") or index)
        parent_id = str(comment.get("in_reply_to_id") or "")
        notes_by_id[note_id] = note
        parent_by_id[note_id] = parent_id
        ordered_ids.append(note_id)

    children_by_parent: dict[str, list[str]] = {}
    for note_id, parent_id in parent_by_id.items():
        if parent_id in notes_by_id:
            children_by_parent.setdefault(parent_id, []).append(note_id)

    for note_id in ordered_ids:
        if parent_by_id[note_id] in notes_by_id:
            continue
        notes = github_thread_notes(note_id, notes_by_id, children_by_parent)
        threads.append(
            RemoteThread(
                thread_id=note_id,
                path=notes[0].path,
                line=notes[0].line,
                notes=notes,
            )
        )

    threads.extend(fetch_github_pending_review_threads(repo, number))

    issue_comments = json.loads(run(["gh", "api", f"repos/{repo}/issues/{number}/comments"]))
    for index, comment in enumerate(issue_comments, 1):
        fallback = fallback_remote_note(
            str(comment.get("body") or ""),
            author_name(comment.get("user") or {}),
            str(comment.get("created_at") or ""),
        )
        if fallback is not None:
            threads.append(thread_from_note(f"issue-{comment.get('id') or index}", fallback, replyable=False))
    return threads


def fetch_remote_threads(provider: str) -> list[RemoteThread]:
    """Fetch published review threads for a provider."""
    if provider == "gitlab":
        return fetch_gitlab_threads()
    if provider == "github":
        return fetch_github_threads()
    die(f"unsupported provider: {provider}")


