REVIEW_MARKER_RE = re.compile(r"(?P<prefix>#|//|--|;|/\*|\*)\s*review\b:?\s*(?P<body>.*)$", re.IGNORECASE)
LEGACY_MARKER_RE = re.compile(r"\breview:\s*(?P<body>.*)$")
MARKER_RE = re.compile(r"(?:#|//|--|;|/\*|\*)\s*review\b:?.*$|\breview:\s*.*$", re.IGNORECASE)
ANSI_RE = re.compile(r"\x1b\[[0-9;?]*[ -/]*[@-~]")
FALLBACK_BODY_RE = re.compile(r"^(?P<path>.+):(?P<line>\d+)\n\n(?P<body>.*)$", re.DOTALL)
SUGGESTION_BLOCK_RE = re.compile(
    r"(?ms)^```suggestion(?P<meta>[^\n`]*)\n(?P<body>.*?)(?:\n```|\Z)"
)
SUGGESTION_RANGE_RE = re.compile(r":(?P<start>[+-]?\d+)(?P<end>[+-]\d+)")
EXPORT_RE = re.compile(r"^\s*export\s+(?P<key>[A-Za-z_][A-Za-z0-9_]*)=(?P<value>.*)$")
JIRA_KEY_RE = re.compile(r"(?<![A-Z0-9])(?P<key>[A-Z][A-Z0-9]+-\d+)(?![A-Z0-9])")
