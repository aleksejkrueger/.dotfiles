def die(message: str) -> None:
    """Print an error message and exit with status 1."""
    print(f"review: {message}", file=sys.stderr)
    raise SystemExit(1)


def run(command: Sequence[str], *, input_text: str | None = None) -> str:
    """Run a command and return stdout."""
    try:
        return subprocess.check_output(
            list(command),
            input=input_text,
            stderr=subprocess.PIPE,
            text=True,
        )
    except FileNotFoundError:
        die(f"missing dependency: {command[0]}")
    except subprocess.CalledProcessError as error:
        detail = error.stderr.strip() or f"command failed: {shlex.join(command)}"
        die(detail)


def try_run(command: Sequence[str], *, input_text: str | None = None) -> tuple[bool, str]:
    """Run a command and return success plus output without exiting."""
    try:
        output = subprocess.check_output(
            list(command),
            input=input_text,
            stderr=subprocess.STDOUT,
            text=True,
        )
    except FileNotFoundError:
        return False, f"missing dependency: {command[0]}"
    except subprocess.CalledProcessError as error:
        return False, error.output.strip() or f"command failed: {shlex.join(command)}"
    return True, output


def call(command: Sequence[str], *, input_text: str | None = None) -> int:
    """Run a command and return its exit code."""
    try:
        return subprocess.run(list(command), input=input_text, text=True, check=False).returncode
    except FileNotFoundError:
        die(f"missing dependency: {command[0]}")


def git(args: Sequence[str]) -> str:
    """Run git and return stdout."""
    return run(["git", *args])


def git_dir() -> Path:
    """Return the repository git directory."""
    return Path(git(["rev-parse", "--git-dir"]).strip())


def branch_name() -> str:
    """Return the current branch name, falling back to HEAD."""
    branch = git(["branch", "--show-current"]).strip()
    return branch or "HEAD"


def ref_exists(ref: str) -> bool:
    """Return whether a git ref exists."""
    return (
        subprocess.run(
            ["git", "rev-parse", "--verify", "--quiet", ref],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        ).returncode
        == 0
    )


def default_base() -> str:
    """Return the repository default comparison base."""
    for ref in ("origin/HEAD", "main", "master"):
        try:
            output = subprocess.check_output(
                ["git", "rev-parse", "--verify", "--quiet", "--abbrev-ref", ref],
                stderr=subprocess.DEVNULL,
                text=True,
            ).strip()
        except subprocess.CalledProcessError:
            continue
        if output:
            local_ref = output.removeprefix("origin/")
            return local_ref if ref_exists(local_ref) else output
    return "main"


def verify_base(base: str) -> None:
    """Fail if the base ref does not exist."""
    git(["rev-parse", "--verify", "--quiet", base])


def safe_name(value: str) -> str:
    """Return a filesystem-safe name."""
    return "".join(character if character.isalnum() else "-" for character in value)


def review_root(base: str) -> Path:
    """Return the private state directory for this branch review."""
    return git_dir() / "review" / f"{safe_name(base)}...{safe_name(branch_name())}"


def state_file(base: str) -> Path:
    """Return the JSON state file for this branch review."""
    return review_root(base) / "state.json"


def load_state(base: str) -> dict[str, Any]:
    """Load review state."""
    path = state_file(base)
    if not path.exists():
        return {"reviewed": []}
    with path.open(encoding="utf-8") as handle:
        return json.load(handle)


def save_state(base: str, state: dict[str, Any]) -> None:
    """Save review state."""
    path = state_file(base)
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        json.dump(state, handle, indent=2, sort_keys=True)
        handle.write("\n")


def changed_files(base: str) -> list[ChangedFile]:
    """Return files changed between base and HEAD."""
    output = subprocess.check_output(
        ["git", "diff", "--name-only", "-z", f"{base}...HEAD"],
        stderr=subprocess.PIPE,
    )
    paths = [path.decode() for path in output.split(b"\0") if path]
    return [ChangedFile(index=index, path=path) for index, path in enumerate(paths, 1)]


def reviewed_paths(state: dict[str, Any]) -> set[str]:
    """Return reviewed file paths from state."""
    return set(state.get("reviewed", []))


def published_comment_ids(state: dict[str, Any]) -> set[str]:
    """Return published review comment IDs from state."""
    return set(state.get("published", []))


def comment_id(comment: ReviewComment) -> str:
    """Return a stable ID for a review comment."""
    payload = {
        "body": comment.body,
        "path": comment.path,
        "target_line": comment.target_line,
    }
    encoded = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode()
    return hashlib.sha1(encoded).hexdigest()


def mark_comment_published(base: str, state: dict[str, Any], comment: ReviewComment) -> None:
    """Persist that a review comment has been published."""
    published = published_comment_ids(state)
    published.add(comment_id(comment))
    state["published"] = sorted(published)
    save_state(base, state)


def is_reviewed(path: str, state: dict[str, Any]) -> bool:
    """Return whether a file is marked reviewed."""
    return path in reviewed_paths(state)


def toggle_reviewed(base: str, path: str) -> None:
    """Toggle the reviewed checkbox for a file."""
    state = load_state(base)
    reviewed = reviewed_paths(state)
    if path in reviewed:
        reviewed.remove(path)
    else:
        reviewed.add(path)
    state["reviewed"] = sorted(reviewed)
    save_state(base, state)


def marker_only(line: str) -> bool:
    """Return whether a line only contains a review marker in a comment."""
    return REVIEW_MARKER_RE.match(line.strip()) is not None or LEGACY_MARKER_RE.match(line.strip()) is not None


def review_marker_match(line: str) -> re.Match[str] | None:
    """Return a review marker match for a line."""
    return REVIEW_MARKER_RE.search(line) or LEGACY_MARKER_RE.search(line)


def next_code_line(lines: list[str], start_index: int) -> int:
    """Return the next non-empty non-marker line number after a marker."""
    for index in range(start_index + 1, len(lines)):
        line = lines[index]
        if line.strip() and not MARKER_RE.search(line):
            return index + 1
    return start_index + 1


def adjusted_target_line(lines: list[str], marker_index: int) -> int:
    """Return the target line adjusted for local standalone marker lines."""
    line = lines[marker_index]
    raw_target = next_code_line(lines, marker_index) if marker_only(line) else marker_index + 1
    local_marker_lines = sum(
        1
        for line_number, current_line in enumerate(lines[:raw_target], 1)
        if line_number <= raw_target and MARKER_RE.search(current_line) and marker_only(current_line)
    )
    return max(1, raw_target - local_marker_lines)


def comments_in_file(path: str) -> list[ReviewComment]:
    """Return review comments found in one file."""
    file_path = Path(path)
    if not file_path.exists() or not file_path.is_file():
        return []

    lines = file_path.read_text(encoding="utf-8", errors="replace").splitlines()
    comments: list[ReviewComment] = []
    for index, line in enumerate(lines):
        match = review_marker_match(line)
        if match is None:
            continue
        body = match.group("body").strip()
        if body:
            comments.append(
                ReviewComment(
                    path=path,
                    marker_line=index + 1,
                    target_line=adjusted_target_line(lines, index),
                    body=body,
                )
            )
    return comments


def collect_comments(files: Sequence[ChangedFile]) -> list[ReviewComment]:
    """Return all local review comments in changed files."""
    comments: list[ReviewComment] = []
    for changed_file in files:
        comments.extend(comments_in_file(changed_file.path))
    return comments


def comments_by_path(files: Sequence[ChangedFile]) -> dict[str, list[ReviewComment]]:
    """Return local review comments grouped by changed file path."""
    comments: dict[str, list[ReviewComment]] = {}
    for changed_file in files:
        path_comments = comments_in_file(changed_file.path)
        if path_comments:
            comments[changed_file.path] = path_comments
    return comments


def remove_published_markers_from_file(path: str, published_ids: set[str]) -> int:
    """Remove standalone local review marker lines by comment ID."""
    file_path = Path(path)
    if not file_path.is_file():
        return 0

    lines = file_path.read_text(encoding="utf-8", errors="replace").splitlines()
    kept_lines: list[str] = []
    removed = 0
    for index, line in enumerate(lines):
        match = review_marker_match(line)
        if match is None or not marker_only(line):
            kept_lines.append(line)
            continue

        comment = ReviewComment(
            path=path,
            marker_line=index + 1,
            target_line=adjusted_target_line(lines, index),
            body=match.group("body").strip(),
        )
        if comment_id(comment) in published_ids:
            removed += 1
            continue
        kept_lines.append(line)

    if removed:
        file_path.write_text("\n".join(kept_lines) + ("\n" if kept_lines else ""), encoding="utf-8")
    return removed


def remove_published_markers(comments: Sequence[ReviewComment]) -> int:
    """Remove standalone local markers for published comments."""
    ids_by_path: dict[str, set[str]] = {}
    for comment in comments:
        ids_by_path.setdefault(comment.path, set()).add(comment_id(comment))
    return sum(remove_published_markers_from_file(path, ids) for path, ids in ids_by_path.items())


def changed_new_lines(base: str, path: str) -> set[int]:
    """Return new-side line numbers touched by the branch diff."""
    diff = git(["diff", "--unified=0", f"{base}...HEAD", "--", path])
    lines: set[int] = set()
    for line in diff.splitlines():
        if not line.startswith("@@"):
            continue
        match = re.search(r"\+(\d+)(?:,(\d+))?", line)
        if match is None:
            continue
        start = int(match.group(1))
        count = int(match.group(2) or "1")
        lines.update(range(start, start + count))
    return lines


def changed_lines_by_path(base: str, paths: set[str]) -> dict[str, set[int]]:
    """Return changed new-side line numbers keyed by file path."""
    return {path: changed_new_lines(base, path) for path in paths}


def print_status(base: str) -> None:
    """Print the changed-file checklist and local comments."""
    files = changed_files(base)
    state = load_state(base)
    file_comments = comments_by_path(files)

    if not files:
        print(f"No files changed against {base}.")
        return

    for changed_file in files:
        checked = "x" if is_reviewed(changed_file.path, state) else " "
        count = len(file_comments.get(changed_file.path, []))
        suffix = f" ({count} comment{'s' if count != 1 else ''})" if count else ""
        print(f"{changed_file.index:>3}. [{checked}] {changed_file.path}{suffix}")


def delta_command(width: int | None = None, *, paging: str = "always") -> list[str]:
    """Return the delta command used for review diffs."""
    command = [
        "delta",
        f"--paging={paging}",
        "--side-by-side",
        "--syntax-theme=Dracula",
        "--line-numbers",
        "--line-numbers-plus-style=#50fa7b #1f3a2a",
        "--line-numbers-minus-style=#ff5555 #4a1f2b",
        "--plus-style=syntax #1f3a2a",
        "--minus-style=syntax #4a1f2b",
        "--plus-emph-style=syntax bold #1f3a2a",
        "--minus-emph-style=syntax bold #4a1f2b",
        "--keep-plus-minus-markers",
    ]
    if width is not None and width > 0:
        command.append(f"--width={width}")
    return command


def diff_command(base: str, path: str, branch: str | None = None) -> list[str]:
    """Return the git diff command for one file."""
    target_branch = branch or branch_name()
    return [
        "git",
        "diff",
        "--no-ext-diff",
        f"--src-prefix={base}/",
        f"--dst-prefix={target_branch}/",
        f"{base}...HEAD",
        "--",
        path,
    ]


def show_diff(base: str, path: str, branch: str | None = None) -> None:
    """Show a side-by-side diff for one file in the pager."""
    git_command = diff_command(base, path, branch)
    delta_process = None
    git_process = subprocess.Popen(git_command, stdout=subprocess.PIPE)
    try:
        delta_process = subprocess.Popen(delta_command(), stdin=git_process.stdout)
    except FileNotFoundError:
        die("missing dependency: delta")
    if git_process.stdout is not None:
        git_process.stdout.close()
    delta_process.wait()
    git_process.wait()


def fast_preview_command(base: str, branch: str) -> str:
    """Return the shell preview command used by fzf fast mode."""
    git_command = [
        "git",
        "diff",
        "--no-ext-diff",
        "--color=always",
        f"--src-prefix={base}/",
        f"--dst-prefix={branch}/",
        f"{base}...HEAD",
        "--",
        "{}",
    ]
    delta_arguments = [argument for argument in delta_command(paging="never") if not argument.startswith("--width=")]
    git_part = shlex.join(git_command).replace("'{}'", "{}")
    delta_part = f"{shlex.join(delta_arguments)} --width=${{FZF_PREVIEW_COLUMNS:-120}}"
    return f"if command -v delta >/dev/null 2>&1; then {git_part} | {delta_part}; else {git_part}; fi"


def fast_select_file(base: str, files: Sequence[ChangedFile]) -> str | None:
    """Select a changed file with fzf and an inline diff preview."""
    command = [
        "fzf",
        "--ansi",
        "--height=100%",
        "--layout=reverse",
        "--border",
        "--prompt=review fast> ",
        "--preview-window=up,70%,border-bottom",
        "--preview",
        fast_preview_command(base, branch_name()),
    ]
    try:
        result = subprocess.run(
            command,
            input="\n".join(changed_file.path for changed_file in files),
            stdout=subprocess.PIPE,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        die("missing dependency: fzf")
    if result.returncode != 0:
        return None
    selected = result.stdout.strip()
    return selected or None


def fast_review(base: str) -> None:
    """Run the lightweight fzf/delta review flow."""
    files = changed_files(base)
    if not files:
        print(f"No files changed against {base}.")
        return
    selected = fast_select_file(base, files)
    if selected is not None:
        show_diff(base, selected, branch_name())


def side_by_side_diff_lines(base: str, path: str, width: int, branch: str | None = None) -> list[str]:
    """Return side-by-side diff lines with ANSI colors preserved."""
    git_command = diff_command(base, path, branch)
    git_process = subprocess.Popen(git_command, stdout=subprocess.PIPE)
    try:
        output = subprocess.check_output(
            delta_command(width, paging="never"),
            stdin=git_process.stdout,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except (FileNotFoundError, subprocess.CalledProcessError):
        output = run(["git", "diff", "--no-color", f"{base}...HEAD", "--", path])
    finally:
        if git_process.stdout is not None:
            git_process.stdout.close()
        git_process.wait()

    lines = [line.replace("\t", "    ") for line in output.splitlines()]
    return lines or ["No diff for this file."]


def open_file(path: str) -> None:
    """Open a file in the configured editor."""
    call(editor_command(path))


def editor_command(path: str) -> list[str]:
    """Return the configured editor command with a file path appended."""
    editor = os.environ.get("VISUAL") or os.environ.get("EDITOR") or "nvim"
    command = shlex.split(editor)
    return [*command, path] if command else ["nvim", path]


def resolve_path(files: Sequence[ChangedFile], value: str) -> str:
    """Resolve a file index or path."""
    if value.isdigit():
        wanted = int(value)
        for changed_file in files:
            if changed_file.index == wanted:
                return changed_file.path
    paths = {changed_file.path for changed_file in files}
    if value in paths:
        return value
    die(f"not a changed file: {value}")


def list_comments(base: str) -> None:
    """Print local review comments."""
    files = changed_files(base)
    comments = collect_comments(files)
    if not comments:
        print("No #review comments found.")
        return

    for comment in comments:
        changed_lines = changed_new_lines(base, comment.path)
        marker = "" if comment.target_line in changed_lines else " [not in diff]"
        print(f"{comment.path}:{comment.target_line}{marker}: {comment.body}")


def remote_url() -> str:
    """Return the git remote URL used to detect the hosting provider."""
    for remote in ("origin", "upstream"):
        try:
            url = subprocess.check_output(
                ["git", "remote", "get-url", remote],
                stderr=subprocess.DEVNULL,
                text=True,
            ).strip()
        except subprocess.CalledProcessError:
            continue
        if url:
            return url
    return ""


def detect_provider() -> str | None:
    """Detect GitLab or GitHub from the git remote URL."""
    url = remote_url().lower()
    if "github" in url:
        return "github"
    if "gitlab" in url:
        return "gitlab"
    return None


def open_review_request(provider: str) -> bool:
    """Open the current merge or pull request in the browser."""
    if provider == "gitlab":
        success, _ = try_run(["glab", "mr", "view", "--web"])
        return success
    if provider == "github":
        success, _ = try_run(["gh", "pr", "view", "--web"])
        return success
    die(f"unsupported provider: {provider}")


def gitlab_project_path() -> str:
    """Return the GitLab project path from glab."""
    data = json.loads(run(["glab", "repo", "view", "--output", "json"]))
    path = data.get("full_name") or data.get("fullName") or data.get("path_with_namespace")
    if not path:
        die("could not detect GitLab project path")
    return quote(str(path), safe="")


def gitlab_mr_iid() -> str:
    """Return the current branch merge request IID."""
    data = json.loads(run(["glab", "mr", "view", "--output", "json"]))
    iid = data.get("iid") or data.get("Iid") or data.get("number")
    if not iid:
        die("could not detect GitLab merge request")
    return str(iid)


def gitlab_latest_version(project: str, iid: str) -> dict[str, Any]:
    """Return the latest GitLab MR version metadata."""
    versions = json.loads(run(["glab", "api", f"projects/{project}/merge_requests/{iid}/versions"]))
    if not versions:
        die("GitLab merge request has no diff versions")
    return versions[0]


def author_name(value: dict[str, Any]) -> str:
    """Return a display name from a provider author object."""
    return str(value.get("username") or value.get("login") or value.get("name") or "unknown")


def remote_threads_by_path(threads: Sequence[RemoteThread]) -> dict[str, list[RemoteThread]]:
    """Return remote review threads grouped by file path."""
    grouped: dict[str, list[RemoteThread]] = {}
    for thread in threads:
        grouped.setdefault(thread.path, []).append(thread)
    return grouped


def fallback_remote_note(
    body: str,
    author: str,
    created_at: str = "",
    *,
    is_reply: bool = False,
) -> RemoteNote | None:
    """Parse a fallback provider comment body into a remote note."""
    match = FALLBACK_BODY_RE.match(body)
    if match is None:
        return None
    return RemoteNote(
        path=match.group("path"),
        line=int(match.group("line")),
        author=author,
        body=match.group("body").strip(),
        note_id="",
        created_at=created_at,
        is_reply=is_reply,
    )


def thread_from_note(
    thread_id: str,
    note: RemoteNote,
    *,
    resolved: bool = False,
    replyable: bool = True,
) -> RemoteThread:
    """Create a single-note remote thread."""
    return RemoteThread(
        thread_id=thread_id,
        path=note.path,
        line=note.line,
        notes=(note,),
        resolved=resolved,
        replyable=replyable,
    )


def provider_note_path_line(note: dict[str, Any], default_path: str, default_line: int) -> tuple[str, int]:
    """Return provider note path and line, falling back to the current thread position."""
    position = note.get("position") or {}
    path = position.get("new_path") or position.get("old_path") or default_path
    line = position.get("new_line") or position.get("old_line") or default_line
    return str(path or ""), int(line or 0)


def gitlab_remote_note(note: dict[str, Any], path: str, line: int, *, is_reply: bool) -> RemoteNote:
    """Return a remote note parsed from one GitLab discussion note."""
    return RemoteNote(
        path=path,
        line=line,
        author=author_name(note.get("author") or {}),
        body=str(note.get("body") or ""),
        note_id=str(note.get("id") or ""),
        created_at=str(note.get("created_at") or ""),
        is_reply=is_reply,
    )


def fetch_gitlab_threads() -> list[RemoteThread]:
    """Fetch GitLab MR discussion threads."""
    project = gitlab_project_path()
    iid = gitlab_mr_iid()
    discussions = json.loads(run(["glab", "api", f"projects/{project}/merge_requests/{iid}/discussions"]))
    threads: list[RemoteThread] = []
    for discussion in discussions:
        discussion_path = ""
        discussion_line = 0
        notes: list[RemoteNote] = []
        for note in discussion.get("notes", []):
            body = str(note.get("body") or "")
            author = author_name(note.get("author") or {})
            created_at = str(note.get("created_at") or "")
            path, line = provider_note_path_line(note, discussion_path, discussion_line)
            if path:
                discussion_path = path
            if line:
                discussion_line = line
            if note.get("system"):
                continue
            if not path or not line:
                fallback = fallback_remote_note(body, author, created_at, is_reply=bool(notes))
                if fallback is not None:
                    notes.append(fallback)
                    discussion_path = fallback.path
                    discussion_line = fallback.line
                continue
            notes.append(gitlab_remote_note(note, path, line, is_reply=bool(notes)))
        if notes:
            thread_id = str(discussion.get("id") or len(threads) + 1)
            resolved = bool(discussion.get("resolved") or any(note.get("resolved") for note in discussion.get("notes", [])))
            threads.append(
                RemoteThread(
                    thread_id=thread_id,
                    path=notes[0].path,
                    line=notes[0].line,
                    notes=tuple(notes),
                    resolved=resolved,
                )
            )
    return threads


def fallback_body(comment: ReviewComment) -> str:
    """Return a general discussion body for providers that reject positioned comments."""
    return f"{comment.path}:{comment.target_line}\n\n{comment.body}"


def publish_gitlab_comment(
    comment: ReviewComment,
    project: str,
    iid: str,
    version: dict[str, Any],
    *,
    positioned: bool,
) -> None:
    """Publish one comment as a GitLab MR discussion."""
    command = [
        "glab",
        "api",
        f"projects/{project}/merge_requests/{iid}/discussions",
        "--method",
        "POST",
        "--header",
        "Content-Type: application/json",
        "--input",
        "-",
    ]
    output = ""
    if positioned:
        payload = {
            "body": comment.body,
            "position": {
                "position_type": "text",
                "base_sha": version["base_commit_sha"],
                "start_sha": version["start_commit_sha"],
                "head_sha": version["head_commit_sha"],
                "new_path": comment.path,
                "old_path": comment.path,
                "new_line": comment.target_line,
            },
        }
        success, output = try_run(command, input_text=json.dumps(payload))
        if success:
            print(f"posted gitlab {comment.path}:{comment.target_line}")
            return

    fallback_success, fallback_output = try_run(command, input_text=json.dumps({"body": fallback_body(comment)}))
    if not fallback_success:
        die(f"could not publish GitLab comment at {comment.path}:{comment.target_line}\n{output}\n{fallback_output}")
    print(f"posted gitlab fallback {comment.path}:{comment.target_line}")


def github_repo() -> str:
    """Return the GitHub owner/repo name."""
    data = json.loads(run(["gh", "repo", "view", "--json", "nameWithOwner"]))
    return str(data["nameWithOwner"])


def github_pr() -> dict[str, Any]:
    """Return the current branch pull request metadata."""
    return json.loads(run(["gh", "pr", "view", "--json", "number,headRefOid"]))


def github_remote_note(comment: dict[str, Any]) -> RemoteNote | None:
    """Return a remote note parsed from one GitHub PR review comment."""
    path = comment.get("path")
    line = comment.get("line") or comment.get("original_line")
    if not path or not line:
        return None
    return RemoteNote(
        path=str(path),
        line=int(line),
        author=author_name(comment.get("user") or {}),
        body=str(comment.get("body") or ""),
        note_id=str(comment.get("id") or ""),
        created_at=str(comment.get("created_at") or ""),
    )


def remote_note_with_reply(note: RemoteNote, *, is_reply: bool) -> RemoteNote:
    """Return a note with the reply flag adjusted."""
    return RemoteNote(
        path=note.path,
        line=note.line,
        author=note.author,
        body=note.body,
        note_id=note.note_id,
        created_at=note.created_at,
        is_reply=is_reply,
    )


def github_thread_notes(
    root_id: str,
    notes_by_id: dict[str, RemoteNote],
    children_by_parent: dict[str, list[str]],
) -> tuple[RemoteNote, ...]:
    """Return one GitHub review thread with replies flattened in display order."""
    notes = [remote_note_with_reply(notes_by_id[root_id], is_reply=False)]
    for child_id in children_by_parent.get(root_id, []):
        notes.append(remote_note_with_reply(notes_by_id[child_id], is_reply=True))
        for nested_id in children_by_parent.get(child_id, []):
            notes.append(remote_note_with_reply(notes_by_id[nested_id], is_reply=True))
    return tuple(notes)


def fetch_github_threads() -> list[RemoteThread]:
    """Fetch GitHub PR review threads."""
    repo = github_repo()
    pr = github_pr()
    number = str(pr["number"])
    raw_comments = json.loads(run(["gh", "api", f"repos/{repo}/pulls/{number}/comments"]))
    threads: list[RemoteThread] = []
    notes_by_id: dict[str, RemoteNote] = {}
    parent_by_id: dict[str, str] = {}
    ordered_ids: list[str] = []
    for index, comment in enumerate(raw_comments, 1):
        note = github_remote_note(comment)
        if note is None:
            continue
        note_id = str(comment.get("id") or index)
        parent_id = str(comment.get("in_reply_to_id") or "")
        notes_by_id[note_id] = note
        parent_by_id[note_id] = parent_id
        ordered_ids.append(note_id)

    children_by_parent: dict[str, list[str]] = {}
    for note_id, parent_id in parent_by_id.items():
        if parent_id in notes_by_id:
            children_by_parent.setdefault(parent_id, []).append(note_id)

    for note_id in ordered_ids:
        if parent_by_id[note_id] in notes_by_id:
            continue
        notes = github_thread_notes(note_id, notes_by_id, children_by_parent)
        threads.append(
            RemoteThread(
                thread_id=note_id,
                path=notes[0].path,
                line=notes[0].line,
                notes=notes,
            )
        )

    issue_comments = json.loads(run(["gh", "api", f"repos/{repo}/issues/{number}/comments"]))
    for index, comment in enumerate(issue_comments, 1):
        fallback = fallback_remote_note(
            str(comment.get("body") or ""),
            author_name(comment.get("user") or {}),
            str(comment.get("created_at") or ""),
        )
        if fallback is not None:
            threads.append(thread_from_note(f"issue-{comment.get('id') or index}", fallback, replyable=False))
    return threads


def fetch_remote_threads(provider: str) -> list[RemoteThread]:
    """Fetch published review threads for a provider."""
    if provider == "gitlab":
        return fetch_gitlab_threads()
    if provider == "github":
        return fetch_github_threads()
    die(f"unsupported provider: {provider}")


def post_gitlab_reply(thread: RemoteThread, body: str) -> None:
