    def show_jira_popup(self) -> None:
        """Show the current Jira ticket and allow adding comments."""
        key = current_jira_issue_key(self.branch)
        if not key:
            self.show_text_popup("jira", ["No Jira key found in JIRA_KEY or current branch name."])
            return

        config = jira_config()
        if not config.base_url:
            self.show_text_popup("jira", [f"No Jira URL found. Set JIRA_URL in {work_config_path()}."])
            return

        issue, status = self.load_jira_issue_for_popup(config, key)
        if issue is None:
            self.show_text_popup("jira", [status])
            return

        self.draw()
        height, width = self.screen.getmaxyx()
        popup_height = max(8, min(height - 4, int(height * 0.8)))
        popup_width = max(50, min(width - 4, int(width * 0.88)))
        top = max(1, (height - popup_height) // 2)
        left = max(1, (width - popup_width) // 2)
        content_width = popup_width - 4
        content_height = popup_height - 4
        scroll = 0

        while True:
            lines = jira_issue_popup_lines(issue, content_width)
            max_scroll = max(0, len(lines) - content_height)
            scroll = max(0, min(scroll, max_scroll))
            popup = curses.newwin(popup_height, popup_width, top, left)
            popup.keypad(True)
            popup.erase()
            popup.box()
            add_text(popup, 0, 2, f" jira {issue.key} ", popup_width - 4, curses.A_BOLD | color_pair(theme_color("purple")))
            footer = status or "j/k scroll  J/K page  a comment  R refresh  o open  q/Esc"
            add_text(
                popup,
                popup_height - 2,
                2,
                footer.ljust(popup_width - 4),
                popup_width - 4,
                color_pair(theme_color("comment")),
            )
            for row in range(content_height):
                index = scroll + row
                if index >= len(lines):
                    break
                text, mode = lines[index]
                add_text(popup, row + 2, 2, text.ljust(content_width), content_width, mode)
            popup.refresh()

            key_pressed = popup.getch()
            if key_pressed in {ord("q"), curses.KEY_ENTER, 10, 13} or is_escape_key(key_pressed):
                self.draw()
                return
            if key_pressed in {ord("j"), curses.KEY_DOWN}:
                scroll += 1
                status = ""
            elif key_pressed in {ord("k"), curses.KEY_UP}:
                scroll -= 1
                status = ""
            elif key_pressed in {ord("J"), curses.KEY_NPAGE}:
                scroll += content_height
                status = ""
            elif key_pressed in {ord("K"), curses.KEY_PPAGE}:
                scroll -= content_height
                status = ""
            elif key_pressed == ord("R"):
                refreshed_issue, refresh_status = self.load_jira_issue_for_popup(config, issue.key)
                if refreshed_issue is not None:
                    issue = refreshed_issue
                    status = "Jira ticket refreshed."
                else:
                    status = refresh_status
            elif key_pressed == ord("a"):
                issue, status = self.add_jira_comment_from_popup(config, issue)
            elif key_pressed == ord("o"):
                status = "Opened Jira ticket." if open_url(issue.url) else "Could not open Jira ticket."

    def load_remote_comments(self, provider: str) -> None:
        """Load remote comments into the TUI cache."""
        self.remote_threads_by_path = remote_threads_by_path(fetch_remote_threads(provider))

    def try_load_remote_comments(self, provider: str) -> tuple[bool, str]:
        """Load remote comments and return success plus a status message."""
        output = StringIO()
        with redirect_stdout(output), redirect_stderr(output):
            try:
                self.load_remote_comments(provider)
            except SystemExit:
                detail = output.getvalue().strip().splitlines()
                message = detail[-1] if detail else f"Could not load {provider} comments."
                return False, message
            except Exception as error:
                return False, f"review: {error}"

        total = sum(len(threads) for threads in self.remote_threads_by_path.values())
        return True, f"Loaded {total} remote thread{'s' if total != 1 else ''}."

    def load_startup_remote_comments(self) -> None:
        """Load remote comments automatically when the TUI starts."""
        provider = detect_provider()
        if provider is None:
            return
        self.message = f"Loading {provider} comments..."
        self.draw()
        success, message = self.try_load_remote_comments(provider)
        self.message = message if success else f"Remote comments not loaded: {message}"

    def refresh_remote_comments(self) -> None:
        """Refresh remote MR/PR comments."""
        provider = detect_provider()
        if provider is None:
            self.message = "Remote refresh cancelled: could not detect GitLab/GitHub remote."
            return
        self.message = f"Loading {provider} comments..."
        self.draw()
        success, message = self.try_load_remote_comments(provider)
        self.message = message if success else f"Remote refresh failed: {message}"

    def target_reply_drafts(self, target: ReplyTarget) -> list[ReplyDraft]:
        """Return reply drafts for a selected remote note."""
        return [
            draft
            for draft in reply_drafts(self.state)
            if reply_draft_matches_target(draft, target)
        ]

    def reply_target_for_draft(self, draft: ReplyDraft) -> ReplyTarget | None:
        """Return the current remote reply target for a saved draft."""
        for thread in self.remote_threads_by_path.get(draft.path, []):
            if thread.thread_id != draft.thread_id:
                continue
            for note in thread.notes:
                if note.note_id == draft.note_id:
                    return ReplyTarget(thread=thread, note=note)
        return None

    def comment_popup_lines(
        self,
        width: int,
        selected_target: int,
    ) -> tuple[list[tuple[str, int]], list[tuple[int, int]], list[CommentPopupSelection]]:
        """Return comment popup lines, selected row ranges, and selections."""
        current = self.selected_file()
        if current is None:
            return [("No file selected.", color_pair(theme_color("comment")))], [], []

        lines: list[tuple[str, int]] = []
        target_ranges: list[tuple[int, int]] = []
        targets: list[CommentPopupSelection] = []
        target_index = 0
        local_comments = self.comments_by_path.get(current.path, [])
        remote_threads = self.remote_threads_by_path.get(current.path, [])
        for index, comment in enumerate(local_comments, 1):
            header = f"local draft {index}  line {comment.target_line}"
            lines.append((header, curses.A_BOLD | color_pair(theme_color("yellow"))))
            append_wrapped_popup_text(lines, comment.body, width, 2, color_pair(theme_color("foreground")))
            lines.append(("", 0))
        for index, thread in enumerate(remote_threads, 1):
            replies = max(0, len(thread.notes) - 1)
            state = "pending" if thread.pending else "resolved" if thread.resolved else "open"
            header = f"thread {index}  line {thread.line}  {state}  {replies} repl{'y' if replies == 1 else 'ies'}"
            lines.append((header, curses.A_BOLD | color_pair(theme_color("purple"))))
            for note_index, note in enumerate(thread.notes):
                is_reply = note_index > 0 or note.is_reply
                timestamp = short_timestamp(note.created_at)
                suffix = f"  {timestamp}" if timestamp else ""
                marker = ">" if target_index == selected_target else " "
                prefix = f"{marker} |- reply" if is_reply else f"{marker} comment"
                color = theme_color("green") if is_reply else theme_color("cyan")
                mode = curses.A_BOLD | color_pair(color)
                if target_index == selected_target:
                    mode |= curses.A_REVERSE
                block_start = len(lines)
                target = ReplyTarget(thread=thread, note=note)
                targets.append(CommentPopupSelection(target=target))
                lines.append((f"{prefix} @{note.author}{suffix}", mode))
                append_wrapped_popup_text(lines, note.body, width, 6 if is_reply else 4, color_pair(theme_color("foreground")))
                target_ranges.append((block_start, len(lines) - 1))
                active_suggestions = [] if thread.resolved else note_suggestions(note)
                for suggestion_index, suggestion in enumerate(active_suggestions, 1):
                    target_index += 1
                    marker = ">" if target_index == selected_target else " "
                    location = (
                        f"line {suggestion.start_line}"
                        if suggestion.start_line == suggestion.end_line
                        else f"lines {suggestion.start_line}-{suggestion.end_line}"
                    )
                    mode = curses.A_BOLD | color_pair(theme_color("orange"))
                    if target_index == selected_target:
                        mode |= curses.A_REVERSE
                    block_start = len(lines)
                    targets.append(CommentPopupSelection(target=target, suggestion=suggestion))
                    lines.append((f"{marker}    suggestion {suggestion_index}  {location}", mode))
                    append_wrapped_popup_text(lines, suggestion.body, width, 8, color_pair(theme_color("foreground")))
                    target_ranges.append((block_start, len(lines) - 1))
                for draft_index, draft in enumerate(self.target_reply_drafts(target), 1):
                    target_index += 1
                    marker = ">" if target_index == selected_target else " "
                    mode = curses.A_BOLD | color_pair(theme_color("yellow"))
                    if target_index == selected_target:
                        mode |= curses.A_REVERSE
                    block_start = len(lines)
                    targets.append(CommentPopupSelection(target=target, draft=draft))
                    lines.append(
                        (
                            f"{marker}    draft {draft_index}",
                            mode,
                        )
                    )
                    append_wrapped_popup_text(lines, draft.body, width, 8, color_pair(theme_color("foreground")))
                    target_ranges.append((block_start, len(lines) - 1))
                target_index += 1
            lines.append(("", 0))
        return lines or [("No comments for this file.", color_pair(theme_color("comment")))], target_ranges, targets

    def add_reply_draft_to_target(self, target: ReplyTarget) -> str:
        """Prompt for and save a reply draft for the selected remote note."""
        if not target.thread.replyable:
            return "This comment is not replyable from the review API."
        body = prompt(self.screen, "draft> ")
        if body is None:
            return "Draft cancelled."
        if not body:
            return "Draft cancelled: empty body."
        add_reply_draft(self.ref_range, target, body)
        self.state = load_state(self.ref_range)
        return "Draft saved."

    def edit_reply_draft(self, draft: ReplyDraft) -> str:
        """Open the selected reply draft in the configured editor."""
        success, body = self.suspend(lambda: edit_text(draft.body))
        if not success:
            return "Draft edit cancelled: editor exited with an error."
        if not body:
            return "Draft edit cancelled: empty body."
        if body == draft.body:
            return "Draft unchanged."
        update_reply_draft_body(self.ref_range, draft, body)
        self.state = load_state(self.ref_range)
        return "Draft updated."

    def remove_latest_reply_draft_for_target(self, target: ReplyTarget) -> str:
        """Remove the newest draft for the selected remote note."""
        drafts = self.target_reply_drafts(target)
        if not drafts:
            return "No draft for selected comment."
        removed = remove_reply_drafts(self.ref_range, {drafts[-1].draft_id})
        self.state = load_state(self.ref_range)
        return f"Removed {removed} draft{'s' if removed != 1 else ''}."

    def remove_reply_draft_for_selection(self, selection: CommentPopupSelection) -> str:
        """Remove the selected draft or the newest draft for a selected note."""
        if selection.suggestion is not None:
            return "Selected row is not a draft."
        if selection.draft is None:
            return self.remove_latest_reply_draft_for_target(selection.target)
        removed = remove_reply_drafts(self.ref_range, {selection.draft.draft_id})
        self.state = load_state(self.ref_range)
        return f"Removed {removed} draft{'s' if removed != 1 else ''}."

    def publish_reply_drafts(self, drafts: Sequence[ReplyDraft]) -> str:
        """Publish saved reply drafts."""
        if not drafts:
            return "No reply drafts selected."
        answer = prompt(self.screen, f"publish {len(drafts)} draft{'s' if len(drafts) != 1 else ''}? y/N ")
        if answer is None or answer.lower() != "y":
            return "Publish drafts cancelled."

        provider = detect_provider()
        if provider is None:
            return "Publish drafts failed: could not detect GitLab/GitHub remote."

        published_ids: set[str] = set()
        failures: list[str] = []
        for draft in drafts:
            target = self.reply_target_for_draft(draft)
            if target is None:
                failures.append(f"missing thread for {draft.path}:{draft.line}")
                continue
            output = StringIO()
            with redirect_stdout(output), redirect_stderr(output):
                try:
                    post_remote_reply(provider, target.thread, target.note, draft.body)
                except SystemExit:
                    detail = output.getvalue().strip().splitlines()
                    failures.append(detail[-1] if detail else f"failed {draft.path}:{draft.line}")
                    continue
                except Exception as error:
                    failures.append(str(error))
                    continue
            published_ids.add(draft.draft_id)

        if published_ids:
            remove_reply_drafts(self.ref_range, published_ids)
            self.state = load_state(self.ref_range)
            self.try_load_remote_comments(provider)

        summary = f"Published {len(published_ids)} draft{'s' if len(published_ids) != 1 else ''}."
        if failures:
            summary = f"{summary} {len(failures)} failed: {failures[0]}"
        return summary

    def publish_reply_drafts_for_current_file(self) -> str:
        """Publish saved reply drafts for the selected file."""
        current = self.selected_file()
        if current is None:
            return "No file selected."
        drafts = [draft for draft in reply_drafts(self.state) if draft.path == current.path]
        if not drafts:
            return "No reply drafts for this file."
        return self.publish_reply_drafts(drafts)

    def publish_reply_drafts_for_selection(self, selection: CommentPopupSelection) -> str:
        """Publish the selected draft or all drafts for the current file."""
        if selection.suggestion is not None:
            return "Selected row is not a draft."
        if selection.draft is None:
            return self.publish_reply_drafts_for_current_file()
        return self.publish_reply_drafts([selection.draft])

    def toggle_selected_thread_resolved(self, target: ReplyTarget) -> str:
        """Toggle resolved state for the selected remote thread."""
        if target.thread.pending:
            return "Pending review comments cannot be resolved before publishing."
        provider = detect_provider()
        if provider is None:
            return "Resolve toggle failed: could not detect GitLab/GitHub remote."
        message = toggle_remote_thread_resolved(provider, target.thread)
        if message.startswith("Marked thread"):
            self.try_load_remote_comments(provider)
        return message

    def copy_selected_popup_row(self, selection: CommentPopupSelection) -> str:
        """Copy the selected comment, suggestion, or draft body to the clipboard."""
        if selection.suggestion is not None:
            body = selection.suggestion.body
        else:
            body = selection.draft.body if selection.draft is not None else selection.target.note.body
        success, message = copy_to_clipboard(body)
        return message if success else f"Copy failed: {message}"

    def apply_selected_suggestion(self, selection: CommentPopupSelection) -> str:
        """Apply the selected suggestion to the working tree."""
        if selection.suggestion is None:
            return "No suggestion selected."
        suggestion = selection.suggestion
        location = (
            f"{suggestion.path}:{suggestion.start_line}"
            if suggestion.start_line == suggestion.end_line
            else f"{suggestion.path}:{suggestion.start_line}-{suggestion.end_line}"
        )
        answer = prompt(self.screen, f"apply suggestion to {location}? y/N ")
        if answer is None or answer.lower() != "y":
            return "Apply suggestion cancelled."
        undo, undo_error = build_suggestion_undo(suggestion)
        if undo is None:
            return f"Apply suggestion failed: {undo_error}"
        success, message = apply_suggestion_to_file(suggestion)
        if success:
            save_suggestion_undo(self.ref_range, undo)
            self.state = load_state(self.ref_range)
            self.diff_cache.clear()
        return message if success else f"Apply suggestion failed: {message}"

    def undo_last_suggestion(self) -> str:
        """Undo the last applied suggestion."""
        success, message = restore_suggestion_undo(self.ref_range)
        if success:
            self.state = load_state(self.ref_range)
            self.diff_cache.clear()
        return message if success else f"Undo failed: {message}"

    def jump_diff_to_line(self, path: str, line_number: int) -> bool:
        """Scroll the diff view to a rendered line number if it can be found."""
        _, width = self.screen.getmaxyx()
        cache_key = (path, width)
        if cache_key not in self.diff_cache:
            self.diff_cache[cache_key] = side_by_side_diff_lines(self.ref_range, path, width, self.branch)
        for index, line in enumerate(self.diff_cache[cache_key]):
            if rendered_new_line_matches(line, line_number):
                self.diff_scroll = index
                return True
        return False

    def jump_to_remote_target(self, target: ReplyTarget) -> str:
        """Close the popup and jump the main diff to the selected remote line."""
        current = self.selected_file()
        if current is None:
            return "No file selected."
        if current.path != target.note.path:
            return f"Selected comment belongs to {target.note.path}."
        if self.jump_diff_to_line(target.note.path, target.note.line):
            self.message = f"Jumped to {target.note.path}:{target.note.line}."
        else:
            self.message = f"Could not find line {target.note.line} in rendered diff."
        return self.message

    def jump_to_popup_selection(self, selection: CommentPopupSelection) -> str:
        """Close the popup and jump the main diff to the selected row line."""
        if selection.suggestion is None:
            return self.jump_to_remote_target(selection.target)
        current = self.selected_file()
        if current is None:
            return "No file selected."
        if current.path != selection.suggestion.path:
            return f"Selected suggestion belongs to {selection.suggestion.path}."
        if self.jump_diff_to_line(selection.suggestion.path, selection.suggestion.start_line):
            self.message = f"Jumped to {selection.suggestion.path}:{selection.suggestion.start_line}."
        else:
            self.message = f"Could not find line {selection.suggestion.start_line} in rendered diff."
        return self.message

    def reply_to_remote_target(self, target: ReplyTarget) -> str:
        """Prompt for and post a reply to the selected remote note."""
        if not target.thread.replyable:
            return "This comment is not replyable from the review API."
        body = prompt(self.screen, "reply> ")
        if body is None:
            return "Reply cancelled."
        if not body:
            return "Reply cancelled: empty body."

        provider = detect_provider()
        if provider is None:
            return "Reply failed: could not detect GitLab/GitHub remote."

        output = StringIO()
        with redirect_stdout(output), redirect_stderr(output):
            try:
                post_remote_reply(provider, target.thread, target.note, body)
            except SystemExit:
                detail = output.getvalue().strip().splitlines()
                return detail[-1] if detail else "Reply failed."
            except Exception as error:
                return f"Reply failed: {error}"

        success, message = self.try_load_remote_comments(provider)
        if not success:
            return f"Reply posted, but refresh failed: {message}"
        return f"Reply posted. {message}"

    def show_comments_popup(self) -> None:
        """Show scrollable comments for the selected file."""
        self.draw()
        height, width = self.screen.getmaxyx()
        popup_height = max(8, min(height - 4, int(height * 0.75)))
        popup_width = max(50, min(width - 4, int(width * 0.85)))
        top = max(1, (height - popup_height) // 2)
        left = max(1, (width - popup_width) // 2)
        content_width = popup_width - 4
        content_height = popup_height - 4
        selected_target = 0
        scroll = 0
        status = ""

        while True:
            lines, target_ranges, targets = self.comment_popup_lines(content_width, selected_target)
            if targets:
                if selected_target >= len(targets):
                    selected_target = len(targets) - 1
                    lines, target_ranges, targets = self.comment_popup_lines(content_width, selected_target)
                selected_target = max(0, selected_target)
                block_start, block_end = target_ranges[selected_target]
                scroll = scroll_for_selected_block(scroll, content_height, block_start, block_end)
            max_scroll = max(0, len(lines) - content_height)
            scroll = max(0, min(scroll, max_scroll))
            popup = curses.newwin(popup_height, popup_width, top, left)
            popup.keypad(True)
            popup.erase()
            popup.box()
            add_text(popup, 0, 2, " comments ", popup_width - 4, curses.A_BOLD | color_pair(theme_color("purple")))
            footer = (
                status
                or "Up/Down/j/k select  J/K page  a add/edit  A apply  u undo  x del  P pub  r reply  s res  y copy  g goto  q/Esc"
            )
            add_text(
                popup,
                popup_height - 2,
                2,
                footer.ljust(popup_width - 4),
                popup_width - 4,
                color_pair(theme_color("comment")),
            )
            for row in range(content_height):
                index = scroll + row
                if index >= len(lines):
                    break
                text, mode = lines[index]
                add_text(popup, row + 2, 2, text.ljust(content_width), content_width, mode)
            popup.refresh()
            key = popup.getch()
            if key in {ord("q"), 27, curses.KEY_ENTER, 10, 13}:
                self.draw()
                return
            if key in {ord("j"), curses.KEY_DOWN}:
                selected_target = selected_target + 1 if targets else selected_target
                if targets:
                    selected_target %= len(targets)
                else:
                    scroll += 1
                status = ""
            elif key in {ord("k"), curses.KEY_UP}:
                selected_target = selected_target - 1 if targets else selected_target
                if targets:
                    selected_target %= len(targets)
                else:
                    scroll -= 1
                status = ""
            elif key in {ord("J"), curses.KEY_NPAGE}:
                scroll += content_height
                status = ""
            elif key in {ord("K"), curses.KEY_PPAGE}:
                scroll -= content_height
                status = ""
            elif key == ord("a"):
                if targets:
                    selection = targets[selected_target]
                    status = (
                        self.edit_reply_draft(selection.draft)
                        if selection.draft is not None
                        else self.add_reply_draft_to_target(selection.target)
                    )
                else:
                    status = "No remote comment selected."
            elif key == ord("x"):
                status = (
                    self.remove_reply_draft_for_selection(targets[selected_target])
                    if targets
                    else "No remote comment selected."
                )
            elif key == ord("P"):
                status = (
                    self.publish_reply_drafts_for_selection(targets[selected_target])
                    if targets
                    else self.publish_reply_drafts_for_current_file()
                )
            elif key == ord("A"):
                status = self.apply_selected_suggestion(targets[selected_target]) if targets else "No suggestion selected."
            elif key == ord("u"):
                status = self.undo_last_suggestion()
            elif key == ord("r"):
                status = (
                    self.reply_to_remote_target(targets[selected_target].target)
                    if targets
                    else "No remote comment selected."
                )
            elif key == ord("s"):
                status = (
                    self.toggle_selected_thread_resolved(targets[selected_target].target)
                    if targets
                    else "No remote comment selected."
                )
            elif key == ord("y"):
                status = self.copy_selected_popup_row(targets[selected_target]) if targets else "No remote comment selected."
            elif key == ord("g"):
                if targets:
                    self.jump_to_popup_selection(targets[selected_target])
                    self.draw()
                    return
                status = "No remote comment selected."

    def show_text_popup(self, title: str, messages: Sequence[str]) -> None:
        """Show plain text messages in a scrollable popup."""
        def line_factory(width: int) -> Sequence[tuple[str, int]]:
            """Return wrapped lines for this popup."""
            return plain_popup_lines(messages, width)

        self.show_scroll_popup(title, line_factory)

    def show_help_popup(self) -> None:
        """Show in-app help in a scrollable popup."""
        self.show_scroll_popup("help", help_popup_lines)

    def show_scroll_popup(self, title: str, line_factory: Callable[[int], Sequence[tuple[str, int]]]) -> None:
        """Show styled lines in a scrollable popup."""
        self.draw()
        height, width = self.screen.getmaxyx()
        popup_height = max(8, min(height - 4, int(height * 0.75)))
        popup_width = max(50, min(width - 4, int(width * 0.85)))
        top = max(1, (height - popup_height) // 2)
        left = max(1, (width - popup_width) // 2)
        content_width = popup_width - 4
        content_height = popup_height - 4
        scroll = 0

        while True:
            lines = list(line_factory(content_width))
            max_scroll = max(0, len(lines) - content_height)
            scroll = max(0, min(scroll, max_scroll))
            popup = curses.newwin(popup_height, popup_width, top, left)
            popup.keypad(True)
            popup.erase()
            popup.box()
            add_text(popup, 0, 2, f" {title} ", popup_width - 4, curses.A_BOLD | color_pair(theme_color("purple")))
            add_text(
                popup,
                popup_height - 2,
                2,
                "j/k scroll  J/K page  q/Esc close".ljust(popup_width - 4),
                popup_width - 4,
                color_pair(theme_color("comment")),
            )
            for row in range(content_height):
                index = scroll + row
                if index >= len(lines):
                    break
                text, mode = lines[index]
                add_text(popup, row + 2, 2, text.ljust(content_width), content_width, mode)
            popup.refresh()
            key = popup.getch()
            if key in {ord("q"), 27, curses.KEY_ENTER, 10, 13}:
                self.draw()
                return
            if key in {ord("j"), curses.KEY_DOWN}:
                scroll += 1
            elif key in {ord("k"), curses.KEY_UP}:
                scroll -= 1
            elif key in {ord("J"), curses.KEY_NPAGE}:
                scroll += content_height
            elif key in {ord("K"), curses.KEY_PPAGE}:
                scroll -= content_height

    def suspend(self, action: Callable[[], Any]) -> Any:
        """Temporarily hand the terminal to an interactive command."""
        curses.def_prog_mode()
        curses.endwin()
        try:
            return action()
        finally:
            curses.reset_prog_mode()
            curses.curs_set(0)
            self.screen.keypad(True)

    def draw(self) -> None:
        """Draw the full TUI."""
        self.screen.erase()
        self.search_cursor = None
        height, width = self.screen.getmaxyx()
        if height < 12 or width < 60:
            add_text(self.screen, 0, 0, "Terminal too small for review.", width)
            self.screen.refresh()
            return

        files_height = max(5, min(10, height // 4))
        comments_height = max(4, min(7, height // 5))
        diff_height = height - files_height - comments_height - 4

        self.draw_header(width)
        self.draw_diff(1, 0, diff_height, width)
        self.draw_comments(1 + diff_height, 0, comments_height, width)
        self.draw_files(1 + diff_height + comments_height, 0, files_height, width)
        add_text(
            self.screen,
            height - 2,
            0,
            self.message.ljust(width),
            width,
            color_pair(theme_color("comment")),
        )
        add_text(
            self.screen,
            height - 1,
            0,
            HELP_TEXT.ljust(width),
            width,
            curses.A_BOLD | color_pair(theme_color("purple")),
        )
        if self.search_active and self.search_cursor is not None:
            try:
                self.screen.move(*self.search_cursor)
            except curses.error:
                pass
        self.screen.refresh()

    def draw_header(self, width: int) -> None:
        """Draw the app header."""
        title = f" review  {display_range_label(self.ref_range, self.branch)} "
        add_text(self.screen, 0, 0, title.ljust(width), width, curses.A_BOLD | color_pair(theme_color("purple")))

    def draw_files(self, y: int, x: int, height: int, width: int) -> None:
        """Draw the changed-file checklist pane."""
        files = self.visible_files()
        ignored_count = len([changed_file for changed_file in self.files if changed_file.path in self.ignored])
        search_label = self.search_query or ""
        search_prefix = "search>" if self.search_active else "search"
        title_prefix = f"Files  filter:{self.file_filter}  {search_prefix} /"
        title = f"{title_prefix}{search_label}/  {len(files)}/{len(self.files)}  ignored:{ignored_count}"
        if self.search_error:
            title = f"{title_prefix}{search_label}/  regex error: {self.search_error}"
        add_text(self.screen, y, x, title.ljust(width), width, curses.A_BOLD | color_pair(theme_color("cyan")))
        if self.search_active:
            cursor_x = min(width - 1, len(title_prefix) + len(search_label))
            self.search_cursor = (y, x + cursor_x)
        visible_height = max(1, height - 1)
        if self.selected < self.file_scroll:
            self.file_scroll = self.selected
        if self.selected >= self.file_scroll + visible_height:
            self.file_scroll = self.selected - visible_height + 1

        for row in range(visible_height):
            index = self.file_scroll + row
            line_y = y + row + 1
            if index >= len(files):
                add_text(self.screen, line_y, x, " ".ljust(width), width)
                continue
            changed_file = files[index]
            checked = "x" if changed_file.path in self.reviewed else " "
            ignored = "i" if changed_file.path in self.ignored else " "
            count = len(self.comments_by_path.get(changed_file.path, []))
            suffix = f" ({count})" if count else ""
            label = f"[{checked}][{ignored}] {changed_file.path}{suffix}"
            color = (
                theme_color("comment")
                if ignored == "i"
                else theme_color("green")
                if checked == "x"
                else theme_color("foreground")
            )
            mode = color_pair(color)
            if index == self.selected:
                mode = curses.A_BOLD | curses.A_UNDERLINE | color_pair(theme_color("purple"))
            add_text(self.screen, line_y, x, label.ljust(width), width, mode)

    def draw_diff(self, y: int, x: int, height: int, width: int) -> None:
        """Draw the side-by-side diff pane."""
        current = self.selected_file()
        title = f"Diff: {current.path}" if current else "Diff"
        add_text(self.screen, y, x, title.ljust(width), width, curses.A_BOLD | color_pair(theme_color("cyan")))
        if current is None:
            add_text(self.screen, y + 1, x, "No changed files.", width)
            return

        cache_key = (current.path, width)
        if cache_key not in self.diff_cache:
            self.diff_cache[cache_key] = side_by_side_diff_lines(self.ref_range, current.path, width, self.branch)
        lines = self.diff_cache[cache_key]
        max_scroll = max(0, len(lines) - height + 1)
        self.diff_scroll = max(0, min(self.diff_scroll, max_scroll))

        for row in range(max(1, height - 1)):
            index = self.diff_scroll + row
            line = lines[index] if index < len(lines) else ""
            segments = parse_ansi_line(line)
            add_styled_text(self.screen, y + row + 1, x, segments, width)
            padding = width - visible_length(segments)
            if padding > 0:
                add_text(self.screen, y + row + 1, x + width - padding, " " * padding, padding)

    def draw_comments(self, y: int, x: int, height: int, width: int) -> None:
        """Draw comments for the selected file."""
        current = self.selected_file()
        add_text(self.screen, y, x, "Comments".ljust(width), width, curses.A_BOLD | color_pair(theme_color("cyan")))
        if current is None:
            return
        local_comments = self.comments_by_path.get(current.path, [])
        remote_threads = self.remote_threads_by_path.get(current.path, [])
        if not local_comments and not remote_threads:
            add_text(self.screen, y + 1, x, "No #review comments in this file.", width)
            return

        local_count = len(local_comments)
        reply_count = sum(max(0, len(thread.notes) - 1) for thread in remote_threads)
        suggestion_count = sum(
            len(note_suggestions(note))
            for thread in remote_threads
            if not thread.resolved
            for note in thread.notes
        )
        draft_count = len([draft for draft in reply_drafts(self.state) if draft.path == current.path])
        summary = (
            f"{local_count} local / {len(remote_threads)} threads / {reply_count} replies / "
            f"{suggestion_count} suggestions / {draft_count} drafts"
        )
        add_text(self.screen, y + 1, x, summary.ljust(width), width, color_pair(theme_color("foreground")))
        if height > 2 and local_comments:
            local_lines = ", ".join(str(comment.target_line) for comment in local_comments)
            add_text(self.screen, y + 2, x, f"local lines: {local_lines}".ljust(width), width, color_pair(theme_color("yellow")))
        if height > 3 and remote_threads:
            remote_lines = ", ".join(str(thread.line) for thread in remote_threads)
            add_text(self.screen, y + 3, x, f"remote lines: {remote_lines}".ljust(width), width, color_pair(theme_color("green")))


def interactive(ref_range: ReviewRange, ignore_patterns: Sequence[str] = ()) -> None:
    """Run the full-screen terminal UI."""
    curses.wrapper(lambda screen: ReviewApp(screen, ref_range, ignore_patterns).run())


def parser() -> argparse.ArgumentParser:
    """Build the CLI argument parser."""
    argument_parser = argparse.ArgumentParser(description="Review branch changes from the terminal.")
    argument_parser.add_argument("--base", help="base branch/ref to compare against")
    argument_parser.add_argument("--from", dest="from_ref", help="left ref for an explicit two-ref comparison")
    argument_parser.add_argument("--to", dest="to_ref", help="right ref for an explicit two-ref comparison")
    argument_parser.add_argument("--fast", action="store_true", help="open the lightweight fzf/delta review picker")
    argument_parser.add_argument(
        "--ignore",
        action="append",
        default=[],
        metavar="PATTERN",
        help="hide a changed file path, directory, or glob from review commands; repeatable",
    )
    subparsers = argument_parser.add_subparsers(dest="command")

    subparsers.add_parser("status", help="show changed files and reviewed checkboxes")
    subparsers.add_parser("checked", help="show files marked reviewed")
    subparsers.add_parser("comments", help="show local #review comments")
    subparsers.add_parser("ui", help="open the interactive CLI app")
    subparsers.add_parser("open", help="open the current merge/pull request in the browser")

    diff_parser = subparsers.add_parser("diff", help="show a side-by-side diff for a changed file")
    diff_parser.add_argument("file", help="changed file path or list number")

    edit_parser = subparsers.add_parser("edit", help="open a changed file to add #review comments")
    edit_parser.add_argument("file", help="changed file path or list number")

    toggle_parser = subparsers.add_parser("toggle", help="toggle reviewed checkbox for a changed file")
    toggle_parser.add_argument("file", help="changed file path or list number")

    publish_parser = subparsers.add_parser("publish", help="publish #review comments to a merge/pull request")
    publish_parser.add_argument("--provider", choices=["auto", "gitlab", "github"], default="auto")
    publish_parser.add_argument("--dry-run", action="store_true")
    publish_parser.add_argument("--force", action="store_true", help="publish even if local state says comments were published")

    return argument_parser


def normalize_args(arguments: Sequence[str]) -> list[str]:
    """Move global options before the subcommand for argparse."""
    normalized: list[str] = []
    remaining: list[str] = []
    index = 0
    while index < len(arguments):
        argument = arguments[index]
        if argument in {"--base", "--from", "--to", "--ignore"} and index + 1 < len(arguments):
            normalized.extend([argument, arguments[index + 1]])
            index += 2
        elif argument.startswith(("--base=", "--from=", "--to=", "--ignore=")):
            normalized.append(argument)
            index += 1
        elif argument == "--fast":
            normalized.append(argument)
            index += 1
        else:
            remaining.append(argument)
            index += 1
    return [*normalized, *remaining]


def review_range_from_args(args: argparse.Namespace) -> ReviewRange:
    """Return the selected review range from parsed CLI arguments."""
    has_from = bool(args.from_ref)
    has_to = bool(args.to_ref)
    if has_from != has_to:
        die("use --from and --to together")
    if args.base and has_from:
        die("use either --base or --from/--to")
    if has_from and has_to:
        return review_range(args.from_ref, args.to_ref, explicit=True)
    return review_range(args.base or default_base())


def main() -> None:
    """Run the review CLI."""
    args = parser().parse_args(normalize_args(sys.argv[1:]))
    ref_range = review_range_from_args(args)
    ignore_patterns = tuple(args.ignore or [])
    verify_range(ref_range)

    if args.fast:
        fast_review(ref_range, ignore_patterns)
    elif args.command in {None, "ui"}:
        interactive(ref_range, ignore_patterns)
    elif args.command == "status":
        print_status(ref_range, ignore_patterns)
    elif args.command == "checked":
        print_checked(ref_range, ignore_patterns)
    elif args.command == "comments":
        list_comments(ref_range, ignore_patterns)
    elif args.command == "diff":
        show_diff(ref_range, resolve_path(changed_files(ref_range, ignore_patterns), args.file))
    elif args.command == "edit":
        open_file(resolve_path(changed_files(ref_range, ignore_patterns), args.file))
    elif args.command == "toggle":
        toggle_reviewed(ref_range, resolve_path(changed_files(ref_range, ignore_patterns), args.file))
    elif args.command == "open":
        if not reviewable_files(ref_range, ignore_patterns):
            die(f"no files changed in {range_label(ref_range)}; no review to open")
        provider = detect_provider()
        if provider is None:
            die("could not detect provider from git remote")
        if not open_review_request(provider):
            die(f"could not open {provider} review")
    elif args.command == "publish":
        provider = detect_provider() if args.provider == "auto" else args.provider
        if provider is None:
            die("could not detect provider from git remote; pass --provider gitlab or --provider github")
        published = publish_comments(
            ref_range,
            provider,
            args.dry_run,
            force=args.force,
            ignore_patterns=ignore_patterns,
        )
        removed = remove_published_markers(published) if published else 0
        if removed:
            print(f"Removed {removed} local review marker{'s' if removed != 1 else ''}.")


if __name__ == "__main__":
    main()
