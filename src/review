    print(f"posted gitlab reply to thread {thread.thread_id}")


def post_github_reply(thread: RemoteThread, note: RemoteNote, body: str) -> None:
    """Post a reply to an existing GitHub PR review comment."""
    if not thread.replyable or not note.note_id:
        die("this GitHub comment is not replyable from the pull request review API")
    repo = github_repo()
    pr = github_pr()
    number = str(pr["number"])
    command = [
        "gh",
        "api",
        f"repos/{repo}/pulls/{number}/comments/{note.note_id}/replies",
        "--method",
        "POST",
        "--header",
        "Content-Type: application/json",
        "--input",
        "-",
    ]
    success, output = try_run(command, input_text=json.dumps({"body": body}))
    if not success:
        die(f"could not reply to GitHub comment {note.note_id}\n{output}")
    print(f"posted github reply to comment {note.note_id}")


def post_remote_reply(provider: str, thread: RemoteThread, note: RemoteNote, body: str) -> None:
    """Post a reply to a remote review thread or comment."""
    if provider == "gitlab":
        post_gitlab_reply(thread, body)
    elif provider == "github":
        post_github_reply(thread, note, body)
    else:
        die(f"unsupported provider: {provider}")


def publish_github_comment(
    comment: ReviewComment,
    repo: str,
    number: str,
    commit_id: str,
    *,
    positioned: bool,
) -> None:
    """Publish one comment as a GitHub PR review comment."""
    output = ""
    if positioned:
        payload = {
            "body": comment.body,
            "commit_id": commit_id,
            "path": comment.path,
            "line": comment.target_line,
            "side": "RIGHT",
        }
        command = [
            "gh",
            "api",
            f"repos/{repo}/pulls/{number}/comments",
            "--method",
            "POST",
            "--header",
            "Content-Type: application/json",
            "--input",
            "-",
        ]
        success, output = try_run(command, input_text=json.dumps(payload))
        if success:
            print(f"posted github {comment.path}:{comment.target_line}")
            return

    fallback_command = [
        "gh",
        "api",
        f"repos/{repo}/issues/{number}/comments",
        "--method",
        "POST",
        "--header",
        "Content-Type: application/json",
        "--input",
        "-",
    ]
    fallback_success, fallback_output = try_run(
        fallback_command,
        input_text=json.dumps({"body": fallback_body(comment)}),
    )
    if not fallback_success:
        die(f"could not publish GitHub comment at {comment.path}:{comment.target_line}\n{output}\n{fallback_output}")
    print(f"posted github fallback {comment.path}:{comment.target_line}")


def publish_comments(base: str, provider: str, dry_run: bool, *, force: bool = False) -> list[ReviewComment]:
    """Publish local review comments to a provider."""
    files = changed_files(base)
    all_comments = collect_comments(files)
    if not all_comments:
        print("No #review comments found.")
        return []

    state = load_state(base)
    published = published_comment_ids(state)
    comments = all_comments if force else [comment for comment in all_comments if comment_id(comment) not in published]
    skipped = len(all_comments) - len(comments)
    if skipped:
        print(f"Skipping {skipped} already published comment{'s' if skipped != 1 else ''}.")
    if not comments:
        print("No unpublished #review comments found.")
        return []

    lines_by_path = changed_lines_by_path(base, {comment.path for comment in comments})
    bad_comments = [comment for comment in comments if comment.target_line not in lines_by_path[comment.path]]
    if bad_comments:
        print("These comments do not point at changed lines; they will use fallback comments:")
        for comment in bad_comments:
            print(f"- {comment.path}:{comment.target_line}: {comment.body}")

    if dry_run:
        for comment in comments:
            print(f"{provider} {comment.path}:{comment.target_line}: {comment.body}")
        return []

    published_comments: list[ReviewComment] = []
    if provider == "gitlab":
        project = gitlab_project_path()
        iid = gitlab_mr_iid()
        version = gitlab_latest_version(project, iid)
        for comment in comments:
            publish_gitlab_comment(
                comment,
                project,
                iid,
                version,
                positioned=comment.target_line in lines_by_path[comment.path],
            )
            mark_comment_published(base, state, comment)
            published_comments.append(comment)
    elif provider == "github":
        repo = github_repo()
        pr = github_pr()
        number = str(pr["number"])
        commit_id = str(pr["headRefOid"])
        for comment in comments:
            publish_github_comment(
                comment,
                repo,
                number,
                commit_id,
                positioned=comment.target_line in lines_by_path[comment.path],
            )
            mark_comment_published(base, state, comment)
            published_comments.append(comment)
    else:
        die(f"unsupported provider: {provider}")
    return published_comments


def add_text(window: curses.window, y: int, x: int, text: str, width: int, mode: int = 0) -> None:
    """Draw clipped text if it fits inside a curses window."""
    if width <= 0:
        return
    try:
        window.addnstr(y, x, text, width, mode)
    except curses.error:
        pass


def hex_to_rgb(value: str) -> tuple[int, int, int]:
    """Convert a hex color string to an RGB tuple."""
    normalized = value.strip().removeprefix("#")
    if len(normalized) != 6:
        raise ValueError(value)
    return (int(normalized[0:2], 16), int(normalized[2:4], 16), int(normalized[4:6], 16))


def load_theme(theme_name: str) -> dict[str, tuple[int, int, int]]:
    """Load a built-in or user theme."""
    if theme_name in THEMES:
        return THEMES[theme_name]

    theme_path = Path.home() / ".config" / "review" / "themes" / f"{theme_name}.json"
    if not theme_path.exists():
        return THEMES["dracula"]

    with theme_path.open(encoding="utf-8") as handle:
        raw_theme = json.load(handle)

    theme = dict(THEMES["dracula"])
    for name, value in raw_theme.items():
        if isinstance(value, str):
            try:
                theme[name] = hex_to_rgb(value)
            except ValueError:
                continue
    return theme


def init_theme(theme_name: str) -> None:
    """Initialize transparent-background color pairs for the TUI."""
    global ACTIVE_THEME

    ACTIVE_THEME = load_theme(theme_name)
    COLOR_PAIR_CACHE.clear()
    THEME_COLOR_NUMBERS.clear()
    if not curses.has_colors():
        return

    curses.start_color()
    try:
        curses.use_default_colors()
    except curses.error:
        pass

    can_define_colors = curses.can_change_color() and curses.COLORS > 32
    start_color = 16
    for offset, (name, rgb) in enumerate(ACTIVE_THEME.items()):
        color_number = start_color + offset
        if can_define_colors and color_number < curses.COLORS:
            try:
                curses.init_color(color_number, *(round(channel / 255 * 1000) for channel in rgb))
                THEME_COLOR_NUMBERS[name] = color_number
            except curses.error:
                THEME_COLOR_NUMBERS[name] = DRACULA_ANSI_COLORS.get(name, 7)
        else:
            THEME_COLOR_NUMBERS[name] = DRACULA_ANSI_COLORS.get(name, 7)


def theme_color(name: str) -> int:
    """Return a curses color number from the active theme."""
    return THEME_COLOR_NUMBERS.get(name, -1)


def color_pair(color: int, reverse: bool = False) -> int:
    """Return a curses color pair using the terminal default background."""
    if color < 0 or not curses.has_colors():
        return curses.A_REVERSE if reverse else 0

    key = (color, reverse)
    if key not in COLOR_PAIR_CACHE:
        pair_number = len(COLOR_PAIR_CACHE) + 1
        if pair_number >= curses.COLOR_PAIRS:
            return curses.A_REVERSE if reverse else 0
        background = color if reverse else -1
        foreground = -1 if reverse else color
        try:
            curses.init_pair(pair_number, foreground, background)
        except curses.error:
            return curses.A_REVERSE if reverse else 0
        COLOR_PAIR_CACHE[key] = pair_number
    return curses.color_pair(COLOR_PAIR_CACHE[key])


def nearest_theme_color(red: int, green: int, blue: int) -> int:
    """Return the closest active theme color for an RGB value."""
    if not THEME_COLOR_NUMBERS:
        return -1

    closest_name = min(
        THEME_COLOR_NUMBERS,
        key=lambda name: sum((ACTIVE_THEME[name][index] - value) ** 2 for index, value in enumerate((red, green, blue))),
    )
    return THEME_COLOR_NUMBERS[closest_name]


def ansi_256_to_color(value: int) -> int:
    """Map a 256-color ANSI value to a curses color number."""
    if 232 <= value <= 255:
        level = 8 + (value - 232) * 10
        return nearest_theme_color(level, level, level)
    if 16 <= value <= 255:
        red_index = (value - 16) // 36
        green_index = ((value - 16) % 36) // 6
        blue_index = (value - 16) % 6
        steps = [0, 95, 135, 175, 215, 255]
        return nearest_theme_color(steps[red_index], steps[green_index], steps[blue_index])
    return ansi_basic_color(value + 30 if value < 8 else value + 82)


def ansi_basic_color(code: int) -> int:
    """Map a basic ANSI color code to the active theme."""
    color_names = {
        30: "foreground",
        31: "red",
        32: "green",
        33: "yellow",
        34: "purple",
        35: "pink",
        36: "cyan",
        37: "foreground",
        90: "comment",
        91: "red",
        92: "green",
        93: "yellow",
        94: "purple",
        95: "pink",
        96: "cyan",
        97: "foreground",
    }
    return theme_color(color_names.get(code, "foreground"))


def parse_ansi_line(line: str) -> list[StyledSegment]:
    """Parse ANSI SGR color sequences into styled text segments."""
    segments: list[StyledSegment] = []
    position = 0
    color = theme_color("foreground")
    bold = False
    reverse = False

    for match in ANSI_RE.finditer(line):
        if match.start() > position:
            segments.append(StyledSegment(line[position : match.start()], color, bold, reverse))

        sequence = match.group()
        if sequence.endswith("m"):
            codes = [int(code or "0") for code in sequence[2:-1].split(";")]
            index = 0
            while index < len(codes):
                code = codes[index]
                if code == 0:
                    color = theme_color("foreground")
                    bold = False
                    reverse = False
                elif code == 1:
                    bold = True
                elif code == 22:
                    bold = False
                elif code == 7:
                    reverse = True
                elif code == 27:
                    reverse = False
                elif code == 39:
                    color = theme_color("foreground")
                elif code in BASIC_ANSI_COLOR_CODES:
                    color = ansi_basic_color(code)
                elif code == 38 and index + 2 < len(codes) and codes[index + 1] == 5:
                    color = ansi_256_to_color(codes[index + 2])
                    index += 2
                elif code == 38 and index + 4 < len(codes) and codes[index + 1] == 2:
                    color = nearest_theme_color(codes[index + 2], codes[index + 3], codes[index + 4])
                    index += 4
                index += 1
        position = match.end()

    if position < len(line):
        segments.append(StyledSegment(line[position:], color, bold, reverse))
    return segments or [StyledSegment("")]


def visible_length(segments: Sequence[StyledSegment]) -> int:
    """Return visible width for parsed segments."""
    return sum(len(segment.text) for segment in segments)


def add_styled_text(
    window: curses.window,
    y: int,
    x: int,
    segments: Sequence[StyledSegment],
    width: int,
) -> None:
    """Draw clipped styled text segments."""
    used = 0
    for segment in segments:
        if used >= width:
            return
        text = segment.text[: width - used]
        mode = color_pair(segment.color, segment.reverse)
        if segment.bold:
            mode |= curses.A_BOLD
        add_text(window, y, x + used, text, width - used, mode)
        used += len(text)


def wrap_text(text: str, width: int) -> list[str]:
    """Wrap text to a fixed terminal width."""
    if width <= 1:
        return [text]
    lines: list[str] = []
    for raw_line in text.splitlines() or [""]:
        line = raw_line
        while len(line) > width:
            lines.append(line[:width])
            line = line[width:]
        lines.append(line)
    return lines


def plain_popup_lines(messages: Sequence[str], width: int) -> list[tuple[str, int]]:
    """Return wrapped popup lines using the normal foreground color."""
    lines: list[tuple[str, int]] = []
    mode = color_pair(theme_color("foreground"))
    for message in messages:
        for wrapped in wrap_text(message, width):
            lines.append((wrapped, mode))
    return lines or [("", mode)]


def short_timestamp(value: str) -> str:
    """Return a compact timestamp for comment metadata."""
    return value.replace("T", " ")[:16] if value else ""


def append_wrapped_popup_text(
    lines: list[tuple[str, int]],
    text: str,
    width: int,
    indent: int,
    mode: int,
) -> None:
    """Append wrapped popup text with a fixed left indent."""
    prefix = " " * max(0, min(indent, width - 1))
    wrap_width = max(1, width - len(prefix))
    for wrapped in wrap_text(text, wrap_width):
        lines.append((f"{prefix}{wrapped}", mode))


def prompt(window: curses.window, label: str) -> str | None:
    """Read a short prompt from the bottom status line."""
    curses.noecho()
    window.keypad(True)
    curses.curs_set(1)
    height, width = window.getmaxyx()
    value = ""
    try:
        while True:
            window.move(height - 1, 0)
            window.clrtoeol()
            text = f"{label}{value}"
            add_text(window, height - 1, 0, text, width)
            window.move(height - 1, min(width - 1, len(text)))
            window.refresh()
            key = window.getch()
            if key == 27:
                return None
            if key in {curses.KEY_ENTER, 10, 13}:
                return value.strip()
            if key in {curses.KEY_BACKSPACE, 8, 127}:
                value = value[:-1]
            elif key == 21:
                value = ""
            elif 32 <= key <= 126:
                value += chr(key)
    finally:
        curses.noecho()
        curses.curs_set(0)


def confirm_publish(window: curses.window, provider: str) -> bool | None:
    """Return whether to publish for real, or None when cancelled."""
    height, width = window.getmaxyx()
    window.move(height - 1, 0)
    window.clrtoeol()
    add_text(window, height - 1, 0, f"{provider}: y publish, any other key dry-run, Esc cancel", width)
    window.refresh()
    key = window.getch()
    if key == 27:
        return None
    return key in {ord("y"), ord("Y")}


class ReviewApp:
    """Full-screen review terminal UI."""

    def __init__(self, screen: curses.window, base: str) -> None:
        """Create the TUI app."""
        self.screen = screen
        self.base = base
        self.branch = branch_name()
        self.files: list[ChangedFile] = []
        self.state: dict[str, Any] = {}
        self.reviewed: set[str] = set()
        self.comments_by_path: dict[str, list[ReviewComment]] = {}
        self.remote_threads_by_path: dict[str, list[RemoteThread]] = {}
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0
        self.message = "Ready."
        self.diff_cache: dict[tuple[str, int], list[str]] = {}
        self.search_query = ""
        self.search_error = ""
        self.search_active = False
        self.search_cursor: tuple[int, int] | None = None
        self.file_filter = "all"

    def selected_file(self) -> ChangedFile | None:
        """Return the selected changed file."""
        files = self.visible_files()
        if not files:
            return None
        self.selected = max(0, min(self.selected, len(files) - 1))
        return files[self.selected]

    def visible_files(self) -> list[ChangedFile]:
        """Return changed files matching the active regex search."""
        files = self.files
        if self.file_filter == "checked":
            files = [changed_file for changed_file in files if changed_file.path in self.reviewed]
        elif self.file_filter == "unchecked":
            files = [changed_file for changed_file in files if changed_file.path not in self.reviewed]

        if not self.search_query:
            self.search_error = ""
            return files
        try:
            pattern = re.compile(self.search_query, re.IGNORECASE)
        except re.error as error:
            self.search_error = str(error)
            return []
        self.search_error = ""
        return [changed_file for changed_file in files if pattern.search(changed_file.path)]

    def reload(self) -> None:
        """Reload files, state, and clear stale diff cache."""
        self.files = changed_files(self.base)
        self.state = load_state(self.base)
        self.reviewed = reviewed_paths(self.state)
        self.comments_by_path = comments_by_path(self.files)
        self.selected = max(0, min(self.selected, max(0, len(self.visible_files()) - 1)))
        self.diff_cache.clear()

    def run(self) -> None:
        """Run the curses event loop."""
        init_theme(os.environ.get("review_THEME", "dracula").lower())
        curses.curs_set(0)
        self.screen.keypad(True)
        self.reload()
        self.load_startup_remote_comments()
        while True:
            curses.curs_set(1 if self.search_active else 0)
            self.draw()
            key = self.screen.getch()
            if not self.search_active and key in {ord("q"), 27}:
                return
            self.handle_key(key)

    def handle_key(self, key: int) -> None:
        """Handle one key press."""
        if self.search_active:
            self.handle_search_key(key)
        elif key in {ord("j"), curses.KEY_DOWN}:
            self.move_selection(1)
        elif key in {ord("k"), curses.KEY_UP}:
            self.move_selection(-1)
        elif key in {ord("J"), curses.KEY_NPAGE}:
            self.diff_scroll += 10
        elif key in {ord("K"), curses.KEY_PPAGE}:
            self.diff_scroll = max(0, self.diff_scroll - 10)
        elif key == ord(" "):
            self.toggle_current()
        elif key in {ord("c"), ord("e"), curses.KEY_ENTER, 10, 13}:
            self.edit_current()
        elif key == ord("m"):
            self.show_comments_popup()
        elif key == ord("d"):
            self.open_current_diff()
        elif key == ord("/"):
            self.search_active = True
            self.message = "Search mode. Enter accepts, Esc leaves, Ctrl-U clears."
        elif key == ord("f"):
            self.cycle_file_filter()
        elif key == ord("n"):
            self.jump_unreviewed(1)
        elif key == ord("N"):
            self.jump_unreviewed(-1)
        elif key == 21:
            self.clear_search()
        elif key == ord("o"):
            self.open_review_request()
        elif key == ord("R"):
            self.refresh_remote_comments()
        elif key == ord("p"):
            self.publish_dry_run()
        elif key == ord("r"):
            self.reload()
            self.message = "Refreshed."

    def handle_search_key(self, key: int) -> None:
        """Handle one key press while editing the regex search."""
        if key in {27, curses.KEY_ENTER, 10, 13}:
            self.search_active = False
            self.message = "Search applied." if self.search_query else "Search cleared."
        elif key == 21:
            self.clear_search()
        elif key == 23:
            self.delete_search_word()
        elif key in {curses.KEY_BACKSPACE, 8, 127}:
            self.delete_search_char()
        elif 32 <= key <= 126:
            self.append_search_char(chr(key))

    def move_selection(self, step: int) -> None:
        """Move the selected file."""
        files = self.visible_files()
        if not files:
            return
        self.selected = max(0, min(len(files) - 1, self.selected + step))
        self.diff_scroll = 0

    def append_search_char(self, character: str) -> None:
        """Append one typed character to the regex search."""
        self.search_query += character
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0

    def delete_search_char(self) -> None:
        """Delete one character from the regex search."""
        self.search_query = self.search_query[:-1]
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0

    def delete_search_word(self) -> None:
        """Delete the last regex search word."""
        self.search_query = self.search_query.rstrip()
        self.search_query = self.search_query[: self.search_query.rfind(" ") + 1].rstrip()
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0

    def clear_search(self) -> None:
        """Clear the active regex search."""
        self.search_query = ""
        self.search_error = ""
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0
        self.message = "Search cleared."

    def cycle_file_filter(self) -> None:
        """Cycle file list filter between all, unchecked, and checked files."""
        index = FILE_FILTERS.index(self.file_filter)
        self.file_filter = FILE_FILTERS[(index + 1) % len(FILE_FILTERS)]
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0
        self.message = f"Showing {self.file_filter} files."

    def jump_unreviewed(self, step: int) -> None:
        """Jump to an unchecked file without changing filters."""
        files = self.visible_files()
        if not files:
            return

        total = len(files)
        for offset in range(1, total + 1):
            index = (self.selected + (offset * step)) % total
            if files[index].path not in self.reviewed:
                self.selected = index
                self.diff_scroll = 0
                direction = "Next" if step > 0 else "Previous"
                self.message = f"{direction}: {files[index].path}"
                return
        self.message = "No unreviewed files in current view."

    def toggle_current(self) -> None:
        """Toggle reviewed state for the selected file."""
        current = self.selected_file()
        if current is None:
            return
        toggle_reviewed(self.base, current.path)
        self.state = load_state(self.base)
        self.reviewed = reviewed_paths(self.state)
        self.message = f"Toggled {current.path}."

    def edit_current(self) -> None:
        """Open the selected file in an editor."""
        current = self.selected_file()
        if current is None:
            return
        self.suspend(lambda: open_file(current.path))
        self.reload()
        self.message = f"Edited {current.path}."

    def open_current_diff(self) -> None:
        """Open the selected file diff in the pager."""
        current = self.selected_file()
        if current is None:
            return
        self.suspend(lambda: show_diff(self.base, current.path, self.branch))
        self.message = f"Viewed diff for {current.path}."

    def publish_dry_run(self) -> None:
        """Publish or dry-run comments and show the result in a popup."""
        provider = detect_provider()
        if provider is None:
            self.message = "Ready."
            self.show_text_popup("publish", ["Could not detect GitLab/GitHub remote."])
            return
        publish_for_real = confirm_publish(self.screen, provider)
        if publish_for_real is None:
            self.message = "Ready."
            self.show_text_popup("publish", ["Publish cancelled."])
            return
        dry_run = not publish_for_real
        self.message = f"Publishing to {provider}..."
        self.draw()
        output = StringIO()
        published: list[ReviewComment] = []
        removed = 0
        failed = False
        with redirect_stdout(output), redirect_stderr(output):
            try:
                published = publish_comments(self.base, provider, dry_run=dry_run)
                removed = remove_published_markers(published) if published else 0
                if published:
                    self.reload()
                    self.load_remote_comments(provider)
            except SystemExit:
                failed = True
            except Exception as error:
                failed = True
                print(f"review: {error}", file=sys.stderr)

        mode = "dry-run" if dry_run else "publish"
        messages = output.getvalue().splitlines()
        if removed:
            messages.append(f"Removed {removed} local review marker{'s' if removed != 1 else ''}.")
        if not messages:
            messages.append(f"{provider} {mode} finished.")
        title = "publish failed" if failed else f"{provider} {mode}"
        self.message = "Ready."
        self.show_text_popup(title, messages)

    def open_review_request(self) -> None:
        """Open the detected merge or pull request in the browser."""
        provider = detect_provider()
        if provider is None:
            self.message = "Open cancelled: could not detect GitLab/GitHub remote."
            return
        self.message = f"Opening {provider} review..."
        self.draw()
        opened = open_review_request(provider)
        self.message = f"Opened {provider} review." if opened else f"Could not open {provider} review."

    def load_remote_comments(self, provider: str) -> None:
        """Load remote comments into the TUI cache."""
        self.remote_threads_by_path = remote_threads_by_path(fetch_remote_threads(provider))

    def try_load_remote_comments(self, provider: str) -> tuple[bool, str]:
        """Load remote comments and return success plus a status message."""
        output = StringIO()
        with redirect_stdout(output), redirect_stderr(output):
            try:
                self.load_remote_comments(provider)
            except SystemExit:
                detail = output.getvalue().strip().splitlines()
                message = detail[-1] if detail else f"Could not load {provider} comments."
                return False, message
            except Exception as error:
                return False, f"review: {error}"

        total = sum(len(threads) for threads in self.remote_threads_by_path.values())
        return True, f"Loaded {total} remote thread{'s' if total != 1 else ''}."

    def load_startup_remote_comments(self) -> None:
        """Load remote comments automatically when the TUI starts."""
        provider = detect_provider()
        if provider is None:
            return
        self.message = f"Loading {provider} comments..."
        self.draw()
        success, message = self.try_load_remote_comments(provider)
        self.message = message if success else f"Remote comments not loaded: {message}"

    def refresh_remote_comments(self) -> None:
        """Refresh remote MR/PR comments."""
        provider = detect_provider()
        if provider is None:
            self.message = "Remote refresh cancelled: could not detect GitLab/GitHub remote."
            return
        self.message = f"Loading {provider} comments..."
        self.draw()
        success, message = self.try_load_remote_comments(provider)
        self.message = message if success else f"Remote refresh failed: {message}"

    def comment_popup_lines(
        self,
        width: int,
        selected_target: int,
    ) -> tuple[list[tuple[str, int]], list[int], list[ReplyTarget]]:
        """Return comment popup lines, selected note positions, and reply targets."""
        current = self.selected_file()
        if current is None:
            return [("No file selected.", color_pair(theme_color("comment")))], [], []

        lines: list[tuple[str, int]] = []
        target_positions: list[int] = []
        targets: list[ReplyTarget] = []
        target_index = 0
        local_comments = self.comments_by_path.get(current.path, [])
        remote_threads = self.remote_threads_by_path.get(current.path, [])
        for index, comment in enumerate(local_comments, 1):
            header = f"local draft {index}  line {comment.target_line}"
            lines.append((header, curses.A_BOLD | color_pair(theme_color("yellow"))))
            append_wrapped_popup_text(lines, comment.body, width, 2, color_pair(theme_color("foreground")))
            lines.append(("", 0))
        for index, thread in enumerate(remote_threads, 1):
            replies = max(0, len(thread.notes) - 1)
            state = "resolved" if thread.resolved else "open"
            header = f"thread {index}  line {thread.line}  {state}  {replies} repl{'y' if replies == 1 else 'ies'}"
            lines.append((header, curses.A_BOLD | color_pair(theme_color("purple"))))
            for note_index, note in enumerate(thread.notes):
                is_reply = note_index > 0 or note.is_reply
                timestamp = short_timestamp(note.created_at)
                suffix = f"  {timestamp}" if timestamp else ""
                marker = ">" if target_index == selected_target else " "
                prefix = f"{marker} |- reply" if is_reply else f"{marker} comment"
                color = theme_color("green") if is_reply else theme_color("cyan")
                mode = curses.A_BOLD | color_pair(color)
                if target_index == selected_target:
                    mode |= curses.A_REVERSE
                target_positions.append(len(lines))
                targets.append(ReplyTarget(thread=thread, note=note))
                lines.append((f"{prefix} @{note.author}{suffix}", mode))
                append_wrapped_popup_text(lines, note.body, width, 6 if is_reply else 4, color_pair(theme_color("foreground")))
                target_index += 1
            lines.append(("", 0))
        return lines or [("No comments for this file.", color_pair(theme_color("comment")))], target_positions, targets

    def reply_to_remote_target(self, target: ReplyTarget) -> str:
        """Prompt for and post a reply to the selected remote note."""
        if not target.thread.replyable:
            return "This comment is not replyable from the review API."
        body = prompt(self.screen, "reply> ")
        if body is None:
            return "Reply cancelled."
        if not body:
            return "Reply cancelled: empty body."

        provider = detect_provider()
        if provider is None:
            return "Reply failed: could not detect GitLab/GitHub remote."

        output = StringIO()
        with redirect_stdout(output), redirect_stderr(output):
            try:
                post_remote_reply(provider, target.thread, target.note, body)
            except SystemExit:
                detail = output.getvalue().strip().splitlines()
                return detail[-1] if detail else "Reply failed."
            except Exception as error:
                return f"Reply failed: {error}"

        success, message = self.try_load_remote_comments(provider)
        if not success:
            return f"Reply posted, but refresh failed: {message}"
        return f"Reply posted. {message}"

    def show_comments_popup(self) -> None:
        """Show scrollable comments for the selected file."""
        self.draw()
        height, width = self.screen.getmaxyx()
        popup_height = max(8, min(height - 4, int(height * 0.75)))
        popup_width = max(50, min(width - 4, int(width * 0.85)))
        top = max(1, (height - popup_height) // 2)
        left = max(1, (width - popup_width) // 2)
        content_width = popup_width - 4
        content_height = popup_height - 4
        selected_target = 0
        scroll = 0
        status = ""

        while True:
            lines, target_positions, targets = self.comment_popup_lines(content_width, selected_target)
            if targets:
                if selected_target >= len(targets):
                    selected_target = len(targets) - 1
                    lines, target_positions, targets = self.comment_popup_lines(content_width, selected_target)
                selected_target = max(0, selected_target)
                selected_line = target_positions[selected_target]
                if selected_line < scroll:
                    scroll = selected_line
                elif selected_line >= scroll + content_height:
                    scroll = selected_line - content_height + 1
            max_scroll = max(0, len(lines) - content_height)
            scroll = max(0, min(scroll, max_scroll))
            popup = curses.newwin(popup_height, popup_width, top, left)
            popup.keypad(True)
            popup.erase()
            popup.box()
            add_text(popup, 0, 2, " comments ", popup_width - 4, curses.A_BOLD | color_pair(theme_color("purple")))
            footer = status or "Up/Down or j/k select  J/K page  r reply  q/Esc close"
            add_text(
                popup,
                popup_height - 2,
                2,
                footer.ljust(popup_width - 4),
                popup_width - 4,
                color_pair(theme_color("comment")),
            )
            for row in range(content_height):
                index = scroll + row
                if index >= len(lines):
                    break
                text, mode = lines[index]
                add_text(popup, row + 2, 2, text.ljust(content_width), content_width, mode)
            popup.refresh()
            key = popup.getch()
            if key in {ord("q"), 27, curses.KEY_ENTER, 10, 13}:
                self.draw()
                return
            if key in {ord("j"), curses.KEY_DOWN}:
                selected_target = selected_target + 1 if targets else selected_target
                if targets:
                    selected_target %= len(targets)
                else:
                    scroll += 1
                status = ""
            elif key in {ord("k"), curses.KEY_UP}:
                selected_target = selected_target - 1 if targets else selected_target
                if targets:
                    selected_target %= len(targets)
                else:
                    scroll -= 1
                status = ""
            elif key in {ord("J"), curses.KEY_NPAGE}:
                scroll += content_height
                status = ""
            elif key in {ord("K"), curses.KEY_PPAGE}:
                scroll -= content_height
                status = ""
            elif key == ord("r"):
                status = self.reply_to_remote_target(targets[selected_target]) if targets else "No remote comment selected."

    def show_text_popup(self, title: str, messages: Sequence[str]) -> None:
        """Show plain text messages in a scrollable popup."""
        def line_factory(width: int) -> Sequence[tuple[str, int]]:
            """Return wrapped lines for this popup."""
            return plain_popup_lines(messages, width)

        self.show_scroll_popup(title, line_factory)

    def show_scroll_popup(self, title: str, line_factory: Callable[[int], Sequence[tuple[str, int]]]) -> None:
        """Show styled lines in a scrollable popup."""
        self.draw()
        height, width = self.screen.getmaxyx()
        popup_height = max(8, min(height - 4, int(height * 0.75)))
        popup_width = max(50, min(width - 4, int(width * 0.85)))
        top = max(1, (height - popup_height) // 2)
        left = max(1, (width - popup_width) // 2)
        content_width = popup_width - 4
        content_height = popup_height - 4
        scroll = 0

        while True:
            lines = list(line_factory(content_width))
            max_scroll = max(0, len(lines) - content_height)
            scroll = max(0, min(scroll, max_scroll))
            popup = curses.newwin(popup_height, popup_width, top, left)
            popup.keypad(True)
            popup.erase()
            popup.box()
            add_text(popup, 0, 2, f" {title} ", popup_width - 4, curses.A_BOLD | color_pair(theme_color("purple")))
            add_text(
                popup,
                popup_height - 2,
                2,
                "j/k scroll  J/K page  q/Esc close".ljust(popup_width - 4),
                popup_width - 4,
                color_pair(theme_color("comment")),
            )
            for row in range(content_height):
                index = scroll + row
                if index >= len(lines):
                    break
                text, mode = lines[index]
                add_text(popup, row + 2, 2, text.ljust(content_width), content_width, mode)
            popup.refresh()
            key = popup.getch()
            if key in {ord("q"), 27, curses.KEY_ENTER, 10, 13}:
                self.draw()
                return
            if key in {ord("j"), curses.KEY_DOWN}:
                scroll += 1
            elif key in {ord("k"), curses.KEY_UP}:
                scroll -= 1
            elif key in {ord("J"), curses.KEY_NPAGE}:
                scroll += content_height
            elif key in {ord("K"), curses.KEY_PPAGE}:
                scroll -= content_height

    def suspend(self, action: Callable[[], Any]) -> Any:
        """Temporarily hand the terminal to an interactive command."""
        curses.def_prog_mode()
        curses.endwin()
        try:
            return action()
        finally:
            curses.reset_prog_mode()
            curses.curs_set(0)
            self.screen.keypad(True)

    def draw(self) -> None:
        """Draw the full TUI."""
        self.screen.erase()
        self.search_cursor = None
        height, width = self.screen.getmaxyx()
        if height < 12 or width < 60:
            add_text(self.screen, 0, 0, "Terminal too small for review.", width)
            self.screen.refresh()
            return

        files_height = max(5, min(10, height // 4))
        comments_height = max(4, min(7, height // 5))
        diff_height = height - files_height - comments_height - 4

        self.draw_header(width)
        self.draw_diff(1, 0, diff_height, width)
        self.draw_comments(1 + diff_height, 0, comments_height, width)
        self.draw_files(1 + diff_height + comments_height, 0, files_height, width)
        add_text(
            self.screen,
            height - 2,
            0,
            self.message.ljust(width),
            width,
            color_pair(theme_color("comment")),
        )
        add_text(
            self.screen,
            height - 1,
            0,
            HELP_TEXT.ljust(width),
            width,
            curses.A_BOLD | color_pair(theme_color("purple")),
        )
        if self.search_active and self.search_cursor is not None:
            try:
                self.screen.move(*self.search_cursor)
            except curses.error:
                pass
        self.screen.refresh()

    def draw_header(self, width: int) -> None:
        """Draw the app header."""
        title = f" review  {self.branch} against {self.base} "
        add_text(self.screen, 0, 0, title.ljust(width), width, curses.A_BOLD | color_pair(theme_color("purple")))

    def draw_files(self, y: int, x: int, height: int, width: int) -> None:
        """Draw the changed-file checklist pane."""
        files = self.visible_files()
        search_label = self.search_query or ""
        search_prefix = "search>" if self.search_active else "search"
        title_prefix = f"Files  filter:{self.file_filter}  {search_prefix} /"
        title = f"{title_prefix}{search_label}/  {len(files)}/{len(self.files)}"
        if self.search_error:
            title = f"{title_prefix}{search_label}/  regex error: {self.search_error}"
        add_text(self.screen, y, x, title.ljust(width), width, curses.A_BOLD | color_pair(theme_color("cyan")))
        if self.search_active:
            cursor_x = min(width - 1, len(title_prefix) + len(search_label))
            self.search_cursor = (y, x + cursor_x)
        visible_height = max(1, height - 1)
        if self.selected < self.file_scroll:
            self.file_scroll = self.selected
        if self.selected >= self.file_scroll + visible_height:
            self.file_scroll = self.selected - visible_height + 1

        for row in range(visible_height):
            index = self.file_scroll + row
            line_y = y + row + 1
            if index >= len(files):
                add_text(self.screen, line_y, x, " ".ljust(width), width)
                continue
            changed_file = files[index]
            checked = "x" if changed_file.path in self.reviewed else " "
            count = len(self.comments_by_path.get(changed_file.path, []))
            suffix = f" ({count})" if count else ""
            label = f"[{checked}] {changed_file.path}{suffix}"
            color = theme_color("green") if checked == "x" else theme_color("foreground")
            mode = color_pair(color)
            if index == self.selected:
                mode = curses.A_BOLD | curses.A_UNDERLINE | color_pair(theme_color("purple"))
            add_text(self.screen, line_y, x, label.ljust(width), width, mode)

    def draw_diff(self, y: int, x: int, height: int, width: int) -> None:
        """Draw the side-by-side diff pane."""
        current = self.selected_file()
        title = f"Diff: {current.path}" if current else "Diff"
        add_text(self.screen, y, x, title.ljust(width), width, curses.A_BOLD | color_pair(theme_color("cyan")))
        if current is None:
            add_text(self.screen, y + 1, x, "No changed files.", width)
            return

        cache_key = (current.path, width)
        if cache_key not in self.diff_cache:
            self.diff_cache[cache_key] = side_by_side_diff_lines(self.base, current.path, width, self.branch)
        lines = self.diff_cache[cache_key]
        max_scroll = max(0, len(lines) - height + 1)
        self.diff_scroll = max(0, min(self.diff_scroll, max_scroll))

        for row in range(max(1, height - 1)):
            index = self.diff_scroll + row
            line = lines[index] if index < len(lines) else ""
            segments = parse_ansi_line(line)
            add_styled_text(self.screen, y + row + 1, x, segments, width)
            padding = width - visible_length(segments)
            if padding > 0:
                add_text(self.screen, y + row + 1, x + width - padding, " " * padding, padding)

    def draw_comments(self, y: int, x: int, height: int, width: int) -> None:
        """Draw comments for the selected file."""
        current = self.selected_file()
        add_text(self.screen, y, x, "Comments".ljust(width), width, curses.A_BOLD | color_pair(theme_color("cyan")))
        if current is None:
            return
        local_comments = self.comments_by_path.get(current.path, [])
        remote_threads = self.remote_threads_by_path.get(current.path, [])
        if not local_comments and not remote_threads:
            add_text(self.screen, y + 1, x, "No #review comments in this file.", width)
            return

        local_count = len(local_comments)
        reply_count = sum(max(0, len(thread.notes) - 1) for thread in remote_threads)
        summary = f"{local_count} local / {len(remote_threads)} threads / {reply_count} replies"
        add_text(self.screen, y + 1, x, summary.ljust(width), width, color_pair(theme_color("foreground")))
        if height > 2 and local_comments:
            local_lines = ", ".join(str(comment.target_line) for comment in local_comments)
            add_text(self.screen, y + 2, x, f"local lines: {local_lines}".ljust(width), width, color_pair(theme_color("yellow")))
        if height > 3 and remote_threads:
            remote_lines = ", ".join(str(thread.line) for thread in remote_threads)
            add_text(self.screen, y + 3, x, f"remote lines: {remote_lines}".ljust(width), width, color_pair(theme_color("green")))


def interactive(base: str) -> None:
    """Run the full-screen terminal UI."""
    curses.wrapper(lambda screen: ReviewApp(screen, base).run())


def parser() -> argparse.ArgumentParser:
    """Build the CLI argument parser."""
    argument_parser = argparse.ArgumentParser(description="Review branch changes from the terminal.")
    argument_parser.add_argument("--base", help="base branch/ref to compare against")
    argument_parser.add_argument("--fast", action="store_true", help="open the lightweight fzf/delta review picker")
    subparsers = argument_parser.add_subparsers(dest="command")

    subparsers.add_parser("status", help="show changed files and reviewed checkboxes")
    subparsers.add_parser("comments", help="show local #review comments")
    subparsers.add_parser("ui", help="open the interactive CLI app")
    subparsers.add_parser("open", help="open the current merge/pull request in the browser")

    diff_parser = subparsers.add_parser("diff", help="show a side-by-side diff for a changed file")
    diff_parser.add_argument("file", help="changed file path or list number")

    edit_parser = subparsers.add_parser("edit", help="open a changed file to add #review comments")
    edit_parser.add_argument("file", help="changed file path or list number")

    toggle_parser = subparsers.add_parser("toggle", help="toggle reviewed checkbox for a changed file")
    toggle_parser.add_argument("file", help="changed file path or list number")

    publish_parser = subparsers.add_parser("publish", help="publish #review comments to a merge/pull request")
    publish_parser.add_argument("--provider", choices=["auto", "gitlab", "github"], default="auto")
    publish_parser.add_argument("--dry-run", action="store_true")
    publish_parser.add_argument("--force", action="store_true", help="publish even if local state says comments were published")

    return argument_parser


def normalize_args(arguments: Sequence[str]) -> list[str]:
    """Move global options before the subcommand for argparse."""
    normalized: list[str] = []
    remaining: list[str] = []
    index = 0
    while index < len(arguments):
        argument = arguments[index]
        if argument == "--base" and index + 1 < len(arguments):
            normalized.extend([argument, arguments[index + 1]])
            index += 2
        elif argument.startswith("--base="):
            normalized.append(argument)
            index += 1
        elif argument == "--fast":
            normalized.append(argument)
            index += 1
        else:
            remaining.append(argument)
            index += 1
    return [*normalized, *remaining]


def main() -> None:
    """Run the review CLI."""
    args = parser().parse_args(normalize_args(sys.argv[1:]))
    base = args.base or default_base()
    verify_base(base)

    if args.fast:
        fast_review(base)
    elif args.command in {None, "ui"}:
        interactive(base)
    elif args.command == "status":
        print_status(base)
    elif args.command == "comments":
        list_comments(base)
    elif args.command == "diff":
        show_diff(base, resolve_path(changed_files(base), args.file))
    elif args.command == "edit":
        open_file(resolve_path(changed_files(base), args.file))
    elif args.command == "toggle":
        toggle_reviewed(base, resolve_path(changed_files(base), args.file))
    elif args.command == "open":
        provider = detect_provider()
        if provider is None:
            die("could not detect provider from git remote")
        if not open_review_request(provider):
            die(f"could not open {provider} review")
    elif args.command == "publish":
        provider = detect_provider() if args.provider == "auto" else args.provider
        if provider is None:
            die("could not detect provider from git remote; pass --provider gitlab or --provider github")
        published = publish_comments(base, provider, args.dry_run, force=args.force)
        removed = remove_published_markers(published) if published else 0
        if removed:
            print(f"Removed {removed} local review marker{'s' if removed != 1 else ''}.")


if __name__ == "__main__":
    main()
