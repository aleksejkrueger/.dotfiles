def scroll_for_selected_block(scroll: int, content_height: int, block_start: int, block_end: int) -> int:
    """Return popup scroll adjusted to show the selected block when it fits."""
    block_height = block_end - block_start + 1
    if block_height <= content_height:
        if block_start < scroll:
            return block_start
        if block_end >= scroll + content_height:
            return block_end - content_height + 1
        return scroll
    if block_start < scroll or block_start >= scroll + content_height:
        return block_start
    return scroll


def clipboard_commands() -> list[list[str]]:
    """Return available clipboard commands in preferred order."""
    candidates = (
        ["pbcopy"],
        ["wl-copy"],
        ["xclip", "-selection", "clipboard"],
        ["xsel", "--clipboard", "--input"],
    )
    return [command for command in candidates if shutil.which(command[0]) is not None]


def copy_to_clipboard(text: str) -> tuple[bool, str]:
    """Copy text to the system clipboard."""
    last_error = ""
    for command in clipboard_commands():
        success, output = try_run(command, input_text=text)
        if success:
            return True, "Copied selected comment."
        if output:
            last_error = output
    detail = f": {last_error}" if last_error else ""
    return False, f"No clipboard command worked{detail}."


def is_escape_key(key: int) -> bool:
    """Return whether a curses key should cancel the current mode."""
    return key in {27, curses.KEY_EXIT}


def prompt(window: curses.window, label: str) -> str | None:
    """Read a short prompt from the bottom status line."""
    curses.noecho()
    window.keypad(True)
    curses.curs_set(1)
    height, width = window.getmaxyx()
    value = ""
    try:
        while True:
            window.move(height - 1, 0)
            window.clrtoeol()
            text = f"{label}{value}"
            add_text(window, height - 1, 0, text, width)
            window.move(height - 1, min(width - 1, len(text)))
            window.refresh()
            key = window.getch()
            if is_escape_key(key):
                curses.flushinp()
                return None
            if key in {curses.KEY_ENTER, 10, 13}:
                return value.strip()
            if key in {curses.KEY_BACKSPACE, 8, 127}:
                value = value[:-1]
            elif key == 21:
                value = ""
            elif 32 <= key <= 126:
                value += chr(key)
    finally:
        curses.noecho()
        curses.curs_set(0)


def confirm_publish(window: curses.window, provider: str) -> bool | None:
    """Return whether to publish for real, or None when cancelled."""
    height, width = window.getmaxyx()
    window.move(height - 1, 0)
    window.clrtoeol()
    add_text(window, height - 1, 0, f"{provider}: y publish, any other key dry-run, Esc cancel", width)
    window.refresh()
    key = window.getch()
    if key == 27:
        return None
    return key in {ord("y"), ord("Y")}


class ReviewApp:
    """Full-screen review terminal UI."""

    def __init__(
        self,
        screen: curses.window,
        ref_range: ReviewRange,
        ignore_patterns: Sequence[str] = (),
    ) -> None:
        """Create the TUI app."""
        self.screen = screen
        self.ref_range = ref_range
        self.ignore_patterns = tuple(ignore_patterns)
        self.branch = branch_name()
        self.files: list[ChangedFile] = []
        self.state: dict[str, Any] = {}
        self.reviewed: set[str] = set()
        self.ignored: set[str] = set()
        self.comments_by_path: dict[str, list[ReviewComment]] = {}
        self.remote_threads_by_path: dict[str, list[RemoteThread]] = {}
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0
        self.message = "Ready."
        self.diff_cache: dict[tuple[str, int], list[str]] = {}
        self.search_query = ""
        self.search_error = ""
        self.search_active = False
        self.search_cursor: tuple[int, int] | None = None
        self.file_filter = "all"

    def selected_file(self) -> ChangedFile | None:
        """Return the selected changed file."""
        files = self.visible_files()
        if not files:
            return None
        self.selected = max(0, min(self.selected, len(files) - 1))
        return files[self.selected]

    def visible_files(self) -> list[ChangedFile]:
        """Return changed files matching the active regex search."""
        files = self.files
        if self.file_filter == "checked":
            files = [
                changed_file
                for changed_file in files
                if changed_file.path in self.reviewed and changed_file.path not in self.ignored
            ]
        elif self.file_filter == "unchecked":
            files = [
                changed_file
                for changed_file in files
                if changed_file.path not in self.reviewed and changed_file.path not in self.ignored
            ]
        elif self.file_filter == "ignored":
            files = [changed_file for changed_file in files if changed_file.path in self.ignored]

        if not self.search_query:
            self.search_error = ""
            return files
        try:
            pattern = re.compile(self.search_query, re.IGNORECASE)
        except re.error as error:
            self.search_error = str(error)
            return []
        self.search_error = ""
        return [changed_file for changed_file in files if pattern.search(changed_file.path)]

    def reload(self) -> None:
        """Reload files, state, and clear stale diff cache."""
        self.files = changed_files(self.ref_range, self.ignore_patterns)
        self.state = load_state(self.ref_range)
        self.reviewed = reviewed_paths(self.state)
        self.ignored = ignored_file_paths(self.state)
        self.comments_by_path = comments_by_path(self.files)
        self.selected = max(0, min(self.selected, max(0, len(self.visible_files()) - 1)))
        self.diff_cache.clear()

    def run(self) -> None:
        """Run the curses event loop."""
        init_theme(os.environ.get("review_THEME", "dracula").lower())
        try:
            curses.set_escdelay(25)
        except curses.error:
            pass
        curses.curs_set(0)
        self.screen.keypad(True)
        self.reload()
        self.load_startup_remote_comments()
        while True:
            curses.curs_set(1 if self.search_active else 0)
            self.draw()
            key = self.screen.getch()
            if not self.search_active and key in {ord("q"), 27}:
                return
            self.handle_key(key)

    def handle_key(self, key: int) -> None:
        """Handle one key press."""
        if self.search_active:
            self.handle_search_key(key)
        elif key in {ord("j"), curses.KEY_DOWN}:
            self.move_selection(1)
        elif key in {ord("k"), curses.KEY_UP}:
            self.move_selection(-1)
        elif key in {ord("J"), curses.KEY_NPAGE}:
            self.diff_scroll += 10
        elif key in {ord("K"), curses.KEY_PPAGE}:
            self.diff_scroll = max(0, self.diff_scroll - 10)
        elif key == ord(" "):
            self.toggle_current()
        elif key == ord("i"):
            self.toggle_ignored_current()
        elif key in {ord("c"), ord("e"), curses.KEY_ENTER, 10, 13}:
            self.edit_current()
        elif key == ord("m"):
            self.show_comments_popup()
        elif key == ord("t"):
            self.show_jira_popup()
        elif key == ord("?"):
            self.show_help_popup()
        elif key == ord("d"):
            self.open_current_diff()
        elif key == ord("/"):
            self.search_active = True
            self.message = "Search mode. Enter accepts, Esc leaves, Ctrl-U clears."
        elif key == ord("f"):
            self.cycle_file_filter()
        elif key == ord("n"):
            self.jump_unreviewed(1)
        elif key == ord("N"):
            self.jump_unreviewed(-1)
        elif key == 21:
            self.clear_search()
        elif key == ord("o"):
            self.open_review_request()
        elif key == ord("R"):
            self.refresh_remote_comments()
        elif key == ord("p"):
            self.publish_dry_run()
        elif key == ord("r"):
            self.reload()
            self.message = "Refreshed."

    def handle_search_key(self, key: int) -> None:
        """Handle one key press while editing the regex search."""
        if key in {27, curses.KEY_ENTER, 10, 13}:
            self.search_active = False
            self.message = "Search applied." if self.search_query else "Search cleared."
        elif key == 21:
            self.clear_search()
        elif key == 23:
            self.delete_search_word()
        elif key in {curses.KEY_BACKSPACE, 8, 127}:
            self.delete_search_char()
        elif 32 <= key <= 126:
            self.append_search_char(chr(key))

    def move_selection(self, step: int) -> None:
        """Move the selected file."""
        files = self.visible_files()
        if not files:
            return
        self.selected = max(0, min(len(files) - 1, self.selected + step))
        self.diff_scroll = 0

    def append_search_char(self, character: str) -> None:
        """Append one typed character to the regex search."""
        self.search_query += character
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0

    def delete_search_char(self) -> None:
        """Delete one character from the regex search."""
        self.search_query = self.search_query[:-1]
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0

    def delete_search_word(self) -> None:
        """Delete the last regex search word."""
        self.search_query = self.search_query.rstrip()
        self.search_query = self.search_query[: self.search_query.rfind(" ") + 1].rstrip()
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0

    def clear_search(self) -> None:
        """Clear the active regex search."""
        self.search_query = ""
        self.search_error = ""
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0
        self.message = "Search cleared."

    def cycle_file_filter(self) -> None:
        """Cycle file list filter between all, unchecked, and checked files."""
        index = FILE_FILTERS.index(self.file_filter)
        self.file_filter = FILE_FILTERS[(index + 1) % len(FILE_FILTERS)]
        self.selected = 0
        self.file_scroll = 0
        self.diff_scroll = 0
        self.message = f"Showing {self.file_filter} files."

    def jump_unreviewed(self, step: int) -> None:
        """Jump to an unchecked file without changing filters."""
        files = self.visible_files()
        if not files:
            return

        total = len(files)
        for offset in range(1, total + 1):
            index = (self.selected + (offset * step)) % total
            if files[index].path not in self.reviewed and files[index].path not in self.ignored:
                self.selected = index
                self.diff_scroll = 0
                direction = "Next" if step > 0 else "Previous"
                self.message = f"{direction}: {files[index].path}"
                return
        self.message = "No unreviewed files in current view."

    def toggle_current(self) -> None:
        """Toggle reviewed state for the selected file."""
        current = self.selected_file()
        if current is None:
            return
        toggle_reviewed(self.ref_range, current.path)
        self.state = load_state(self.ref_range)
        self.reviewed = reviewed_paths(self.state)
        self.message = f"Toggled {current.path}."

    def toggle_ignored_current(self) -> None:
        """Toggle ignored state for the selected file."""
        current = self.selected_file()
        if current is None:
            return
        is_now_ignored = toggle_ignored(self.ref_range, current.path)
        self.state = load_state(self.ref_range)
        self.ignored = ignored_file_paths(self.state)
        self.selected = max(0, min(self.selected, max(0, len(self.visible_files()) - 1)))
        self.diff_scroll = 0
        action = "Ignored" if is_now_ignored else "Unignored"
        self.message = f"{action} {current.path}."

    def edit_current(self) -> None:
        """Open the selected file in an editor."""
        current = self.selected_file()
        if current is None:
            return
        self.suspend(lambda: open_file(current.path))
        self.reload()
        self.message = f"Edited {current.path}."

    def open_current_diff(self) -> None:
        """Open the selected file diff in the pager."""
        current = self.selected_file()
        if current is None:
            return
        self.suspend(lambda: show_diff(self.ref_range, current.path, self.branch))
        self.message = f"Viewed diff for {current.path}."

    def publish_dry_run(self) -> None:
        """Publish or dry-run comments and show the result in a popup."""
        provider = detect_provider()
        if provider is None:
            self.message = "Ready."
            self.show_text_popup("publish", ["Could not detect GitLab/GitHub remote."])
            return
        publish_for_real = confirm_publish(self.screen, provider)
        if publish_for_real is None:
            self.message = "Ready."
            self.show_text_popup("publish", ["Publish cancelled."])
            return
        dry_run = not publish_for_real
        self.message = f"Publishing to {provider}..."
        self.draw()
        output = StringIO()
        published: list[ReviewComment] = []
        removed = 0
        failed = False
        with redirect_stdout(output), redirect_stderr(output):
            try:
                published = publish_comments(
                    self.ref_range,
                    provider,
                    dry_run=dry_run,
                    ignore_patterns=self.ignore_patterns,
                )
                removed = remove_published_markers(published) if published else 0
                if published:
                    self.reload()
                    self.load_remote_comments(provider)
            except SystemExit:
                failed = True
            except Exception as error:
                failed = True
                print(f"review: {error}", file=sys.stderr)

        mode = "dry-run" if dry_run else "publish"
        messages = output.getvalue().splitlines()
        if removed:
            messages.append(f"Removed {removed} local review marker{'s' if removed != 1 else ''}.")
        if not messages:
            messages.append(f"{provider} {mode} finished.")
        title = "publish failed" if failed else f"{provider} {mode}"
        self.message = "Ready."
        self.show_text_popup(title, messages)

    def open_review_request(self) -> None:
        """Open the detected merge or pull request in the browser."""
        if not self.files:
            self.message = f"Open cancelled: no changed files in {range_label(self.ref_range)}."
            return
        provider = detect_provider()
        if provider is None:
            self.message = "Open cancelled: could not detect GitLab/GitHub remote."
            return
        self.message = f"Opening {provider} review..."
        self.draw()
        opened = open_review_request(provider)
        self.message = f"Opened {provider} review." if opened else f"Could not open {provider} review."

    def load_jira_issue_for_popup(self, config: JiraConfig, key: str) -> tuple[JiraIssue | None, str]:
