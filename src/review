        f"projects/{project}/merge_requests/{iid}/discussions/{thread.thread_id}/notes",
        "--method",
        "POST",
        "--header",
        "Content-Type: application/json",
        "--input",
        "-",
    ]
    success, output = try_run(command, input_text=json.dumps({"body": body}))
    if not success:
