#!/usr/bin/env python3
from __future__ import annotations

import argparse
import curses
import json
import keyword
import shlex
import subprocess
import sys
import time
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any


@dataclass(frozen=True)
class ReplVariable:
    """A compact representation of one REPL variable."""

    name: str
    type_name: str
    detail: str
    value: str
    viewer_kind: str = ""
    viewer_path: str = ""


@dataclass(frozen=True)
class TableColumn:
    """Rendering metadata for one variable table column."""

    title: str
    field: str
    min_width: int
    max_width: int
    weight: int


@dataclass
class ViewState:
    """Mutable state for the variable browser."""

    variables: list[ReplVariable]
    watched_names: set[str] = field(default_factory=set)
    variable_signatures: dict[str, str] = field(default_factory=dict)
    changed_until: dict[str, float] = field(default_factory=dict)
    pending_delete_name: str = ""
    pending_delete_until: float = 0.0
    selected: int = 0
    offset: int = 0
    updated_at: str = ""
    message: str = ""


TABLE_COLUMNS = (
    TableColumn("name", "name", 8, 24, 2),
    TableColumn("type", "type_name", 6, 18, 1),
    TableColumn("detail", "detail", 6, 24, 1),
    TableColumn("value", "value", 8, 120, 4),
)
TABLE_SEPARATOR = " | "
TABLE_DIVIDER = "-+-"
COLOR_HEADER = 1
COLOR_DIVIDER = 2
COLOR_NAME = 3
COLOR_TYPE = 4
COLOR_DETAIL = 5
COLOR_FOOTER = 6
COLOR_SELECTED = 7
COLOR_MESSAGE = 8
COLOR_WATCH = 9
COLOR_CHANGED = 10
CHANGE_HIGHLIGHT_SECONDS = 2.5
DELETE_CONFIRM_SECONDS = 3.0
R_RESERVED_WORDS = {
    "FALSE",
    "Inf",
    "NA",
    "NA_character_",
    "NA_complex_",
    "NA_integer_",
    "NA_real_",
    "NULL",
    "NaN",
    "TRUE",
    "break",
    "else",
    "for",
    "function",
    "if",
    "in",
    "next",
    "repeat",
    "while",
}


def parse_args() -> argparse.Namespace:
    """Parse command-line arguments for the variable browser."""

    parser = argparse.ArgumentParser(description="Browse exported REPL variables in tmux.")
    parser.add_argument("--vars-file", required=True, type=Path)
    parser.add_argument("--target-pane", required=True)
    parser.add_argument("--language", choices=("python", "r"), default="python")
    parser.add_argument("--refresh-seconds", default=0.5, type=float)
    return parser.parse_args()


def text_value(value: Any) -> str:
    """Return a plain string for JSON values that may be missing or malformed."""

    return str(value) if value is not None else ""


def truncate(value: str, width: int) -> str:
    """Trim a string to fit in a fixed terminal width."""

    if width <= 0:
        return ""
    if len(value) <= width:
        return value
    if width == 1:
        return "."
    return value[: width - 1] + "."


def init_colors(window: curses.window) -> None:
    """Initialize a small transparent color palette for curses."""

    curses.start_color()
    curses.use_default_colors()
    window.bkgd(" ", curses.color_pair(0))

    if not curses.has_colors():
        return

    curses.init_pair(COLOR_HEADER, curses.COLOR_CYAN, -1)
    curses.init_pair(COLOR_DIVIDER, curses.COLOR_BLUE, -1)
    curses.init_pair(COLOR_NAME, curses.COLOR_GREEN, -1)
    curses.init_pair(COLOR_TYPE, curses.COLOR_MAGENTA, -1)
    curses.init_pair(COLOR_DETAIL, curses.COLOR_YELLOW, -1)
    curses.init_pair(COLOR_FOOTER, curses.COLOR_BLUE, -1)
    curses.init_pair(COLOR_SELECTED, curses.COLOR_BLACK, curses.COLOR_CYAN)
    curses.init_pair(COLOR_MESSAGE, curses.COLOR_YELLOW, -1)
    curses.init_pair(COLOR_WATCH, curses.COLOR_YELLOW, -1)
    curses.init_pair(COLOR_CHANGED, curses.COLOR_BLACK, curses.COLOR_YELLOW)


def color(number: int, attr: int = 0) -> int:
    """Return a curses color pair with optional attributes."""

    if not curses.has_colors():
        return attr

    return curses.color_pair(number) | attr


def visible_row_count(height: int) -> int:
    """Return how many variable rows fit in the current window."""

    return max(1, height - 3)


def minimum_column_width(column: TableColumn) -> int:
    """Return the smallest readable width for a table column."""

    return min(column.min_width, len(column.title))


def shrink_widths(widths: list[int], target_total: int) -> list[int]:
    """Shrink column widths from right to left until they fit."""

    minimums = [minimum_column_width(column) for column in TABLE_COLUMNS]

    while sum(widths) > target_total:
        changed = False

        for index in reversed(range(len(widths))):
            if widths[index] > minimums[index]:
                widths[index] -= 1
                changed = True
                break

        if not changed:
            break

    return widths


def grow_widths(widths: list[int], extra_width: int) -> list[int]:
    """Grow column widths by weighted priority until extra width is used."""

    weighted_indexes = [
        index
        for index, column in enumerate(TABLE_COLUMNS)
        for _ in range(column.weight)
    ]

    while extra_width > 0:
        changed = False

        for index in weighted_indexes:
            if widths[index] >= TABLE_COLUMNS[index].max_width:
                continue

            widths[index] += 1
            extra_width -= 1
            changed = True

            if extra_width == 0:
                break

        if not changed:
            widths[-1] += extra_width
            break

    return widths


def table_widths(total_width: int) -> list[int]:
    """Compute table column widths for the current terminal width."""

    separator_width = len(TABLE_SEPARATOR) * (len(TABLE_COLUMNS) - 1)
    available_width = max(1, total_width - separator_width)
    widths = [column.min_width for column in TABLE_COLUMNS]

    if sum(widths) > available_width:
        return shrink_widths(widths, available_width)

    return grow_widths(widths, available_width - sum(widths))


def table_cell(value: str, width: int) -> str:
    """Return one padded table cell."""

    return f"{truncate(value, width):<{width}}"


def variable_value(variable: ReplVariable, column: TableColumn) -> str:
    """Read a variable field for the requested table column."""

    return getattr(variable, column.field)


def variable_signature(variable: ReplVariable) -> str:
    """Return a compact signature used to detect displayed value changes."""

    return "\0".join((variable.type_name, variable.detail, variable.value))


def visible_name(variable: ReplVariable, watched_names: set[str]) -> str:
    """Return a variable name with a watch marker when needed."""

    if variable.name in watched_names:
        return f"* {variable.name}"
    return variable.name


def display_value(variable: ReplVariable, column: TableColumn, watched_names: set[str]) -> str:
    """Return a table display value for a variable column."""

    if column.field == "name":
        return visible_name(variable, watched_names)
    return variable_value(variable, column)


def display_values(variable: ReplVariable, watched_names: set[str]) -> list[str]:
    """Return all table display values for a variable."""

    return [display_value(variable, column, watched_names) for column in TABLE_COLUMNS]


def table_row(values: list[str], widths: list[int]) -> str:
    """Render a complete table row from cell values."""

    return TABLE_SEPARATOR.join(
        table_cell(value, width)
        for value, width in zip(values, widths, strict=True)
    )


def header_row(widths: list[int]) -> str:
    """Render the variable table header row."""

    return table_row([column.title for column in TABLE_COLUMNS], widths)


def divider_row(widths: list[int]) -> str:
    """Render the variable table divider row."""

    return TABLE_DIVIDER.join("-" * width for width in widths)


def variable_row(variable: ReplVariable, widths: list[int], watched_names: set[str]) -> str:
    """Render one variable as a table row."""

    return table_row(display_values(variable, watched_names), widths)


def load_variables(path: Path) -> tuple[list[ReplVariable], str, str]:
    """Load exported variables from a JSON snapshot."""

    if not path.exists():
        return [], "", "Waiting for the first variable snapshot."

    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        return [], "", f"Could not read vars file: {error}"

    variables = [
        ReplVariable(
            name=text_value(item.get("name")),
            type_name=text_value(item.get("type")),
            detail=text_value(item.get("detail")),
            value=text_value(item.get("value")),
            viewer_kind=text_value(item.get("viewer_kind")),
            viewer_path=text_value(item.get("viewer_path")),
        )
        for item in payload.get("vars", [])
        if isinstance(item, dict) and item.get("name")
    ]
    message = text_value(payload.get("message"))
    return variables, text_value(payload.get("updated_at")), message


def selected_name(state: ViewState) -> str:
    """Return the currently selected variable name, if any."""

    if not state.variables:
        return ""
    if not 0 <= state.selected < len(state.variables):
        return ""
    return state.variables[state.selected].name


def ordered_variables(variables: list[ReplVariable], watched_names: set[str]) -> list[ReplVariable]:
    """Return variables with watched names pinned to the top."""

    watched = [variable for variable in variables if variable.name in watched_names]
    regular = [variable for variable in variables if variable.name not in watched_names]
    return watched + regular


def index_of_name(variables: list[ReplVariable], name: str) -> int | None:
    """Return the index of a variable name in a variable list."""

    for index, variable in enumerate(variables):
        if variable.name == name:
            return index
    return None


def cleanup_change_marks(state: ViewState, now: float) -> None:
    """Remove expired or unwatched change markers."""

    state.changed_until = {
        name: expires_at
        for name, expires_at in state.changed_until.items()
        if name in state.watched_names and expires_at > now
    }


def cleanup_pending_delete(state: ViewState, now: float) -> None:
    """Clear an expired pending delete confirmation."""

    if state.pending_delete_name and state.pending_delete_until <= now:
        if state.message == f"Press d again to delete {state.pending_delete_name}":
            state.message = ""
        state.pending_delete_name = ""
        state.pending_delete_until = 0.0


def refresh_watch_signatures(state: ViewState, variables: list[ReplVariable], now: float) -> None:
    """Update watched variable signatures and mark changed watched values."""

    for variable in variables:
        if variable.name not in state.watched_names:
            continue

        signature = variable_signature(variable)
        previous_signature = state.variable_signatures.get(variable.name)
        if previous_signature is not None and previous_signature != signature:
            state.changed_until[variable.name] = now + CHANGE_HIGHLIGHT_SECONDS
        state.variable_signatures[variable.name] = signature

    cleanup_change_marks(state, now)


def update_variables(
    state: ViewState,
    variables: list[ReplVariable],
    updated_at: str,
    message: str,
    now: float,
    height: int,
) -> None:
    """Apply a fresh snapshot while preserving selection and watch ordering."""

    name = selected_name(state)
    refresh_watch_signatures(state, variables, now)
    state.variables = ordered_variables(variables, state.watched_names)
    state.updated_at = updated_at
    if message:
        state.message = message

    selected_index = index_of_name(state.variables, name)
    if selected_index is not None:
        state.selected = selected_index
    clamp_state(state, height)


def toggle_watch(state: ViewState, now: float) -> None:
    """Toggle the selected variable in the watch list."""

    if not state.variables:
        state.message = "No variable to watch."
        return

    variable = state.variables[state.selected]
    if variable.name in state.watched_names:
        state.watched_names.remove(variable.name)
        state.variable_signatures.pop(variable.name, None)
        state.changed_until.pop(variable.name, None)
        state.message = f"Unwatched {variable.name}"
    else:
        state.watched_names.add(variable.name)
        state.variable_signatures[variable.name] = variable_signature(variable)
        state.message = f"Watching {variable.name}"

    state.variables = ordered_variables(state.variables, state.watched_names)
    selected_index = index_of_name(state.variables, variable.name)
    if selected_index is not None:
        state.selected = selected_index
    cleanup_change_marks(state, now)


def python_reference(name: str) -> str:
    """Return a Python expression that references a variable name."""

    if name.isidentifier() and not keyword.iskeyword(name):
        return name
    return f"globals()[{name!r}]"


def is_r_identifier(name: str) -> bool:
    """Return whether a name can be referenced directly in R code."""

    if not name or name in R_RESERVED_WORDS:
        return False

    first = name[0]
    if first == ".":
        if len(name) > 1 and name[1].isdigit():
            return False
    elif not first.isalpha():
        return False

    return all(character.isalnum() or character in "._" for character in name[1:])


def r_string(value: str) -> str:
    """Return a double-quoted R string literal."""

    return json.dumps(value)


def r_reference(name: str) -> str:
    """Return an R expression that references a variable name."""

    if is_r_identifier(name):
        return name
    escaped_name = name.replace("\\", "\\\\").replace("`", "\\`")
    return f"`{escaped_name}`"


def variable_reference(name: str, language: str) -> str:
    """Return a language-specific expression that references a variable."""

    if language == "r":
        return r_reference(name)
    return python_reference(name)


def print_expression(name: str, language: str) -> str:
    """Return language-specific code that prints a variable."""

    return f"print({variable_reference(name, language)})"


def delete_expression(name: str, language: str) -> str:
    """Return language-specific code that deletes a variable."""

    if language == "r":
        return f"rm(list = {r_string(name)}, envir = .GlobalEnv)"
    if name.isidentifier() and not keyword.iskeyword(name):
        return f"del {name}"
    return f"_ = globals().pop({name!r}, None)"


def forget_variable_state(state: ViewState, name: str) -> None:
    """Remove UI state associated with a deleted variable."""

    state.watched_names.discard(name)
    state.variable_signatures.pop(name, None)
    state.changed_until.pop(name, None)
    state.pending_delete_name = ""
    state.pending_delete_until = 0.0


def delete_selected(state: ViewState, target_pane: str, now: float, language: str) -> None:
    """Delete the selected variable after a short second-key confirmation."""

    if not state.variables:
        state.message = "No variable to delete."
        return

    variable = state.variables[state.selected]
    confirmed = state.pending_delete_name == variable.name and state.pending_delete_until > now
    if not confirmed:
        state.pending_delete_name = variable.name
        state.pending_delete_until = now + DELETE_CONFIRM_SECONDS
        state.message = f"Press d again to delete {variable.name}"
        return

    state.message = send_text(target_pane, delete_expression(variable.name, language), submit=True)
    if state.message.startswith("Pasted "):
        state.message = f"Deleted {variable.name}"
        forget_variable_state(state, variable.name)
        state.variables = [item for item in state.variables if item.name != variable.name]


def send_text(target_pane: str, text: str, submit: bool = False) -> str:
    """Send literal text to the target tmux pane."""

    try:
        subprocess.run(["tmux", "send-keys", "-t", target_pane, "-l", text], check=True)
        if submit:
            subprocess.run(["tmux", "send-keys", "-t", target_pane, "Enter"], check=True)
    except (OSError, subprocess.CalledProcessError) as error:
        return f"Could not send to {target_pane}: {error}"

    return f"Pasted {text}"


def copy_text(text: str) -> str:
    """Copy text into the tmux paste buffer."""

    try:
        subprocess.run(["tmux", "set-buffer", text], check=True)
    except (OSError, subprocess.CalledProcessError) as error:
        return f"Could not copy to tmux buffer: {error}"

    return f"Copied {text}"


def open_external(path: Path) -> str:
    """Open a file with the platform's default graphical application."""

    if sys.platform == "darwin":
        command = ["open", str(path)]
    elif sys.platform.startswith("linux"):
        command = ["xdg-open", str(path)]
    elif sys.platform.startswith("win"):
        command = ["cmd", "/c", "start", "", str(path)]
    else:
        return f"No external opener configured for {sys.platform}"

    try:
        subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except OSError as error:
        return f"Could not open {path.name}: {error}"

    return f"Opened {path.name}"


def open_viewer(variable: ReplVariable) -> str:
    """Open a variable preview in a tmux popup."""

    if not variable.viewer_path:
        return f"No preview for {variable.name}"

    viewer_path = Path(variable.viewer_path)
    figure_suffixes = {".png", ".jpg", ".jpeg", ".svg", ".pdf"}
    is_figure = variable.viewer_kind == "figure" or viewer_path.suffix.lower() in figure_suffixes

    if is_figure:
        return open_external(viewer_path)

    if variable.viewer_kind == "json":
        viewer_script = Path.home() / ".dotfiles" / "src" / "repl-json-viewer"
        command = f"{shlex.quote(str(viewer_script))} --json-file {shlex.quote(variable.viewer_path)}"
    elif variable.viewer_kind == "inspect":
        viewer_script = Path.home() / ".dotfiles" / "src" / "repl-inspect-viewer"
        command = f"{shlex.quote(str(viewer_script))} --inspect-file {shlex.quote(variable.viewer_path)}"
    else:
        viewer_script = Path.home() / ".dotfiles" / "src" / "repl-table-viewer"
        command = f"{shlex.quote(str(viewer_script))} --table-file {shlex.quote(variable.viewer_path)}"

    try:
        subprocess.run(["tmux", "display-popup", "-E", "-w", "90%", "-h", "80%", command], check=True)
    except (OSError, subprocess.CalledProcessError) as error:
        return f"Could not open viewer: {error}"

    return f"Opened {variable.name}"


def clamp_state(state: ViewState, height: int) -> None:
    """Keep selection and scroll offset inside the visible variable list."""

    if not state.variables:
        state.selected = 0
        state.offset = 0
        return

    state.selected = max(0, min(state.selected, len(state.variables) - 1))
    visible_rows = visible_row_count(height)

    if state.selected < state.offset:
        state.offset = state.selected
    elif state.selected >= state.offset + visible_rows:
        state.offset = state.selected - visible_rows + 1

    max_offset = max(0, len(state.variables) - visible_rows)
    state.offset = max(0, min(state.offset, max_offset))


def draw_text(window: curses.window, y: int, x: int, text: str, attr: int = 0) -> None:
    """Draw text while ignoring curses boundary errors."""

    try:
        window.addstr(y, x, text, attr)
    except curses.error:
        return


def draw_cell(window: curses.window, y: int, x: int, text: str, attr: int) -> int:
    """Draw one table cell and return the next cursor column."""

    draw_text(window, y, x, text, attr)
    return x + len(text)


def draw_colored_row(
    window: curses.window,
    y: int,
    values: list[str],
    widths: list[int],
    attrs: list[int],
) -> None:
    """Draw one table row with per-column colors."""

    x = 0
    for index, (value, width, attr) in enumerate(zip(values, widths, attrs, strict=True)):
        x = draw_cell(window, y, x, table_cell(value, width), attr)
        if index < len(values) - 1:
            x = draw_cell(window, y, x, TABLE_SEPARATOR, color(COLOR_DIVIDER, curses.A_DIM))


def draw_row(
    window: curses.window,
    y: int,
    variable: ReplVariable,
    widths: list[int],
    width: int,
    selected: bool,
    watched: bool,
    changed: bool,
) -> None:
    """Draw one variable row."""

    if selected:
        selected_attr = color(COLOR_CHANGED, curses.A_BOLD) if changed else color(COLOR_SELECTED)
        watched_names = {variable.name} if watched else set()
        draw_text(window, y, 0, " " * width, selected_attr)
        draw_text(
            window,
            y,
            0,
            truncate(variable_row(variable, widths, watched_names), width),
            selected_attr,
        )
        return

    if changed:
        changed_attr = color(COLOR_CHANGED, curses.A_BOLD)
        draw_text(window, y, 0, " " * width, changed_attr)
        draw_text(
            window,
            y,
            0,
            truncate(variable_row(variable, widths, {variable.name}), width),
            changed_attr,
        )
        return

    draw_colored_row(
        window,
        y,
        display_values(variable, {variable.name} if watched else set()),
        widths,
        [
            color(COLOR_WATCH, curses.A_BOLD) if watched else color(COLOR_NAME),
            color(COLOR_TYPE),
            color(COLOR_DETAIL),
            0,
        ],
    )


def draw(window: curses.window, state: ViewState) -> None:
    """Render the complete variable browser."""

    window.erase()
    height, width = window.getmaxyx()
    if height < 5 or width < 24:
        draw_text(window, 0, 0, "vars")
        window.refresh()
        return

    widths = table_widths(width)
    draw_colored_row(
        window,
        0,
        [column.title for column in TABLE_COLUMNS],
        widths,
        [color(COLOR_HEADER, curses.A_BOLD)] * len(TABLE_COLUMNS),
    )
    draw_text(window, 1, 0, truncate(divider_row(widths), width), color(COLOR_DIVIDER, curses.A_DIM))

    visible_rows = visible_row_count(height)
    now = time.monotonic()
    cleanup_change_marks(state, now)
    cleanup_pending_delete(state, now)
    if state.variables:
        visible_indexes = range(
            state.offset,
            min(len(state.variables), state.offset + visible_rows),
        )
        for screen_row, index in enumerate(visible_indexes):
            variable = state.variables[index]
            draw_row(
                window,
                screen_row + 2,
                variable,
                widths,
                width,
                index == state.selected,
                variable.name in state.watched_names,
                state.changed_until.get(variable.name, 0.0) > now,
            )
    else:
        draw_text(window, 2, 0, truncate(state.message or "No variables exported yet.", width), color(COLOR_MESSAGE))

    footer = "Click: select  Enter: run  w: watch  d: del  o: open  p: print  y: copy"
    if state.message and state.variables:
        footer = state.message
    draw_text(window, height - 1, 0, truncate(footer, width), color(COLOR_FOOTER, curses.A_DIM))
    window.refresh()


def send_selected(
    state: ViewState,
    target_pane: str,
    language: str,
    expression: str | None = None,
    submit: bool = False,
) -> None:
    """Send the selected variable or expression to the REPL pane."""

    if not state.variables:
        state.message = "No variables to send."
        return

    variable = state.variables[state.selected]
    state.message = send_text(
        target_pane,
        expression or variable_reference(variable.name, language),
        submit,
    )


def handle_mouse(state: ViewState, target_pane: str, height: int) -> None:
    """Handle mouse clicks and wheel events inside the variable browser."""

    try:
        _, _, y, _, button_state = curses.getmouse()
    except curses.error:
        return

    if button_state & curses.BUTTON4_PRESSED:
        state.selected -= 1
        clamp_state(state, height)
        return

    if hasattr(curses, "BUTTON5_PRESSED") and button_state & curses.BUTTON5_PRESSED:
        state.selected += 1
        clamp_state(state, height)
        return

    if button_state & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED | curses.BUTTON1_RELEASED):
        index = state.offset + y - 2
        if 0 <= index < len(state.variables):
            state.selected = index
            clamp_state(state, height)


def handle_key(
    key: int,
    state: ViewState,
    target_pane: str,
    height: int,
    now: float,
    language: str,
) -> bool:
    """Handle one keyboard or mouse event."""

    if key == curses.KEY_MOUSE:
        handle_mouse(state, target_pane, height)
    elif key in (curses.KEY_UP, ord("k")):
        state.selected -= 1
    elif key in (curses.KEY_DOWN, ord("j")):
        state.selected += 1
    elif key == curses.KEY_PPAGE:
        state.selected -= max(1, height - 5)
    elif key == curses.KEY_NPAGE:
        state.selected += max(1, height - 5)
    elif key in (10, 13):
        send_selected(state, target_pane, language, submit=True)
    elif key == ord("p") and state.variables:
        expression = print_expression(state.variables[state.selected].name, language)
        send_selected(state, target_pane, language, expression, True)
    elif key == ord("o") and state.variables:
        state.message = open_viewer(state.variables[state.selected])
    elif key == ord("w"):
        toggle_watch(state, now)
    elif key == ord("d"):
        delete_selected(state, target_pane, now, language)
    elif key == ord("y") and state.variables:
        state.message = copy_text(state.variables[state.selected].name)

    clamp_state(state, height)
    return True


def run(window: curses.window, args: argparse.Namespace) -> None:
    """Run the curses variable browser."""

    curses.curs_set(0)
    curses.mousemask(curses.ALL_MOUSE_EVENTS)
    init_colors(window)
    window.keypad(True)
    window.timeout(200)

    state = ViewState(variables=[])
    last_load = 0.0

    while True:
        height, _ = window.getmaxyx()
        now = time.monotonic()

        if now - last_load >= args.refresh_seconds:
            variables, updated_at, message = load_variables(args.vars_file)
            update_variables(state, variables, updated_at, message, now, height)
            last_load = now

        draw(window, state)
        key = window.getch()
        if key == -1:
            continue
        if not handle_key(key, state, args.target_pane, height, time.monotonic(), args.language):
            break


def main() -> None:
    """Run the variable browser from the command line."""

    args = parse_args()
    curses.wrapper(run, args)


if __name__ == "__main__":
    main()
