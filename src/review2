    "dracula": {
        "foreground": (248, 248, 242),
        "comment": (98, 114, 164),
        "cyan": (139, 233, 253),
        "green": (80, 250, 123),
        "orange": (255, 184, 108),
        "pink": (255, 121, 198),
        "purple": (189, 147, 249),
        "red": (255, 85, 85),
