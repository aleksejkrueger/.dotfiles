#!/usr/bin/env python3
"""CLI review helper with file checklist state and publishable inline comments."""

from __future__ import annotations

import argparse
import curses
import hashlib
import json
import os
import re
import shlex
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Sequence
from urllib.parse import quote


REVIEW_MARKER_RE = re.compile(r"(?P<prefix>#|//|--|;|/\*|\*)\s*review\b:?\s*(?P<body>.*)$", re.IGNORECASE)
LEGACY_MARKER_RE = re.compile(r"\bREVIEW2:\s*(?P<body>.*)$")
MARKER_RE = re.compile(r"(?:#|//|--|;|/\*|\*)\s*review\b:?.*$|\bREVIEW2:\s*.*$", re.IGNORECASE)
ANSI_RE = re.compile(r"\x1b\[[0-9;?]*[ -/]*[@-~]")
BASIC_ANSI_COLOR_CODES = {*range(30, 38), *range(90, 98)}
HELP_TEXT = (
    "/ search  f filter  j/k move  J/K scroll  Space toggle  c/e edit  d pager  p publish  "
    "r refresh  q quit"
)
FILE_FILTERS = ("all", "unchecked", "checked")
DRACULA_ANSI_COLORS = {
    "foreground": 15,
    "comment": 4,
    "cyan": 6,
    "green": 2,
    "orange": 3,
    "pink": 5,
    "purple": 5,
    "red": 1,
    "yellow": 3,
}


@dataclass(frozen=True)
class ChangedFile:
    """A file changed against the selected base ref."""

    index: int
    path: str


@dataclass(frozen=True)
class ReviewComment:
    """A local inline review comment marker."""

    path: str
    marker_line: int
    target_line: int
    body: str


@dataclass(frozen=True)
class StyledSegment:
    """A text segment with optional terminal styling."""

    text: str
    color: int = -1
    bold: bool = False
    reverse: bool = False


